<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="VinhKhanhTourDemo.MainPage"
             BackgroundColor="#F5F6F8">

    <Grid RowDefinitions="Auto, Auto, *, Auto">
        <Border Grid.Row="0" Stroke="Transparent" Padding="20,15,20,10" Margin="0">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="0,0,15,15" />
            </Border.StrokeShape>
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#FF5722" Offset="0.0" />
                    <GradientStop Color="#FF8A65" Offset="1.0" />
                </LinearGradientBrush>
            </Border.Background>
            <Grid ColumnDefinitions="Auto, *, Auto" VerticalOptions="Center">
                <Image Grid.Column="0" Source="icon_app.png" WidthRequest="40" HeightRequest="40" />
                <VerticalStackLayout Grid.Column="1" Margin="15,0">
                    <Label Text="Vĩnh Khánh Tour" TextColor="White" FontSize="20" FontAttributes="Bold" />
                    <Label Text="Khám Phá Phố Ẩm Thực" TextColor="White" FontSize="14" Opacity="0.8" />
                </VerticalStackLayout>
            </Grid>
        </Border>

        <VerticalStackLayout Grid.Row="1" Spacing="15" Padding="20,15,20,0">
            <Border Stroke="#E0E0E0" BackgroundColor="White" Padding="15,10">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10" />
                </Border.StrokeShape>
                <Grid ColumnDefinitions="Auto, *, Auto">
                    <Entry Grid.Column="1" Placeholder="Tìm quán ăn, món ốc..." FontSize="16" />
                </Grid>
            </Border>
        </VerticalStackLayout>

        <ScrollView x:Name="ViewKhamPha" Grid.Row="2" VerticalScrollBarVisibility="Never" IsVisible="True">
            <VerticalStackLayout Spacing="20" Padding="20">
                <Label Text="Điểm Đến Gần Bạn" FontSize="18" FontAttributes="Bold" TextColor="#333333"/>

                <Border Stroke="Transparent" BackgroundColor="White">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="15" />
                    </Border.StrokeShape>
                    <Grid RowDefinitions="160, Auto">
                        <Image Source="https://images.unsplash.com/photo-1555396273-367ea4eb4db5?q=80&amp;w=800" Aspect="AspectFill" Grid.Row="0"/>
                        <VerticalStackLayout Grid.Row="1" Padding="15" Spacing="8">
                            <Label Text="Quán Ốc Oanh" FontSize="18" FontAttributes="Bold" TextColor="Black"/>
                            <Label Text="Cách bạn: 20 mét • Hải sản tươi sống" FontSize="14" TextColor="#666666"/>
                            <Button Text="🎧 Nghe Thuyết Minh" BackgroundColor="#4CAF50" TextColor="White" CornerRadius="8" Margin="0,10,0,0" FontAttributes="Bold" Clicked="OnListenClicked"/>
                        </VerticalStackLayout>
                    </Grid>
                </Border>

                <Border Stroke="Transparent" BackgroundColor="White">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="15" />
                    </Border.StrokeShape>
                    <Grid RowDefinitions="160, Auto">
                        <Image Source="https://images.unsplash.com/photo-1565557623262-b51c2513a641?q=80&amp;w=800" Aspect="AspectFill" Grid.Row="0"/>
                        <VerticalStackLayout Grid.Row="1" Padding="15" Spacing="8">
                            <Label Text="Quán Ốc Vũ" FontSize="18" FontAttributes="Bold" TextColor="Black"/>
                            <Label Text="Cách bạn: 150 mét • Rộng rãi" FontSize="14" TextColor="#666666"/>
                            <Button Text="🚶 Dẫn Đường" BackgroundColor="#2196F3" TextColor="White" CornerRadius="8" Margin="0,10,0,0" FontAttributes="Bold"/>
                        </VerticalStackLayout>
                    </Grid>
                </Border>
            </VerticalStackLayout>
        </ScrollView>

        <Grid x:Name="ViewBanDo" Grid.Row="2" IsVisible="False" Padding="0">
            <WebView x:Name="MapWebView" HorizontalOptions="Fill" VerticalOptions="Fill" />
        </Grid>


        <Border Grid.Row="3" Stroke="Transparent" Padding="15" BackgroundColor="White">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="15,15,0,0" />
            </Border.StrokeShape>
            <Border.Shadow>
                <Shadow Brush="Black" Offset="0,-2" Opacity="0.1" Radius="5" />
            </Border.Shadow>
            <Grid ColumnDefinitions="*, *, *">

                <VerticalStackLayout x:Name="BtnKhamPha" Grid.Column="0" Spacing="5" HorizontalOptions="Center" VerticalOptions="Center" Opacity="1.0" BackgroundColor="Transparent">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnTabKhamPhaTapped" />
                    </VerticalStackLayout.GestureRecognizers>
                    <Label x:Name="LblKhamPha" Text="Khám Phá" FontSize="14" TextColor="#FF5722" FontAttributes="Bold"/>
                </VerticalStackLayout>

                <VerticalStackLayout x:Name="BtnBanDo" Grid.Column="1" Spacing="5" HorizontalOptions="Center" VerticalOptions="Center" Opacity="0.4" BackgroundColor="Transparent">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnTabBanDoTapped" />
                    </VerticalStackLayout.GestureRecognizers>
                    <Label x:Name="LblBanDo" Text="Bản Đồ" FontSize="14" TextColor="Black" FontAttributes="Bold"/>
                </VerticalStackLayout>

                <VerticalStackLayout Grid.Column="2" Spacing="5" HorizontalOptions="Center" VerticalOptions="Center" Opacity="0.4">
                    <Label Text="Cài Đặt" FontSize="14" TextColor="Black" FontAttributes="Bold"/>
                </VerticalStackLayout>

            </Grid>
        </Border>
    </Grid>
</ContentPage>