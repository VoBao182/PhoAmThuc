<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="VinhKhanhTourDemo.MainPage"
             BackgroundColor="#F5F6F8"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto, Auto, Auto, *, Auto"
          BackgroundColor="#F5F6F8">

        <Border Grid.Row="0" Stroke="Transparent" Padding="20,12,20,14">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="0,0,20,20"/>
            </Border.StrokeShape>
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#FF5722" Offset="0.0"/>
                    <GradientStop Color="#FF8A65" Offset="1.0"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid ColumnDefinitions="Auto, *, Auto" VerticalOptions="Center">
                <Border Grid.Column="0"
                        BackgroundColor="#00000022"
                        Stroke="Transparent"
                        Padding="8"
                        WidthRequest="48"
                        HeightRequest="48">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="12"/>
                    </Border.StrokeShape>
                    <Label Text="VK"
                           FontSize="18"
                           FontAttributes="Bold"
                           TextColor="White"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"/>
                </Border>
                <VerticalStackLayout Grid.Column="1"
                                     Margin="14,0"
                                     Spacing="1"
                                     VerticalOptions="Center">
                    <Label x:Name="LblHeaderTitle"
                           Text="Vinh Khanh Tour"
                           TextColor="White"
                           FontSize="19"
                           FontAttributes="Bold"/>
                    <Label x:Name="LblHeaderSub"
                           Text="Khám phá phố ẩm thực"
                           TextColor="White"
                           FontSize="13"
                           Opacity="0.85"/>
                </VerticalStackLayout>
                <Border Grid.Column="2"
                        x:Name="GpsStatusDot"
                        BackgroundColor="#4CAF50"
                        Stroke="White"
                        StrokeThickness="1.5"
                        WidthRequest="14"
                        HeightRequest="14"
                        VerticalOptions="Center">
                    <Border.StrokeShape>
                        <Ellipse/>
                    </Border.StrokeShape>
                </Border>
            </Grid>
        </Border>

        <Border x:Name="NowPlayingBanner"
                Grid.Row="1"
                IsVisible="False"
                Stroke="Transparent"
                Padding="16,10">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#E65100" Offset="0.0"/>
                    <GradientStop Color="#FF6D00" Offset="1.0"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid ColumnDefinitions="Auto, *, Auto">
                <Label Grid.Column="0"
                       x:Name="NowPlayingIcon"
                       Text="AUDIO"
                       FontSize="10"
                       VerticalOptions="Center"
                       Margin="0,0,10,0"/>
                <VerticalStackLayout Grid.Column="1"
                                     Spacing="1"
                                     VerticalOptions="Center">
                    <Label x:Name="NowPlayingTitle"
                           Text="Đang phát thuyết minh"
                           TextColor="White"
                           FontSize="11"
                           FontAttributes="Bold"
                           Opacity="0.85"/>
                    <Label x:Name="NowPlayingName"
                           Text=""
                           TextColor="White"
                           FontSize="15"
                           FontAttributes="Bold"/>
                </VerticalStackLayout>
                <Button Grid.Column="2"
                        x:Name="BtnNowPlayingDetail"
                        Text="Chi tiết"
                        BackgroundColor="White"
                        TextColor="#E65100"
                        CornerRadius="20"
                        FontSize="12"
                        FontAttributes="Bold"
                        Padding="12,6"
                        Clicked="OnNowPlayingDetailClicked"/>
            </Grid>
        </Border>

        <Border x:Name="SearchBarRow"
                Grid.Row="2"
                Stroke="#E8E8E8"
                BackgroundColor="White"
                Padding="14,10"
                Margin="16,12,16,0">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="14"/>
            </Border.StrokeShape>
            <Border.Shadow>
                <Shadow Brush="Black" Offset="0,2" Opacity="0.05" Radius="6"/>
            </Border.Shadow>
            <Grid ColumnDefinitions="Auto, *" ColumnSpacing="10">
                <Border Grid.Column="0"
                        BackgroundColor="#FFF3E0"
                        Stroke="Transparent"
                        Padding="8,4">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="10"/>
                    </Border.StrokeShape>
                    <Label Text="Find"
                           FontSize="11"
                           FontAttributes="Bold"
                           TextColor="#E65100"
                           VerticalOptions="Center"/>
                </Border>
                <Entry x:Name="SearchEntry"
                       Grid.Column="1"
                       Placeholder="Tìm quán ăn, địa chỉ..."
                       FontSize="15"
                       TextColor="#111111"
                       PlaceholderColor="#AAAAAA"
                       VerticalOptions="Center"
                       TextChanged="OnSearchTextChanged"/>
            </Grid>
        </Border>

        <ScrollView x:Name="ViewKhamPha"
                    Grid.Row="3"
                    VerticalScrollBarVisibility="Never"
                    IsVisible="True">
            <VerticalStackLayout Spacing="16" Padding="16,14,16,8">
                <Grid ColumnDefinitions="*, Auto">
                    <Label x:Name="LblNearbyTitle"
                           Grid.Column="0"
                           Text="Điểm đến gần bạn"
                           FontSize="18"
                           FontAttributes="Bold"
                           TextColor="#1a1a1a"/>
                    <Label Grid.Column="1"
                           x:Name="LblPoiCount"
                           Text=""
                           FontSize="13"
                           TextColor="#FF5722"
                           VerticalOptions="Center"/>
                </Grid>
                <VerticalStackLayout x:Name="PoiListContainer" Spacing="14"/>
            </VerticalStackLayout>
        </ScrollView>

        <Grid x:Name="ViewBanDo" Grid.Row="3" IsVisible="False">
            <Grid x:Name="MapHost"
                  HorizontalOptions="Fill"
                  VerticalOptions="Fill">
                <VerticalStackLayout HorizontalOptions="Center"
                                     VerticalOptions="Center"
                                     Spacing="10">
                    <ActivityIndicator IsRunning="True"
                                       Color="#FF5722"
                                       HorizontalOptions="Center"/>
                    <Label Text="Ban do se tai khi mo tab nay"
                           FontSize="14"
                           TextColor="#777777"
                           HorizontalOptions="Center"/>
                </VerticalStackLayout>
            </Grid>

            <Border x:Name="MapPoiSheet"
                    IsVisible="False"
                    VerticalOptions="End"
                    HorizontalOptions="Fill"
                    Stroke="Transparent"
                    BackgroundColor="White"
                    Padding="20,16,20,28">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="24,24,0,0"/>
                </Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="Black" Offset="0,-4" Opacity="0.15" Radius="16"/>
                </Border.Shadow>
                <VerticalStackLayout Spacing="12">
                    <BoxView HorizontalOptions="Center"
                             WidthRequest="40"
                             HeightRequest="4"
                             CornerRadius="2"
                             Color="#DDDDDD"
                             Margin="0,0,0,4"/>
                    <Grid ColumnDefinitions="84, *" ColumnSpacing="14">
                        <Border Grid.Column="0"
                                Stroke="Transparent"
                                HeightRequest="84"
                                WidthRequest="84">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="12"/>
                            </Border.StrokeShape>
                            <Image x:Name="SheetImg" Aspect="AspectFill"/>
                        </Border>
                        <VerticalStackLayout Grid.Column="1"
                                             Spacing="3"
                                             VerticalOptions="Center">
                            <Label x:Name="SheetTen"
                                   FontSize="17"
                                   FontAttributes="Bold"
                                   TextColor="#1a1a1a"/>
                            <Label x:Name="SheetDiaChi"
                                   FontSize="13"
                                   TextColor="#777"/>
                            <Label x:Name="SheetSDT"
                                   FontSize="13"
                                   TextColor="#FF5722"/>
                            <Border x:Name="SheetNearBadge"
                                    IsVisible="False"
                                    BackgroundColor="#FFF3E0"
                                    Stroke="#FF6600"
                                    StrokeThickness="1"
                                    Padding="8,3">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="20"/>
                                </Border.StrokeShape>
                                <Label x:Name="LblSheetNearBadge"
                                       Text="Đang trong vùng audio"
                                       FontSize="11"
                                       TextColor="#E65100"
                                       FontAttributes="Bold"/>
                            </Border>
                        </VerticalStackLayout>
                    </Grid>
                    <Grid ColumnDefinitions="*, *"
                          ColumnSpacing="12"
                          Margin="0,4,0,0">
                        <Button Grid.Column="0"
                                x:Name="SheetBtnDetail"
                                Text="Xem chi tiết"
                                BackgroundColor="#FF5722"
                                TextColor="White"
                                CornerRadius="12"
                                FontAttributes="Bold"
                                FontSize="14"
                                HeightRequest="48"
                                Clicked="OnSheetDetailClicked"/>
                        <Button Grid.Column="1"
                                x:Name="SheetBtnMap"
                                Text="Chỉ đường"
                                BackgroundColor="#2196F3"
                                TextColor="White"
                                CornerRadius="12"
                                FontAttributes="Bold"
                                FontSize="14"
                                HeightRequest="48"
                                Clicked="OnSheetMapClicked"/>
                    </Grid>
                    <Button x:Name="BtnSheetClose"
                            Text="Đóng"
                            BackgroundColor="Transparent"
                            TextColor="#AAAAAA"
                            FontSize="13"
                            Padding="0"
                            HeightRequest="32"
                            Clicked="OnSheetCloseClicked"/>
                </VerticalStackLayout>
            </Border>
        </Grid>

        <ScrollView x:Name="ViewCaiDat"
                    Grid.Row="3"
                    IsVisible="False"
                    VerticalScrollBarVisibility="Never">
            <VerticalStackLayout Spacing="0" Padding="0,0,0,32">

                <!-- ── PROFILE HEADER ── -->
                <Border Stroke="Transparent" Padding="20,32,20,28">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#FF5722" Offset="0.0"/>
                            <GradientStop Color="#FF8A65" Offset="1.0"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.StrokeShape><RoundRectangle CornerRadius="0,0,28,28"/></Border.StrokeShape>
                    <VerticalStackLayout Spacing="16">

                        <!-- Avatar + Name row -->
                        <HorizontalStackLayout Spacing="18" HorizontalOptions="Center">
                            <Border BackgroundColor="#FFF7E6"
                                    Stroke="#FFE1BF" StrokeThickness="2.5"
                                    WidthRequest="76" HeightRequest="76">
                                <Border.StrokeShape><Ellipse/></Border.StrokeShape>
                                <Label x:Name="LblUserName"
                                       Text="VK"
                                       FontSize="26" FontAttributes="Bold"
                                       TextColor="#F97316"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center"/>
                            </Border>
                            <VerticalStackLayout Spacing="5" VerticalOptions="Center">
                                <Label Text="Khách VK"
                                       FontSize="20" FontAttributes="Bold"
                                       TextColor="White"/>
                                <Label x:Name="LblUserRole"
                                       Text="Thám tử ẩm thực · Cấp 1"
                                       FontSize="13" TextColor="White" Opacity="0.85"/>
                                <Border BackgroundColor="#FFF7ED"
                                        Stroke="Transparent" Padding="10,4"
                                        HorizontalOptions="Start">
                                    <Border.StrokeShape><RoundRectangle CornerRadius="20"/></Border.StrokeShape>
                                    <Label Text="+ Explorer"
                                           FontSize="11" TextColor="#C2410C" FontAttributes="Bold"/>
                                </Border>
                            </VerticalStackLayout>
                        </HorizontalStackLayout>

                        <!-- XP Bar -->
                        <VerticalStackLayout Spacing="6">
                            <Grid ColumnDefinitions="*, Auto">
                                <Label Grid.Column="0" Text="Kinh nghiệm khám phá"
                                       FontSize="12" TextColor="White" Opacity="0.8"/>
                                <Label x:Name="LblXpProgress" Grid.Column="1" Text="XP: 0 / 500"
                                       FontSize="12" TextColor="White" FontAttributes="Bold"/>
                            </Grid>
                            <ProgressBar x:Name="ProfileXpBar"
                                         Progress="0"
                                         ProgressColor="White"
                                         BackgroundColor="#FF6D40"
                                         HeightRequest="7"/>
                        </VerticalStackLayout>

                    </VerticalStackLayout>
                </Border>

                <!-- ── BADGES ── -->
                <Grid ColumnDefinitions="*, *, *" Padding="16,16,16,4" ColumnSpacing="10" IsVisible="False">
                    <Border Grid.Column="0" BackgroundColor="White" Stroke="#F3F4F6"
                            StrokeThickness="1" Padding="0,14">
                        <Border.StrokeShape><RoundRectangle CornerRadius="14"/></Border.StrokeShape>
                        <Border.Shadow><Shadow Brush="Black" Offset="0,1" Opacity="0.04" Radius="4"/></Border.Shadow>
                        <VerticalStackLayout Spacing="5" HorizontalOptions="Center">
                            <Label Text="🏆" FontSize="22" HorizontalOptions="Center"/>
                            <Label Text="Nhà vô địch" FontSize="10" TextColor="#555"
                                   HorizontalOptions="Center" FontAttributes="Bold"/>
                            <Label Text="Chưa mở" FontSize="10" TextColor="#CCC" HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Border>
                    <Border Grid.Column="1" BackgroundColor="White" Stroke="#F3F4F6"
                            StrokeThickness="1" Padding="0,14">
                        <Border.StrokeShape><RoundRectangle CornerRadius="14"/></Border.StrokeShape>
                        <Border.Shadow><Shadow Brush="Black" Offset="0,1" Opacity="0.04" Radius="4"/></Border.Shadow>
                        <VerticalStackLayout Spacing="5" HorizontalOptions="Center">
                            <Label Text="🗺" FontSize="22" HorizontalOptions="Center"/>
                            <Label Text="Khám phá" FontSize="10" TextColor="#555"
                                   HorizontalOptions="Center" FontAttributes="Bold"/>
                            <Label Text="Chưa mở" FontSize="10" TextColor="#CCC" HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Border>
                    <Border Grid.Column="2" BackgroundColor="White" Stroke="#F3F4F6"
                            StrokeThickness="1" Padding="0,14">
                        <Border.StrokeShape><RoundRectangle CornerRadius="14"/></Border.StrokeShape>
                        <Border.Shadow><Shadow Brush="Black" Offset="0,1" Opacity="0.04" Radius="4"/></Border.Shadow>
                        <VerticalStackLayout Spacing="5" HorizontalOptions="Center">
                            <Label Text="⭐" FontSize="22" HorizontalOptions="Center"/>
                            <Label Text="Huyền thoại" FontSize="10" TextColor="#555"
                                   HorizontalOptions="Center" FontAttributes="Bold"/>
                            <Label Text="Chưa mở" FontSize="10" TextColor="#CCC" HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <!-- ── STATS ── -->
                <Grid ColumnDefinitions="*, *" Padding="16,10,16,4" ColumnSpacing="10" IsVisible="False">
                    <Border Grid.Column="0" BackgroundColor="White" Stroke="#F3F4F6" StrokeThickness="1">
                        <Border.StrokeShape><RoundRectangle CornerRadius="14"/></Border.StrokeShape>
                        <Border.Shadow><Shadow Brush="Black" Offset="0,1" Opacity="0.04" Radius="4"/></Border.Shadow>
                        <VerticalStackLayout HorizontalOptions="Center" Padding="12,14" Spacing="4">
                            <Label x:Name="LblStatQuanXem" Text="0"
                                   FontSize="30" FontAttributes="Bold"
                                   TextColor="#FF5722" HorizontalOptions="Center"/>
                            <Label Text="Quán đã ghé" FontSize="12"
                                   TextColor="#777" HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Border>
                    <Border Grid.Column="1" BackgroundColor="White" Stroke="#F3F4F6" StrokeThickness="1">
                        <Border.StrokeShape><RoundRectangle CornerRadius="14"/></Border.StrokeShape>
                        <Border.Shadow><Shadow Brush="Black" Offset="0,1" Opacity="0.04" Radius="4"/></Border.Shadow>
                        <VerticalStackLayout HorizontalOptions="Center" Padding="12,14" Spacing="4">
                            <Label Text="Ẩm thực" FontSize="16" FontAttributes="Bold"
                                   TextColor="#2196F3" HorizontalOptions="Center"/>
                            <Label Text="Chuyên gia" FontSize="12"
                                   TextColor="#777" HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <Grid ColumnDefinitions="*, *" Padding="16,10,16,4" ColumnSpacing="10">
                    <Border Grid.Column="0" BackgroundColor="White" Stroke="#F3F4F6" StrokeThickness="1">
                        <Border.StrokeShape><RoundRectangle CornerRadius="14"/></Border.StrokeShape>
                        <Border.Shadow><Shadow Brush="Black" Offset="0,1" Opacity="0.04" Radius="4"/></Border.Shadow>
                        <VerticalStackLayout HorizontalOptions="Center" Padding="12,14" Spacing="4">
                            <Label x:Name="LblStatQuanXemV2" Text="0"
                                   FontSize="30" FontAttributes="Bold"
                                   TextColor="#FF5722" HorizontalOptions="Center"/>
                            <Label Text="Quán đã xem" FontSize="12"
                                   TextColor="#777" HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Border>
                    <Border Grid.Column="1" BackgroundColor="White" Stroke="#F3F4F6" StrokeThickness="1">
                        <Border.StrokeShape><RoundRectangle CornerRadius="14"/></Border.StrokeShape>
                        <Border.Shadow><Shadow Brush="Black" Offset="0,1" Opacity="0.04" Radius="4"/></Border.Shadow>
                        <VerticalStackLayout HorizontalOptions="Center" Padding="12,14" Spacing="4">
                            <Label x:Name="LblStatQuanGheV2" Text="0"
                                   FontSize="30" FontAttributes="Bold"
                                   TextColor="#2196F3" HorizontalOptions="Center"/>
                            <Label Text="Quán đã ghé" FontSize="12"
                                   TextColor="#777" HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <!-- ── SETTINGS CARD ── -->
                <Border BackgroundColor="White" Stroke="#F3F4F6"
                        StrokeThickness="1" Margin="16,12,16,4">
                    <Border.StrokeShape><RoundRectangle CornerRadius="16"/></Border.StrokeShape>
                    <Border.Shadow><Shadow Brush="Black" Offset="0,2" Opacity="0.05" Radius="6"/></Border.Shadow>
                    <VerticalStackLayout>

                        <Label Text="CÀI ĐẶT"
                               FontSize="11" FontAttributes="Bold"
                               TextColor="#9CA3AF" CharacterSpacing="1"
                               Padding="16,14,16,6"/>

                        <!-- Ngôn ngữ -->
                        <Grid ColumnDefinitions="36, *, Auto" ColumnSpacing="12" Padding="16,12">
                            <Label Grid.Column="0" Text="🌐" FontSize="20" VerticalOptions="Center"/>
                            <VerticalStackLayout Grid.Column="1" Spacing="1" VerticalOptions="Center">
                                <Label x:Name="LblLanguageCaption"
                                       Text="Ngôn ngữ thuyết minh"
                                       FontSize="12" TextColor="#999"/>
                                <Label x:Name="LblUserLang"
                                       Text="Tiếng Việt"
                                       FontSize="14" FontAttributes="Bold" TextColor="#1a1a1a"/>
                            </VerticalStackLayout>
                            <Label Grid.Column="2" Text="›" FontSize="22"
                                   TextColor="#CCC" VerticalOptions="Center"/>
                        </Grid>

                        <BoxView HeightRequest="0.5" Color="#F3F4F6" Margin="16,0"/>

                        <!-- Gói đăng ký -->
                        <Grid ColumnDefinitions="36, *, Auto" ColumnSpacing="12" Padding="16,12">
                            <Label Grid.Column="0" Text="✨" FontSize="20" VerticalOptions="Center"/>
                            <VerticalStackLayout Grid.Column="1" Spacing="1" VerticalOptions="Center">
                                <Label x:Name="LblSubCaption"
                                       Text="Gói đăng ký"
                                       FontSize="12" TextColor="#999"/>
                                <Label x:Name="LblSubStatus"
                                       Text="—"
                                       FontSize="14" FontAttributes="Bold" TextColor="#1a1a1a"/>
                            </VerticalStackLayout>
                            <Label Grid.Column="2" Text="›" FontSize="22"
                                   TextColor="#CCC" VerticalOptions="Center"/>
                        </Grid>

                        <BoxView HeightRequest="0.5" Color="#F3F4F6" Margin="16,0"/>

                        <!-- Mã thiết bị -->
                        <Grid ColumnDefinitions="36, *" ColumnSpacing="12" Padding="16,12">
                            <Label Grid.Column="0" Text="📱" FontSize="20" VerticalOptions="Center"/>
                            <VerticalStackLayout Grid.Column="1" Spacing="1" VerticalOptions="Center">
                                <Label x:Name="LblLocalDataCaption"
                                       Text="Mã thiết bị"
                                       FontSize="12" TextColor="#999"/>
                                <Label x:Name="LblUserPhone"
                                       Text="—"
                                       FontSize="13" TextColor="#555"/>
                            </VerticalStackLayout>
                        </Grid>

                        <VerticalStackLayout Padding="16,0,16,12" Spacing="10">
                            <Border BackgroundColor="#FFF7ED"
                                    Stroke="#FED7AA"
                                    StrokeThickness="1"
                                    Padding="12">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="14"/>
                                </Border.StrokeShape>
                                <VerticalStackLayout Spacing="10">
                                    <Label Text="Mã khôi phục dữ liệu"
                                           FontSize="12"
                                           TextColor="#C2410C"
                                           FontAttributes="Bold"/>
                                    <Label x:Name="LblRecoveryCode"
                                           Text="VKT-DEVICE:"
                                           FontSize="11"
                                           TextColor="#7C2D12"
                                           LineBreakMode="CharacterWrap"/>
                                    <Image x:Name="ImgDeviceQr"
                                           HeightRequest="150"
                                           WidthRequest="150"
                                           HorizontalOptions="Center"
                                           Aspect="AspectFit"/>
                                    <Grid ColumnDefinitions="*, *" ColumnSpacing="10">
                                        <Button x:Name="BtnCopyDeviceCode"
                                                Grid.Column="0"
                                                Text="Copy mã"
                                                BackgroundColor="#FFEDD5"
                                                TextColor="#C2410C"
                                                CornerRadius="12"
                                                FontSize="13"
                                                FontAttributes="Bold"
                                                Clicked="OnCopyDeviceCodeClicked"/>
                                        <Button x:Name="BtnRestoreDeviceCode"
                                                Grid.Column="1"
                                                Text="Nhập mã cũ"
                                                BackgroundColor="#1F2937"
                                                TextColor="White"
                                                CornerRadius="12"
                                                FontSize="13"
                                                FontAttributes="Bold"
                                                Clicked="OnRestoreDeviceCodeClicked"/>
                                    </Grid>
                                    <Label Text="Nếu cài lại trên cùng thiết bị, app sẽ tự nhận lại mã này. Nếu cần hỗ trợ dữ liệu cũ, hãy lưu mã/QR trước khi xóa app."
                                           FontSize="11"
                                           TextColor="#9A3412"/>
                                </VerticalStackLayout>
                            </Border>
                        </VerticalStackLayout>

                        <BoxView HeightRequest="0.5" Color="#F3F4F6" Margin="16,0"/>

                        <!-- Chế độ (hidden label kept for code compat) -->
                        <Grid ColumnDefinitions="36, *" ColumnSpacing="12" Padding="16,12">
                            <Label Grid.Column="0" Text="👤" FontSize="20" VerticalOptions="Center"/>
                            <VerticalStackLayout Grid.Column="1" Spacing="1" VerticalOptions="Center">
                                <Label x:Name="LblModeCaption"
                                       Text="Chế độ"
                                       FontSize="12" TextColor="#999"/>
                                <Label x:Name="LblUserUsername"
                                       Text="Khách ẩn danh"
                                       FontSize="14" FontAttributes="Bold" TextColor="#1a1a1a"/>
                            </VerticalStackLayout>
                        </Grid>

                    </VerticalStackLayout>
                </Border>

                <!-- ── BUTTONS ── -->
                <Button x:Name="BtnGiaHan"
                        Text="Gia hạn gói"
                        BackgroundColor="#FF5722"
                        TextColor="White"
                        CornerRadius="14"
                        FontSize="15"
                        FontAttributes="Bold"
                        HeightRequest="52"
                        Margin="16,12,16,10"
                        Clicked="OnGiaHanClicked"/>

                <Button x:Name="BtnReloadData"
                        Text="Tải lại dữ liệu"
                        BackgroundColor="#FFF3E0"
                        TextColor="#E65100"
                        CornerRadius="14"
                        FontSize="15"
                        FontAttributes="Bold"
                        HeightRequest="52"
                        Margin="16,0,16,0"
                        Clicked="OnReloadDataClicked"/>

            </VerticalStackLayout>
        </ScrollView>

        <Border Grid.Row="4" Stroke="Transparent" BackgroundColor="White" Padding="10,10,10,12">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="20,20,0,0"/>
            </Border.StrokeShape>
            <Border.Shadow>
                <Shadow Brush="Black" Offset="0,-2" Opacity="0.08" Radius="8"/>
            </Border.Shadow>
            <Grid ColumnDefinitions="*, *, *">
                <VerticalStackLayout x:Name="BtnKhamPha"
                                     Grid.Column="0"
                                     Spacing="4"
                                     Padding="0,2"
                                     WidthRequest="96"
                                     HorizontalOptions="Center"
                                     VerticalOptions="Center"
                                     Opacity="1.0">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnTabKhamPhaTapped"/>
                    </VerticalStackLayout.GestureRecognizers>
                    <Label x:Name="IconKhamPha"
                           Text="🍜"
                           FontSize="22"
                           HorizontalOptions="Center"/>
                    <Label x:Name="LblKhamPha"
                           Text="Khám phá"
                           FontFamily="OpenSansSemibold"
                           FontSize="11"
                           TextColor="#FF5722"
                           HorizontalOptions="Center"/>
                </VerticalStackLayout>

                <VerticalStackLayout x:Name="BtnBanDo"
                                     Grid.Column="1"
                                     Spacing="4"
                                     Padding="0,2"
                                     WidthRequest="96"
                                     HorizontalOptions="Center"
                                     VerticalOptions="Center"
                                     Opacity="0.45">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnTabBanDoTapped"/>
                    </VerticalStackLayout.GestureRecognizers>
                    <Label x:Name="IconBanDo"
                           Text="🗺"
                           FontSize="22"
                           HorizontalOptions="Center"/>
                    <Label x:Name="LblBanDo"
                           Text="Bản đồ"
                           FontFamily="OpenSansSemibold"
                           FontSize="11"
                           TextColor="#888"
                           HorizontalOptions="Center"/>
                </VerticalStackLayout>

                <VerticalStackLayout x:Name="BtnCaiDat"
                                     Grid.Column="2"
                                     Spacing="4"
                                     Padding="0,2"
                                     WidthRequest="96"
                                     HorizontalOptions="Center"
                                     VerticalOptions="Center"
                                     Opacity="0.45">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnTabCaiDatTapped"/>
                    </VerticalStackLayout.GestureRecognizers>
                    <Label x:Name="IconCaiDat"
                           Text="👤"
                           FontSize="22"
                           HorizontalOptions="Center"/>
                    <Label x:Name="LblCaiDat"
                           Text="Hồ sơ"
                           FontFamily="OpenSansSemibold"
                           FontSize="11"
                           TextColor="#888"
                           HorizontalOptions="Center"/>
                </VerticalStackLayout>
            </Grid>
        </Border>
    </Grid>
</ContentPage>
