<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="VinhKhanhTourDemo.LaunchPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    BackgroundColor="#F7F2EB"
    Shell.NavBarIsVisible="False">

    <Grid Padding="28,44,28,32">
        <VerticalStackLayout Spacing="16"
                             HorizontalOptions="Center"
                             VerticalOptions="Center">
            <Label Text="Vinh Khanh Tour"
                   FontSize="28"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"
                   TextColor="#C2410C"/>
            <Label x:Name="LblStatus"
                   Text="Đang khởi động ứng dụng..."
                   FontSize="15"
                   HorizontalTextAlignment="Center"
                   HorizontalOptions="Center"
                   TextColor="#4B5563"/>
            <ActivityIndicator x:Name="BootIndicator"
                               IsRunning="True"
                               IsVisible="True"
                               Color="#FF5722"
                               HorizontalOptions="Center"/>
            <Button x:Name="BtnRetry"
                    IsVisible="False"
                    Text="Thử lại"
                    BackgroundColor="#FF5722"
                    TextColor="White"
                    CornerRadius="12"
                    FontAttributes="Bold"
                    HeightRequest="46"
                    WidthRequest="180"
                    Clicked="OnRetryClicked"/>
        </VerticalStackLayout>
    </Grid>
</ContentPage>
