<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="VinhKhanhTourDemo.QrScannerPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:zxing="clr-namespace:ZXing.Net.Maui.Controls;assembly=ZXing.Net.MAUI.Controls"
    AutomationId="qr-scanner-page"
    BackgroundColor="#111827"
    Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto, *, Auto">
        <Grid Grid.Row="0" ColumnDefinitions="*, Auto" Padding="20,18">
            <VerticalStackLayout Grid.Column="0" Spacing="2">
                <Label Text="Quet ma QR khoi phuc"
                       FontSize="20"
                       FontAttributes="Bold"
                       TextColor="White"/>
                <Label Text="Dua ma QR vao khung camera"
                       FontSize="13"
                       TextColor="#D1D5DB"/>
            </VerticalStackLayout>
            <Button Grid.Column="1"
                    AutomationId="qr-scanner-close-button"
                    Text="Dong"
                    BackgroundColor="#374151"
                    TextColor="White"
                    CornerRadius="12"
                    Clicked="OnCloseClicked"/>
        </Grid>

        <Border Grid.Row="1"
                Margin="18,8"
                Stroke="#F97316"
                StrokeThickness="2"
                BackgroundColor="#000000">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="18"/>
            </Border.StrokeShape>
            <zxing:CameraBarcodeReaderView
                x:Name="CameraBarcodeReader"
                AutomationId="qr-scanner-camera"
                BarcodesDetected="OnBarcodesDetected"/>
        </Border>

        <VerticalStackLayout Grid.Row="2" Padding="20,12,20,28" Spacing="10">
            <Label x:Name="LblStatus"
                   AutomationId="qr-scanner-status"
                   Text="Dang cho ma QR..."
                   TextColor="#F9FAFB"
                   FontSize="13"
                   HorizontalTextAlignment="Center"/>
            <Grid ColumnDefinitions="*, *" ColumnSpacing="10">
                <Button Grid.Column="0"
                        AutomationId="qr-scanner-torch-button"
                        Text="Bat/tat den"
                        BackgroundColor="#F97316"
                        TextColor="White"
                        CornerRadius="12"
                        Clicked="OnTorchClicked"/>
                <Button Grid.Column="1"
                        AutomationId="qr-scanner-flip-camera-button"
                        Text="Doi camera"
                        BackgroundColor="#374151"
                        TextColor="White"
                        CornerRadius="12"
                        Clicked="OnFlipCameraClicked"/>
            </Grid>
        </VerticalStackLayout>
    </Grid>
</ContentPage>
