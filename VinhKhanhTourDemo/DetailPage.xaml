<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="VinhKhanhTourDemo.DetailPage"
             BackgroundColor="#F5F6F8">

    <Shell.TitleView>
        <Label x:Name="LblTitle"
               TextColor="White" FontSize="18" FontAttributes="Bold"
               VerticalOptions="Center"/>
    </Shell.TitleView>

    <ScrollView>
        <VerticalStackLayout Spacing="0">

            <!-- ===== ẢNH BÌA + LOADING INDICATOR ===== -->
            <Grid HeightRequest="240">
                <Image x:Name="ImgCover"
                       Aspect="AspectFill"
                       HeightRequest="240"/>
                <!-- Gradient overlay phía dưới ảnh -->
                <BoxView VerticalOptions="End"
                         HeightRequest="80"
                         Opacity="0.45">
                    <BoxView.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="Transparent" Offset="0"/>
                            <GradientStop Color="Black" Offset="1"/>
                        </LinearGradientBrush>
                    </BoxView.Background>
                </BoxView>
                <!-- Loading spinner -->
                <ActivityIndicator x:Name="LoadingIndicator"
                                   IsRunning="True" IsVisible="True"
                                   Color="#e67e22"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"/>
            </Grid>

            <!-- ===== THÔNG TIN CƠ BẢN ===== -->
            <VerticalStackLayout Padding="20,16" Spacing="6"
                                 BackgroundColor="White">
                <Label x:Name="LblTen" FontSize="22"
                       FontAttributes="Bold" TextColor="#222"/>
                <Label x:Name="LblDiaChi" FontSize="14"
                       TextColor="#666"/>
                <Label x:Name="LblSDT" FontSize="14"
                       TextColor="#e67e22"/>
            </VerticalStackLayout>

            <!-- ===== NÚT HÀNH ĐỘNG ===== -->
            <Grid ColumnDefinitions="*,*" Padding="16,12"
                  ColumnSpacing="12" BackgroundColor="White">
                <Button x:Name="BtnNghe" Grid.Column="0"
                        Text="🎧 Nghe thuyết minh"
                        BackgroundColor="#4CAF50" TextColor="White"
                        CornerRadius="10" FontAttributes="Bold"
                        FontSize="13"
                        Clicked="OnNgheClicked"/>
                <Button x:Name="BtnMap" Grid.Column="1"
                        Text="📍 Chỉ đường"
                        BackgroundColor="#2196F3" TextColor="White"
                        CornerRadius="10" FontAttributes="Bold"
                        FontSize="13"
                        Clicked="OnMapClicked"/>
            </Grid>

            <VerticalStackLayout x:Name="AudioControls"
                                 Padding="16,0,16,12"
                                 Spacing="10"
                                 BackgroundColor="White"
                                 IsVisible="False">
                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                    <Label x:Name="LblAudioCurrent"
                           Text="0:00"
                           FontSize="12"
                           TextColor="#666"
                           VerticalOptions="Center"/>
                    <Slider x:Name="AudioProgressSlider"
                            Grid.Column="1"
                            Minimum="0"
                            Maximum="1"
                            ValueChanged="OnAudioSliderValueChanged"
                            DragStarted="OnAudioSliderDragStarted"
                            DragCompleted="OnAudioSliderDragCompleted"/>
                    <Label x:Name="LblAudioDuration"
                           Grid.Column="2"
                           Text="0:00"
                           FontSize="12"
                           TextColor="#666"
                           VerticalOptions="Center"/>
                </Grid>
                <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                    <Button x:Name="BtnPlayPauseAudio"
                            Grid.Column="0"
                            Text="Play audio"
                            BackgroundColor="#FF8A65"
                            TextColor="White"
                            CornerRadius="10"
                            FontAttributes="Bold"
                            FontSize="13"
                            Clicked="OnPlayPauseClicked"/>
                    <Button x:Name="BtnStopAudio"
                            Grid.Column="1"
                            Text="Stop"
                            BackgroundColor="#EEEEEE"
                            TextColor="#444"
                            CornerRadius="10"
                            FontAttributes="Bold"
                            FontSize="13"
                            Clicked="OnStopAudioClicked"/>
                </Grid>
            </VerticalStackLayout>

            <WebView x:Name="AudioWebView"
                     HeightRequest="1"
                     WidthRequest="1"
                     Opacity="0"
                     IsVisible="False"
                     Navigated="OnAudioWebViewNavigated"
                     Navigating="OnAudioWebViewNavigating"/>

            <!-- ===== GIỚI THIỆU / THUYẾT MINH ===== -->
            <VerticalStackLayout Padding="20,16" Spacing="10"
                                 BackgroundColor="White" Margin="0,8,0,0">
                <Label x:Name="LblSectionGioiThieu"
                       Text="Giới thiệu" FontSize="16"
                       FontAttributes="Bold" TextColor="#333"/>
                <BoxView HeightRequest="2" Color="#e67e22"
                         HorizontalOptions="Start" WidthRequest="40"/>
                <Label x:Name="LblThuyetMinh" FontSize="15"
                       TextColor="#444" LineHeight="1.6"/>
            </VerticalStackLayout>

            <!-- ===== THỰC ĐƠN ===== -->
            <VerticalStackLayout x:Name="SectionMenu"
                                 Padding="20,16" Spacing="12"
                                 BackgroundColor="White" Margin="0,8,0,16"
                                 IsVisible="False">
                <Label x:Name="LblSectionThucDon"
                       Text="Thực đơn" FontSize="16"
                       FontAttributes="Bold" TextColor="#333"/>
                <BoxView HeightRequest="2" Color="#e67e22"
                         HorizontalOptions="Start" WidthRequest="40"/>
                <VerticalStackLayout x:Name="MenuContainer" Spacing="10"/>
            </VerticalStackLayout>

            <BoxView HeightRequest="20" Color="Transparent"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
