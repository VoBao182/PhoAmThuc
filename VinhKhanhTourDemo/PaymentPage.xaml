<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="VinhKhanhTourDemo.PaymentPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    BackgroundColor="#F7F2EB"
    Shell.NavBarIsVisible="False">

    <ScrollView>
        <VerticalStackLayout Padding="24,48,24,32" Spacing="0">

            <Label Text="QR"
                   FontSize="34"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"
                   Margin="0,0,0,8"
                   TextColor="#E36A11"/>
            <Label Text="Thanh toán chuyển khoản"
                   FontSize="22"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"
                   TextColor="#1F2933"
                   Margin="0,0,0,4"/>
            <Label x:Name="LblTenGoi"
                   FontSize="14"
                   HorizontalOptions="Center"
                   TextColor="#6B7280"
                   Margin="0,0,0,28"/>

            <Border BackgroundColor="White"
                    Stroke="#E5E7EB"
                    StrokeThickness="1.5"
                    Margin="0,0,0,20">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="20"/>
                </Border.StrokeShape>
                <VerticalStackLayout Padding="24,20" Spacing="16">

                    <Label Text="Quét mã QR để chuyển khoản"
                           FontSize="14"
                           FontAttributes="Bold"
                           HorizontalOptions="Center"
                           TextColor="#1F2933"/>

                    <Image x:Name="ImgQR"
                           HeightRequest="220"
                           WidthRequest="220"
                           HorizontalOptions="Center"
                           Aspect="AspectFit"/>

                    <Border BackgroundColor="#F9FAFB"
                            Stroke="#E5E7EB"
                            StrokeThickness="1">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="12"/>
                        </Border.StrokeShape>
                        <Grid RowDefinitions="Auto,Auto,Auto,Auto" Padding="16,12" RowSpacing="8">
                            <Grid Grid.Row="0" ColumnDefinitions="*,*">
                                <Label Grid.Column="0"
                                       Text="Ngân hàng"
                                       FontSize="12"
                                       TextColor="#6B7280"/>
                                <Label Grid.Column="1"
                                       Text="MBBank"
                                       FontSize="12"
                                       FontAttributes="Bold"
                                       TextColor="#1F2933"
                                       HorizontalOptions="End"/>
                            </Grid>
                            <Grid Grid.Row="1" ColumnDefinitions="*,*">
                                <Label Grid.Column="0"
                                       Text="Số tài khoản"
                                       FontSize="12"
                                       TextColor="#6B7280"/>
                                <Label x:Name="LblSoTK"
                                       Grid.Column="1"
                                       FontSize="12"
                                       FontAttributes="Bold"
                                       TextColor="#1F2933"
                                       HorizontalOptions="End"/>
                            </Grid>
                            <Grid Grid.Row="2" ColumnDefinitions="*,*">
                                <Label Grid.Column="0"
                                       Text="Số tiền"
                                       FontSize="12"
                                       TextColor="#6B7280"/>
                                <Label x:Name="LblSoTien"
                                       Grid.Column="1"
                                       FontSize="13"
                                       FontAttributes="Bold"
                                       TextColor="#16A34A"
                                       HorizontalOptions="End"/>
                            </Grid>
                            <Grid Grid.Row="3" ColumnDefinitions="*,Auto">
                                <Label Grid.Column="0"
                                       Text="Nội dung CK"
                                       FontSize="12"
                                       TextColor="#6B7280"
                                       VerticalOptions="Center"/>
                                <HorizontalStackLayout Grid.Column="1" Spacing="8" HorizontalOptions="End">
                                    <Label x:Name="LblNoiDung"
                                           FontSize="12"
                                           FontAttributes="Bold"
                                           TextColor="#E36A11"/>
                                    <Button x:Name="BtnCopyNoiDung"
                                            Text="Copy"
                                            FontSize="12"
                                            BackgroundColor="Transparent"
                                            TextColor="#E36A11"
                                            Padding="2,0"
                                            HeightRequest="28"
                                            Clicked="OnCopyNoiDungClicked"/>
                                </HorizontalStackLayout>
                            </Grid>
                        </Grid>
                    </Border>

                    <Label Text="Nhập đúng nội dung chuyển khoản để hệ thống xác nhận tự động"
                           FontSize="12"
                           TextColor="#92400E"
                           HorizontalOptions="Center"
                           HorizontalTextAlignment="Center"/>

                </VerticalStackLayout>
            </Border>

            <Label x:Name="LblError"
                   IsVisible="False"
                   TextColor="#DC2626"
                   FontSize="13"
                   HorizontalOptions="Center"
                   HorizontalTextAlignment="Center"
                   Margin="0,0,0,8"/>

            <Border x:Name="ApiGuideCard"
                    IsVisible="False"
                    BackgroundColor="White"
                    Stroke="#F59E0B"
                    StrokeThickness="1"
                    Margin="0,0,0,12">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="14"/>
                </Border.StrokeShape>
                <VerticalStackLayout Padding="14,12" Spacing="8">
                    <Label Text="Cần kết nối API để gửi yêu cầu thanh toán"
                           FontSize="13"
                           FontAttributes="Bold"
                           TextColor="#92400E"/>
                    <Label x:Name="LblApiGuideText"
                           FontSize="12"
                           TextColor="#6B7280"/>
                    <Label x:Name="LblApiGuideStatus"
                           FontSize="12"
                           TextColor="#E36A11"/>
                    <Button x:Name="BtnConfigureApi"
                            Text="Nhập API URL"
                            BackgroundColor="#FFF7ED"
                            TextColor="#C2410C"
                            CornerRadius="10"
                            FontSize="13"
                            FontAttributes="Bold"
                            HeightRequest="40"
                            Clicked="OnConfigureApiClicked"/>
                </VerticalStackLayout>
            </Border>

            <ActivityIndicator x:Name="LoadingIndicator"
                               IsRunning="False"
                               IsVisible="False"
                               Color="#E36A11"
                               HorizontalOptions="Center"
                               Margin="0,0,0,12"/>

            <Button x:Name="BtnDaChuyenKhoan"
                    Text="Tôi đã chuyển khoản"
                    BackgroundColor="#16A34A"
                    TextColor="White"
                    CornerRadius="14"
                    FontSize="15"
                    FontAttributes="Bold"
                    HeightRequest="52"
                    Margin="0,0,0,12"
                    Clicked="OnDaChuyenKhoanClicked"/>

            <Button Text="Hủy"
                    BackgroundColor="Transparent"
                    TextColor="#6B7280"
                    FontSize="14"
                    HeightRequest="44"
                    Clicked="OnHuyClicked"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
