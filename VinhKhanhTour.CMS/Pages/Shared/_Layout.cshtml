@{
    var autoRefreshSeconds = 0;
    if (int.TryParse(ViewData["AutoRefreshSeconds"]?.ToString(), out var parsedAutoRefreshSeconds) && parsedAutoRefreshSeconds > 0)
    {
        autoRefreshSeconds = parsedAutoRefreshSeconds;
    }
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Vĩnh Khánh CMS</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;500;600;700&family=Playfair+Display:wght@700&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg: #faf7f2;
            --surface: rgba(255,255,255,0.9);
            --surface-strong: #ffffff;
            --sidebar: #211b16;
            --sidebar-accent: #e36a11;
            --text: #1f2933;
            --muted: #6b7280;
            --border: rgba(31, 41, 51, 0.08);
            --shadow: 0 24px 60px rgba(31, 41, 51, 0.08);
            --radius-lg: 28px;
            --radius-md: 20px;
            --radius-sm: 14px;
        }

        * { box-sizing: border-box; }

        body {
            margin: 0;
            min-height: 100vh;
            background:
                radial-gradient(circle at top left, rgba(255, 143, 61, 0.18), transparent 28%),
                linear-gradient(180deg, #f7f2eb 0%, #efe7dc 100%);
            color: var(--text);
            font-family: "Be Vietnam Pro", system-ui, sans-serif;
        }

        .cms-shell {
            display: grid;
            grid-template-columns: 260px minmax(0, 1fr);
            min-height: 100vh;
        }

        .cms-sidebar {
            background: linear-gradient(180deg, #211b16 0%, #191410 100%);
            color: white;
            padding: 22px 16px;
            display: flex;
            flex-direction: column;
            gap: 22px;
            box-shadow: inset -1px 0 0 rgba(255,255,255,0.04);
        }

        .brand-block {
            padding: 10px 12px 16px;
            border-radius: 18px;
            background: transparent;
            border: none;
        }

        .brand-title {
            margin: 0;
            font-size: 1.9rem;
            font-weight: 700;
            font-family: "Playfair Display", Georgia, serif;
            line-height: 1.05;
        }

        .brand-sub {
            margin: 10px 0 0;
            color: #f08a3c;
            font-size: 0.74rem;
            font-weight: 700;
            letter-spacing: 0.09em;
            text-transform: uppercase;
        }

        .cms-nav {
            display: flex;
            flex-direction: column;
            gap: 10px;
            padding: 10px;
            border-radius: 24px;
            background: rgba(255,255,255,0.05);
            border: 1px solid rgba(255,255,255,0.08);
            box-shadow: inset 0 1px 0 rgba(255,255,255,0.04);
        }

        .cms-nav > a {
            display: flex;
            align-items: center;
            gap: 14px;
            padding: 14px 16px;
            border-radius: 18px;
            color: rgba(255,255,255,0.78);
            text-decoration: none;
            font-weight: 600;
            border: 1px solid transparent;
            transition: 0.2s ease;
        }

        .cms-nav > a:hover {
            color: white;
            background: rgba(255,255,255,0.08);
            border-color: rgba(255,255,255,0.08);
            transform: translateX(2px);
        }

        .cms-nav > a.active {
            color: #201712;
            background: linear-gradient(135deg, #fff6ec 0%, #ffd7b6 100%);
            border-color: rgba(255,255,255,0.18);
            box-shadow: 0 16px 28px rgba(227, 106, 17, 0.22);
        }

        .nav-icon {
            width: 28px;
            height: 28px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border-radius: 10px;
            background: rgba(255,255,255,0.08);
            text-align: center;
            font-size: 13px;
            font-weight: 700;
            opacity: 0.92;
        }

        .cms-nav > a.active .nav-icon {
            background: rgba(32, 23, 18, 0.08);
        }

        .cms-main {
            padding: 28px;
        }

        .cms-content {
            min-height: calc(100vh - 56px);
            background: rgba(255,255,255,0.64);
            backdrop-filter: blur(8px);
            border: 1px solid rgba(255,255,255,0.55);
            border-radius: 34px;
            padding: 30px;
            box-shadow: var(--shadow);
        }

        .dashboard-shell {
            display: grid;
            gap: 28px;
        }

        .dashboard-hero {
            display: flex;
            justify-content: space-between;
            gap: 24px;
            padding: 28px;
            border-radius: var(--radius-lg);
            background:
                linear-gradient(120deg, rgba(255,143,61,0.18), rgba(255,255,255,0.82)),
                linear-gradient(135deg, #ffffff, #fff5eb);
            border: 1px solid var(--border);
        }

        .dashboard-hero h1 {
            margin: 8px 0 10px;
            font-size: clamp(1.8rem, 3vw, 2.5rem);
            line-height: 1.1;
        }

        .dashboard-hero p {
            margin: 0;
            max-width: 720px;
            color: var(--muted);
            font-size: 1rem;
        }

        .eyebrow {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 6px 10px;
            border-radius: 999px;
            background: rgba(255, 143, 61, 0.14);
            color: #b45309;
            font-size: 0.78rem;
            font-weight: 700;
            letter-spacing: 0.04em;
            text-transform: uppercase;
        }

        .hero-badge {
            min-width: 180px;
            align-self: center;
            padding: 22px;
            border-radius: 24px;
            background: #1f2f3d;
            color: white;
            text-align: center;
            box-shadow: 0 18px 36px rgba(31, 47, 61, 0.18);
        }

        .hero-badge span {
            display: block;
            font-size: 2.4rem;
            font-weight: 800;
            line-height: 1;
        }

        .hero-badge small {
            display: block;
            margin-top: 8px;
            color: rgba(255,255,255,0.7);
            font-size: 0.9rem;
        }

        .stats-grid {
            display: grid;
            grid-template-columns: repeat(3, minmax(0, 1fr));
            gap: 18px;
        }

        .stat-tile {
            padding: 24px;
            border-radius: 22px;
            background: var(--surface-strong);
            border: 1px solid var(--border);
            box-shadow: 0 12px 26px rgba(15, 23, 42, 0.05);
        }

        .stat-tile.accent-orange { background: linear-gradient(180deg, #fff8f1 0%, #ffffff 100%); }
        .stat-tile.accent-blue { background: linear-gradient(180deg, #f3f8ff 0%, #ffffff 100%); }
        .stat-tile.accent-green { background: linear-gradient(180deg, #f2fbf6 0%, #ffffff 100%); }

        .tile-label {
            color: var(--muted);
            font-size: 0.92rem;
            font-weight: 600;
        }

        .tile-value {
            margin-top: 10px;
            font-size: 2.35rem;
            font-weight: 800;
            line-height: 1;
        }

        .tile-sub {
            margin-top: 10px;
            color: var(--muted);
            font-size: 0.95rem;
        }

        .dashboard-panel {
            padding: 24px;
            border-radius: 28px;
            background: var(--surface);
            border: 1px solid var(--border);
            box-shadow: 0 18px 44px rgba(15, 23, 42, 0.06);
        }

        .panel-head {
            display: flex;
            justify-content: space-between;
            align-items: end;
            gap: 18px;
            margin-bottom: 22px;
        }

        .panel-head h2 {
            margin: 8px 0 0;
            font-size: 1.6rem;
            font-weight: 750;
        }

        .panel-link {
            color: #d97706;
            font-weight: 700;
            text-decoration: none;
        }

        .poi-dashboard-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(290px, 1fr));
            gap: 18px;
        }

        .poi-dashboard-card {
            overflow: hidden;
            border-radius: 24px;
            background: white;
            border: 1px solid rgba(31, 41, 51, 0.07);
            box-shadow: 0 14px 30px rgba(15, 23, 42, 0.06);
        }

        .poi-cover {
            position: relative;
            aspect-ratio: 16 / 9;
            background: linear-gradient(135deg, #ffd4ad, #ffedd5);
        }

        .poi-cover-img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: block;
        }

        .poi-cover-fallback {
            position: absolute;
            inset: 0;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.8rem;
            font-weight: 800;
            color: #9a3412;
            letter-spacing: 0.08em;
        }

        .poi-card-body {
            padding: 18px;
            display: grid;
            gap: 18px;
        }

        .poi-card-top {
            display: flex;
            justify-content: space-between;
            align-items: start;
            gap: 16px;
        }

        .poi-card-top h3 {
            margin: 0;
            font-size: 1.2rem;
            font-weight: 750;
        }

        .poi-card-top p {
            margin: 6px 0 0;
            color: var(--muted);
            font-size: 0.95rem;
        }

        .status-pill {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            min-width: 68px;
            padding: 8px 12px;
            border-radius: 999px;
            font-size: 0.78rem;
            font-weight: 700;
        }

        .status-on {
            background: #e8f7ee;
            color: #19703c;
        }

        .status-off {
            background: #fdeaea;
            color: #b42318;
        }

        .poi-meta-row {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 12px;
        }

        .poi-meta {
            padding: 14px;
            border-radius: 18px;
            background: #f8fafc;
            border: 1px solid rgba(148, 163, 184, 0.16);
        }

        .meta-label {
            display: block;
            color: var(--muted);
            font-size: 0.82rem;
            margin-bottom: 4px;
        }

        .poi-meta strong {
            font-size: 1.05rem;
        }

        .poi-card-actions {
            display: flex;
            gap: 10px;
        }

        .cms-btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            padding: 11px 14px;
            border-radius: 14px;
            text-decoration: none;
            font-weight: 700;
            font-size: 0.92rem;
            transition: 0.18s ease;
        }

        .cms-btn:hover { transform: translateY(-1px); }

        .cms-btn-primary {
            background: linear-gradient(90deg, #ff8f3d, #ff7a1a);
            color: white;
            box-shadow: 0 14px 24px rgba(255, 122, 26, 0.2);
        }

        .cms-btn-ghost {
            background: #fff7ed;
            color: #c2410c;
        }

        @@media (max-width: 980px) {
            .cms-shell {
                grid-template-columns: 1fr;
            }

            .cms-sidebar {
                min-height: auto;
                padding-bottom: 14px;
            }

            .cms-main {
                padding: 16px;
            }

            .cms-content {
                padding: 18px;
                border-radius: 24px;
            }

            .stats-grid {
                grid-template-columns: 1fr;
            }

            .dashboard-hero {
                flex-direction: column;
            }
        }
    </style>
</head>
<body data-auto-refresh-seconds="@autoRefreshSeconds">
    <div class="cms-shell">
        <aside class="cms-sidebar">
            <div class="brand-block">
                <h1 class="brand-title">Vĩnh Khánh CMS</h1>
                <p class="brand-sub">Quản lý POI, thuyết minh và thống kê trên một giao diện gọn gàng.</p>
            </div>

            <nav class="cms-nav">
                <a href="/" class="@(ViewData["Page"]?.ToString() == "dashboard" ? "active" : "")">
                    <span class="nav-icon">DB</span>
                    <span>Dashboard</span>
                </a>
                <a href="/Poi" class="@(ViewData["Page"]?.ToString() == "poi" ? "active" : "")">
                    <span class="nav-icon">QA</span>
                    <span>Quán ăn</span>
                </a>
                <a href="/ThuyetMinh" class="@(ViewData["Page"]?.ToString() == "thuyetminh" ? "active" : "")">
                    <span class="nav-icon">TM</span>
                    <span>Thuyết minh</span>
                </a>
                <a href="/ThanhToan" class="@(ViewData["Page"]?.ToString() == "thanhtoan" ? "active" : "")">
                    <span class="nav-icon">💰</span>
                    <span>Phí duy trì</span>
                </a>
                <a href="/DuyetThanhToan" class="@(ViewData["Page"]?.ToString() == "duyetthanhtoan" ? "active" : "")">
                    <span class="nav-icon">✅</span>
                    <span>Duyệt thanh toán</span>
                </a>
                <a href="/BanDo" class="@(ViewData["Page"]?.ToString() == "bando" ? "active" : "")">
                    <span class="nav-icon">KH</span>
                    <span>Khách hàng</span>
                </a>
            </nav>
        </aside>

        <main class="cms-main">
            <div class="cms-content">
                @RenderBody()
            </div>
        </main>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        (() => {
            const refreshSeconds = Number(document.body.dataset.autoRefreshSeconds || '0');
            if (!Number.isFinite(refreshSeconds) || refreshSeconds <= 0) {
                return;
            }

            const refreshIntervalMs = Math.max(3000, refreshSeconds * 1000);
            let hasDirtyForm = false;

            const markDirty = (event) => {
                if (event.target instanceof HTMLElement && event.target.closest('form')) {
                    hasDirtyForm = true;
                }
            };

            document.addEventListener('input', markDirty, true);
            document.addEventListener('change', markDirty, true);
            document.addEventListener('submit', () => { hasDirtyForm = false; }, true);

            const shouldPauseRefresh = () => {
                if (document.hidden || hasDirtyForm) {
                    return true;
                }

                if (document.querySelector('.modal.show')) {
                    return true;
                }

                const activeElement = document.activeElement;
                return activeElement instanceof HTMLElement
                    && activeElement.matches('input, textarea, select, [contenteditable="true"]');
            };

            window.setInterval(() => {
                if (!shouldPauseRefresh()) {
                    window.location.reload();
                }
            }, refreshIntervalMs);
        })();
    </script>
    @RenderSection("Scripts", required: false)
</body>
</html>
