@page
@model VinhKhanhTour.CMS.Pages.BanDo.IndexModel
@{
    ViewData["Title"] = "Bản đồ live";
    ViewData["Page"]  = "bando";
    Layout = "/Pages/Shared/_Layout.cshtml";
}

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<style>
    .tracker-panel {
        height: 540px;
        overflow-y: auto;
        border-radius: 16px;
        border: 1px solid rgba(0,0,0,0.08);
        background: white;
    }
    .device-row {
        padding: 12px 14px;
        border-bottom: 1px solid #f3f4f6;
        cursor: pointer;
        transition: background 0.15s;
    }
    .device-row:hover  { background: #fef9f0; }
    .device-row.selected { background: #fff7ed; border-left: 3px solid #f97316; }
    .poi-badge {
        display: inline-block;
        padding: 2px 10px;
        border-radius: 99px;
        font-size: 11px;
        font-weight: 700;
        background: #dcfce7;
        color: #166534;
    }
    .poi-badge.moving { background: #f3f4f6; color: #6b7280; }
    .sub-ok   { font-size:11px; font-weight:700; color:#16a34a; }
    .sub-warn { font-size:11px; font-weight:700; color:#d97706; }
    .sub-exp  { font-size:11px; font-weight:700; color:#dc2626; }
    .stat-chip {
        display: inline-flex; align-items: center; gap: 4px;
        padding: 2px 8px; border-radius: 6px;
        font-size: 11px; font-weight: 600;
        background: #f1f5f9; color: #475569;
    }
    #map { border-radius: 16px; box-shadow: 0 4px 20px rgba(0,0,0,0.10); }
</style>

<!-- Header với bộ đếm nổi bật -->
<div class="d-flex justify-content-between align-items-start mb-3">
    <div>
        <h2 class="fw-bold mb-1">Bản đồ live</h2>
        <p class="text-muted mb-0 small">Theo dõi khách đang sử dụng app theo thời gian thực</p>
    </div>
    <div class="d-flex align-items-center gap-3">
        <div class="text-center px-4 py-2 rounded-3"
             style="background:linear-gradient(135deg,#16a34a,#15803d);color:white;min-width:120px">
            <div class="fs-2 fw-bold" id="lblCount">—</div>
            <div style="font-size:12px;opacity:0.85">khách đang online</div>
        </div>
        <div>
            <div class="text-muted small" id="lblLastUpdate">Đang tải…</div>
            <button class="btn btn-outline-secondary btn-sm mt-1 w-100"
                    onclick="loadData()">🔄 Làm mới</button>
        </div>
    </div>
</div>

<div class="row g-3">
    <!-- Bản đồ -->
    <div class="col-lg-8">
        <div id="map" style="height:540px"></div>
    </div>

    <!-- Panel danh sách khách -->
    <div class="col-lg-4">
        <div class="tracker-panel">
            <div class="p-3 border-bottom" style="background:#fafafa">
                <h6 class="fw-bold mb-0">Khách đang hoạt động</h6>
                <small class="text-muted">Cập nhật mỗi 30 giây • click để xem hành trình</small>
            </div>
            <div id="deviceList">
                <div class="p-3 text-muted text-center small">Đang tải…</div>
            </div>
        </div>
    </div>
</div>

<!-- Modal lịch sử hành trình -->
<div class="modal fade" id="modalHistory" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="modalHistoryTitle">Hành trình khách</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" id="modalHistoryBody">
                <div class="text-center py-4"><div class="spinner-border text-warning"></div></div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script>
const CENTER   = [10.7575, 106.7000];
const API_BASE = '@Model.ApiBaseUrl';
const POI_DATA = @Html.Raw(Model.PoisJson);

// ── Khởi tạo bản đồ ──────────────────────────────────────────────
const map = L.map('map').setView(CENTER, 17);
L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
    attribution: '© OpenStreetMap contributors'
}).addTo(map);

// Icon POI (cam)
const poiIcon = L.divIcon({
    className: '',
    html: `<div style="width:22px;height:22px;background:#f97316;border:3px solid white;
                border-radius:6px;box-shadow:0 2px 8px rgba(0,0,0,.28)"></div>`,
    iconSize: [22, 22], iconAnchor: [11, 11]
});

// Vẽ POI
POI_DATA.forEach(p => {
    L.marker([p.lat, p.lng], { icon: poiIcon })
        .addTo(map)
        .bindPopup(`<strong>${p.ten}</strong><br/><small class="text-muted">${p.diaChi ?? ''}</small>`);
});

// Layer khách
const guestLayer = L.layerGroup().addTo(map);
let   selectedDevice = null;

function makeGuestIcon(atPoi) {
    const bg    = atPoi ? '#22c55e' : '#94a3b8';
    const glow  = atPoi ? 'rgba(34,197,94,.35)' : 'rgba(148,163,184,.25)';
    return L.divIcon({
        className: '',
        html: `<div style="width:16px;height:16px;background:${bg};border:3px solid white;
                    border-radius:50%;box-shadow:0 0 0 4px ${glow}"></div>`,
        iconSize: [16, 16], iconAnchor: [8, 8]
    });
}

// ── Load dữ liệu ─────────────────────────────────────────────────
async function loadData() {
    try {
        const res  = await fetch(`${API_BASE}/api/heartbeat/active`);
        if (!res.ok) throw new Error('API error');
        const data = await res.json();

        // Cập nhật bộ đếm
        document.getElementById('lblCount').textContent = data.count;
        document.getElementById('lblLastUpdate').textContent =
            'Cập nhật: ' + new Date().toLocaleTimeString('vi-VN');

        // Vẽ lại markers
        guestLayer.clearLayers();
        data.items.forEach(item => {
            const atPoi = item.poiIdHienTai != null;
            const marker = L.marker([item.lat, item.lng], { icon: makeGuestIcon(atPoi) })
                .addTo(guestLayer)
                .bindPopup(buildPopup(item));
            marker._deviceShort = item.deviceShort;
        });

        // Cập nhật danh sách bên phải
        renderDeviceList(data.items);

    } catch (e) {
        console.error('Heartbeat error', e);
    }
}

function subHtml(item) {
    if (item.conLaiNgay == null)
        return `<span class="sub-exp">Hết hạn / chưa đăng ký</span>`;
    if (item.conLaiNgay <= 3)
        return `<span class="sub-warn">⚠ ${item.conLaiNgay} ngày còn</span>`;
    return `<span class="sub-ok">✓ ${item.conLaiNgay} ngày còn</span>`;
}

function buildPopup(item) {
    const poi  = item.tenPoiHienTai || 'Đang di chuyển';
    const time = new Date(item.lanCuoi).toLocaleTimeString('vi-VN');
    const atPoi = !!item.poiIdHienTai;
    return `
        <div style="min-width:210px">
            <div class="fw-bold mb-1" style="font-size:14px">
                <span style="color:#22c55e">●</span> Thiết bị ${item.deviceShort}
            </div>
            <div class="mb-1">
                <span style="display:inline-block;padding:2px 10px;border-radius:99px;font-size:11px;font-weight:700;
                      background:${atPoi ? '#dcfce7' : '#f3f4f6'};color:${atPoi ? '#166534' : '#6b7280'}">
                    ${atPoi ? '📍' : '🚶'} ${poi}
                </span>
            </div>
            <div class="d-flex gap-1 flex-wrap mb-1">
                <span style="font-size:11px;background:#f1f5f9;padding:2px 7px;border-radius:5px">🏠 ${item.soQuanDaGhe} ghé</span>
                <span style="font-size:11px;background:#f1f5f9;padding:2px 7px;border-radius:5px">👁 ${item.soQuanDaXem} xem</span>
            </div>
            <div class="mb-1">${subHtml(item)}</div>
            <div class="text-muted" style="font-size:11px">Cập nhật: ${time}</div>
            <button onclick="showHistory('${item.deviceShort}')"
                    class="btn btn-sm btn-outline-primary mt-2 w-100">
                📋 Xem hành trình
            </button>
        </div>`;
}

function renderDeviceList(items) {
    const el = document.getElementById('deviceList');
    if (!items.length) {
        el.innerHTML = '<div class="p-3 text-muted text-center small">Chưa có khách online.</div>';
        return;
    }

    el.innerHTML = items.map(item => {
        const atPoi      = !!item.poiIdHienTai;
        const poiLabel   = item.tenPoiHienTai || 'Đang di chuyển';
        const time       = new Date(item.lanCuoi).toLocaleTimeString('vi-VN');
        const isSelected = selectedDevice === item.deviceShort;
        return `
        <div class="device-row ${isSelected ? 'selected' : ''}"
             onclick="selectDevice('${item.deviceShort}', ${item.lat}, ${item.lng})">

            <!-- Dòng 1: tên thiết bị + hạn dùng -->
            <div class="d-flex justify-content-between align-items-start mb-1">
                <div class="fw-semibold" style="font-size:13px">
                    <span style="color:#22c55e;font-size:10px">●</span>
                    Thiết bị <span style="font-family:monospace">${item.deviceShort}</span>
                </div>
                <div>${subHtml(item)}</div>
            </div>

            <!-- Dòng 2: vị trí hiện tại -->
            <div class="mb-1">
                <span class="poi-badge ${atPoi ? '' : 'moving'}">
                    ${atPoi ? '📍' : '🚶'} ${poiLabel}
                </span>
            </div>

            <!-- Dòng 3: stats + thời gian -->
            <div class="d-flex gap-2 align-items-center flex-wrap mb-1">
                <span class="stat-chip">🏠 ${item.soQuanDaGhe} ghé</span>
                <span class="stat-chip">👁 ${item.soQuanDaXem} xem</span>
                <span class="text-muted ms-auto" style="font-size:10px">${time}</span>
            </div>

            <button onclick="event.stopPropagation();showHistory('${item.deviceShort}')"
                    class="btn btn-sm btn-outline-secondary w-100 py-0"
                    style="font-size:11px">📋 Xem hành trình</button>
        </div>`;
    }).join('');
}

function selectDevice(short, lat, lng) {
    selectedDevice = short;
    map.flyTo([lat, lng], 18, { duration: 0.8 });
    // Re-render list để highlight
    guestLayer.eachLayer(m => {
        if (m._deviceShort === short) m.openPopup();
    });
}

// ── Lịch sử hành trình ───────────────────────────────────────────
async function showHistory(deviceShort) {
    document.getElementById('modalHistoryTitle').textContent = `Hành trình khách ${deviceShort}`;
    document.getElementById('modalHistoryBody').innerHTML =
        '<div class="text-center py-4"><div class="spinner-border text-warning"></div></div>';

    const modal = new bootstrap.Modal(document.getElementById('modalHistory'));
    modal.show();

    try {
        const res  = await fetch(`${API_BASE}/api/heartbeat/history/${deviceShort}`);
        const data = await res.json();

        if (!data.lichSu?.length) {
            document.getElementById('modalHistoryBody').innerHTML =
                '<p class="text-muted text-center py-3">Chưa có lượt ghé thăm nào được ghi nhận.</p>';
            return;
        }

        const rows = data.lichSu.map((h, i) => `
            <tr>
                <td>${i + 1}</td>
                <td><strong>${h.tenPOI}</strong></td>
                <td class="text-muted small">${h.diaChi ?? '—'}</td>
                <td class="text-muted small">${new Date(h.thoiGian).toLocaleTimeString('vi-VN')}</td>
                <td>
                    <a href="https://maps.google.com/?q=${h.lat},${h.lng}" target="_blank"
                       class="btn btn-sm btn-outline-secondary py-0" style="font-size:11px">🗺 Maps</a>
                </td>
            </tr>`).join('');

        document.getElementById('modalHistoryBody').innerHTML = `
            <div class="d-flex gap-3 mb-3">
                <span class="badge bg-success fs-6">${data.soDiemDaGhe} điểm đã ghé</span>
                <span class="text-muted small align-self-center">(4 giờ gần nhất)</span>
            </div>
            <div class="table-responsive">
                <table class="table table-sm table-hover">
                    <thead class="table-light">
                        <tr><th>#</th><th>Địa điểm</th><th>Địa chỉ</th><th>Thời gian</th><th></th></tr>
                    </thead>
                    <tbody>${rows}</tbody>
                </table>
            </div>`;
    } catch {
        document.getElementById('modalHistoryBody').innerHTML =
            '<p class="text-danger text-center">Lỗi tải dữ liệu.</p>';
    }
}

// Tải lần đầu + tự động 30 giây
loadData();
setInterval(loadData, 30000);
</script>
}
