@page
@model VinhKhanhTour.CMS.Pages.BanDo.IndexModel
@{
    ViewData["Title"] = "Khách hàng";
    ViewData["Page"] = "bando";
    Layout = "/Pages/Shared/_Layout.cshtml";
}
<script>
    window.setTimeout(() => window.location.reload(), 10000);
</script>

<style>
    .customer-shell {
        display: grid;
        gap: 24px;
    }

    .customer-hero {
        display: flex;
        justify-content: space-between;
        gap: 20px;
        padding: 28px;
        border-radius: 28px;
        background:
            linear-gradient(120deg, rgba(255,143,61,0.16), rgba(255,255,255,0.92)),
            linear-gradient(135deg, #ffffff, #fff7ef);
        border: 1px solid rgba(31, 41, 51, 0.08);
    }

    .customer-hero h1 {
        margin: 10px 0 8px;
        font-size: clamp(1.7rem, 3vw, 2.35rem);
        line-height: 1.1;
    }

    .customer-hero p {
        margin: 0;
        max-width: 760px;
        color: #6b7280;
    }

    .customer-badge {
        min-width: 180px;
        align-self: center;
        padding: 20px 22px;
        border-radius: 24px;
        background: #1f2f3d;
        color: white;
        text-align: center;
        box-shadow: 0 18px 36px rgba(31, 47, 61, 0.18);
    }

    .customer-badge strong {
        display: block;
        font-size: 2.3rem;
        line-height: 1;
    }

    .customer-badge span {
        display: block;
        margin-top: 8px;
        color: rgba(255,255,255,0.72);
        font-size: 0.92rem;
    }

    .summary-grid {
        display: grid;
        grid-template-columns: repeat(5, minmax(0, 1fr));
        gap: 16px;
    }

    .summary-tile {
        padding: 22px;
        border-radius: 22px;
        background: #fff;
        border: 1px solid rgba(31, 41, 51, 0.08);
        box-shadow: 0 12px 24px rgba(15, 23, 42, 0.05);
    }

    .summary-tile strong {
        display: block;
        margin-top: 10px;
        font-size: 2rem;
        line-height: 1;
    }

    .summary-tile span {
        color: #6b7280;
        font-weight: 600;
        font-size: 0.92rem;
    }

    .customer-panel {
        padding: 24px;
        border-radius: 28px;
        background: rgba(255,255,255,0.88);
        border: 1px solid rgba(31, 41, 51, 0.08);
        box-shadow: 0 18px 40px rgba(15, 23, 42, 0.05);
    }

    .customer-panel-head {
        display: flex;
        justify-content: space-between;
        align-items: end;
        gap: 16px;
        margin-bottom: 18px;
    }

    .customer-panel-head h2 {
        margin: 6px 0 0;
        font-size: 1.5rem;
        font-weight: 750;
    }

    .customer-panel-head p {
        margin: 0;
        color: #6b7280;
    }

    .customer-table-wrap {
        overflow-x: auto;
    }

    .customer-table {
        width: 100%;
        min-width: 1120px;
        border-collapse: separate;
        border-spacing: 0;
    }

    .customer-table thead th {
        padding: 14px 16px;
        background: #f8fafc;
        color: #64748b;
        font-size: 0.83rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        border-bottom: 1px solid rgba(148, 163, 184, 0.16);
    }

    .customer-table tbody td {
        padding: 18px 16px;
        border-bottom: 1px solid rgba(226, 232, 240, 0.92);
        vertical-align: top;
    }

    .customer-table tbody tr:hover {
        background: #fffaf4;
    }

    .device-cell {
        display: grid;
        gap: 8px;
    }

    .device-short {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 76px;
        padding: 5px 10px;
        border-radius: 999px;
        background: #fff7ed;
        color: #c2410c;
        font-size: 0.76rem;
        font-weight: 700;
        letter-spacing: 0.06em;
    }

    .device-full {
        font-family: ui-monospace, SFMono-Regular, Consolas, monospace;
        color: #111827;
        font-size: 0.92rem;
        word-break: break-all;
    }

    .mini-note {
        color: #6b7280;
        font-size: 0.82rem;
    }

    .status-pill,
    .sub-pill {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 7px 12px;
        border-radius: 999px;
        font-size: 0.8rem;
        font-weight: 700;
        white-space: nowrap;
    }

    .status-online {
        background: #e8f7ee;
        color: #19703c;
    }

    .status-at-poi {
        background: #dcfce7;
        color: #166534;
    }

    .status-offline {
        background: #f3f4f6;
        color: #4b5563;
    }

    .status-empty {
        background: #fef2f2;
        color: #b91c1c;
    }

    .sub-active {
        background: #eff6ff;
        color: #1d4ed8;
    }

    .sub-warning {
        background: #fff7ed;
        color: #c2410c;
    }

    .sub-expired {
        background: #fef2f2;
        color: #b91c1c;
    }

    .poi-name {
        font-weight: 700;
        color: #111827;
    }

    .poi-empty {
        color: #9ca3af;
        font-style: italic;
    }

    .count-box {
        display: inline-flex;
        flex-direction: column;
        gap: 4px;
        min-width: 90px;
        padding: 12px 14px;
        border-radius: 16px;
        background: #f8fafc;
        border: 1px solid rgba(148, 163, 184, 0.15);
    }

    .count-box strong {
        font-size: 1.25rem;
        line-height: 1;
    }

    .count-box span {
        color: #64748b;
        font-size: 0.8rem;
        font-weight: 600;
    }

    .xp-card {
        display: grid;
        gap: 7px;
        min-width: 150px;
        padding: 12px 14px;
        border-radius: 16px;
        background: linear-gradient(135deg, #fff7ed, #ffedd5);
        border: 1px solid rgba(249, 115, 22, 0.18);
    }

    .xp-card strong {
        color: #9a3412;
        font-size: 1.05rem;
        line-height: 1;
    }

    .xp-card span {
        color: #c2410c;
        font-size: 0.78rem;
        font-weight: 700;
    }

    .xp-track {
        height: 7px;
        overflow: hidden;
        border-radius: 999px;
        background: rgba(194, 65, 12, 0.15);
    }

    .xp-fill {
        height: 100%;
        border-radius: inherit;
        background: linear-gradient(90deg, #f97316, #ea580c);
    }

    @@media (max-width: 1100px) {
        .summary-grid {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }

        .customer-hero {
            flex-direction: column;
        }
    }

    @@media (max-width: 720px) {
        .summary-grid {
            grid-template-columns: 1fr;
        }
    }
</style>

<section class="customer-shell">
    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="alert alert-warning rounded-4">@Model.ErrorMessage</div>
    }

    <div class="customer-hero">
        <div>
            <div class="eyebrow">Theo dõi khách hàng</div>
            <h1>Danh sách khách đang sử dụng app</h1>
        </div>
        <div class="customer-badge">
            <strong>@Model.TotalCustomers</strong>
            <span>thiết bị đã ghi nhận</span>
        </div>
    </div>

    <div class="summary-grid">
        <article class="summary-tile">
            <span>Tổng khách hàng</span>
            <strong>@Model.TotalCustomers</strong>
        </article>
        <article class="summary-tile">
            <span>Đang hoạt động</span>
            <strong>@Model.ActiveCustomers</strong>
        </article>
        <article class="summary-tile">
            <span>Đang ở quán</span>
            <strong>@Model.CustomersAtPoi</strong>
        </article>
        <article class="summary-tile">
            <span>Hết hạn</span>
            <strong>@Model.ExpiredCustomers</strong>
        </article>
        <article class="summary-tile">
            <span>Tong XP</span>
            <strong>@Model.TotalExperiencePoints.ToString("N0")</strong>
        </article>
    </div>

    <form method="get" class="customer-panel" style="padding:18px;">
        <div style="display:grid;grid-template-columns:2fr repeat(4, minmax(150px, 1fr)) auto;gap:12px;align-items:end;">
            <div>
                <label class="mini-note" style="font-weight:700;">Tim kiem</label>
                <input name="search" value="@Model.Search" class="form-control" placeholder="Ma thiet bi, quan hien tai..." />
            </div>
            <div>
                <label class="mini-note" style="font-weight:700;">Trang thai</label>
                <select name="status" class="form-select">
                    <option value="all" selected="@(Model.StatusFilter == "all")">Tat ca</option>
                    <option value="online" selected="@(Model.StatusFilter == "online")">Dang hoat dong</option>
                    <option value="at-poi" selected="@(Model.StatusFilter == "at-poi")">Dang o quan</option>
                    <option value="offline" selected="@(Model.StatusFilter == "offline")">Khong hoat dong</option>
                    <option value="never" selected="@(Model.StatusFilter == "never")">Chua heartbeat</option>
                    <option value="active-sub" selected="@(Model.StatusFilter == "active-sub")">Con goi</option>
                    <option value="expired" selected="@(Model.StatusFilter == "expired")">Het han</option>
                    <option value="no-sub" selected="@(Model.StatusFilter == "no-sub")">Chua co goi</option>
                </select>
            </div>
            <div>
                <label class="mini-note" style="font-weight:700;">Han su dung</label>
                <select name="expiry" class="form-select">
                    <option value="all" selected="@(Model.ExpiryFilter == "all")">Tat ca</option>
                    <option value="active" selected="@(Model.ExpiryFilter == "active")">Con han</option>
                    <option value="expiring7" selected="@(Model.ExpiryFilter == "expiring7")">Sap het han 7 ngay</option>
                    <option value="expired" selected="@(Model.ExpiryFilter == "expired")">Da het han</option>
                    <option value="none" selected="@(Model.ExpiryFilter == "none")">Chua co han</option>
                </select>
            </div>
            <div>
                <label class="mini-note" style="font-weight:700;">Sap xep</label>
                <select name="sort" class="form-select">
                    <option value="last" selected="@(Model.SortBy == "last")">Lan cuoi hoat dong</option>
                    <option value="expiry" selected="@(Model.SortBy == "expiry")">Han con lai</option>
                    <option value="experience" selected="@(Model.SortBy == "experience")">Kinh nghiem</option>
                    <option value="viewed" selected="@(Model.SortBy == "viewed")">So quan da xem</option>
                    <option value="visited" selected="@(Model.SortBy == "visited")">So quan da ghe</option>
                    <option value="device" selected="@(Model.SortBy == "device")">Ma thiet bi</option>
                    <option value="current" selected="@(Model.SortBy == "current")">Quan hien tai</option>
                </select>
            </div>
            <div>
                <label class="mini-note" style="font-weight:700;">Huong</label>
                <select name="dir" class="form-select">
                    <option value="desc" selected="@(Model.SortDir == "desc")">Cao xuong thap / moi nhat</option>
                    <option value="asc" selected="@(Model.SortDir == "asc")">Thap len cao / cu nhat</option>
                </select>
            </div>
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">Loc</button>
                <a href="/BanDo" class="btn btn-light">Xoa</a>
            </div>
        </div>
        <div class="mini-note" style="margin-top:10px;">Dang hien thi <strong>@Model.Customers.Count</strong> khach hang theo bo loc hien tai.</div>
    </form>

    <section class="customer-panel">
        <div class="customer-panel-head">
            <div>
                <div class="eyebrow">Thông tin khách hàng</div>
                <h2>Bảng theo dõi sử dụng</h2>
                <p>Tự động làm mới mỗi 10 giây để cập nhật khách đang hoạt động nhanh hơn.</p>
            </div>
        </div>

        <div class="customer-table-wrap">
            <table class="customer-table">
                <thead>
                    <tr>
                        <th>Mã thiết bị</th>
                        <th>Trạng thái</th>
                        <th>Thời hạn còn lại</th>
                        <th>Số quán đã xem</th>
                        <th>Số quán đã ghé</th>
                        <th>Kinh nghiệm</th>
                        <th>Đang ở quán nào</th>
                        <th>Lần cuối hoạt động</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Customers.Any())
                    {
                        @foreach (var customer in Model.Customers)
                        {
                            <tr>
                                <td>
                                    <div class="device-cell">
                                        <span class="device-short">@customer.DeviceShort</span>
                                        <div class="device-full">@customer.DeviceId</div>
                                    </div>
                                </td>
                                <td>
                                    <span class="status-pill @customer.StatusClass">@customer.StatusText</span>
                                </td>
                                <td>
                                    <div class="device-cell">
                                        <span class="sub-pill @customer.SubscriptionClass">@customer.SubscriptionText</span>
                                        <div class="mini-note">
                                            @(customer.ExpiresAt.HasValue
                                                ? customer.ExpiresAt.Value.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
                                                : "Chưa có gói đăng ký")
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <div class="count-box">
                                        <strong>@customer.ViewedPoiCount</strong>
                                        <span>quán đã xem</span>
                                    </div>
                                </td>
                                <td>
                                    <div class="count-box">
                                        <strong>@customer.VisitedPoiCount</strong>
                                        <span>quán đã ghé</span>
                                    </div>
                                </td>
                                <td>
                                    <div class="xp-card">
                                        <strong>Lv @customer.Level - @customer.ExperiencePoints.ToString("N0") XP</strong>
                                        <span>@customer.ExperienceInCurrentLevel / 500 XP cấp hiện tại</span>
                                        <div class="xp-track" aria-hidden="true">
                                            <div class="xp-fill" style="width:@customer.ExperienceProgressPercent%"></div>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    @if (!string.IsNullOrWhiteSpace(customer.CurrentPoiName))
                                    {
                                        <div class="poi-name">@customer.CurrentPoiName</div>
                                    }
                                    else
                                    {
                                        <div class="poi-empty">Không có</div>
                                    }
                                </td>
                                <td>
                                    @if (customer.LastHeartbeat.HasValue)
                                    {
                                        <div class="device-cell">
                                            <strong>@customer.LastHeartbeat.Value.ToLocalTime().ToString("dd/MM/yyyy HH:mm:ss")</strong>
                                            <span class="mini-note">cập nhật gần nhất</span>
                                        </div>
                                    }
                                    else
                                    {
                                        <span class="poi-empty">Chưa ghi nhận</span>
                                    }
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="8" class="text-center text-muted py-4">
                                Chưa có khách hàng nào được ghi nhận trong hệ thống.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </section>
</section>
