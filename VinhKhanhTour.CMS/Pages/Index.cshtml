@page
@model IndexModel
@using VinhKhanhTour.CMS.Utils
@{
    ViewData["Title"] = "Dashboard";
    ViewData["Page"] = "dashboard";
}

<section class="dashboard-shell">
    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="alert alert-warning">@Model.ErrorMessage</div>
    }

    <div class="dashboard-hero">
        <div>
            <div class="eyebrow">Tổng quan hệ thống</div>
            <h1>Dashboard quản lý Vĩnh Khánh Tour</h1>
            <p>Theo dõi nhanh số lượng điểm đến, món ăn và tình trạng nội dung trên CMS.</p>
        </div>
        <div class="hero-badge">
            <span>@Model.TongPOI</span>
            <small>POI đang hoạt động</small>
        </div>
    </div>

    @if (Model.SoQuanQuaHan > 0)
    {
        <div class="alert alert-danger d-flex align-items-center gap-3 rounded-4" role="alert">
            <span style="font-size:1.6rem">⚠️</span>
            <div>
                <strong>@Model.SoQuanQuaHan quán đang quá hạn duy trì</strong> — POI sẽ không hiển thị trên app cho đến khi gia hạn.
                <a href="/ThanhToan" class="alert-link ms-2">Xem ngay →</a>
            </div>
        </div>
    }

    <div class="stats-grid">
        <article class="stat-tile accent-orange">
            <div class="tile-label">Tổng POI</div>
            <div class="tile-value">@Model.TongPOI</div>
            <div class="tile-sub">Địa điểm đang hiển thị trên hệ thống</div>
        </article>
        <article class="stat-tile accent-blue">
            <div class="tile-label">Tổng món ăn</div>
            <div class="tile-value">@Model.TongMonAn</div>
            <div class="tile-sub">Món đang bật trong thực đơn</div>
        </article>
        <article class="stat-tile accent-green">
            <div class="tile-label">Ngôn ngữ</div>
            <div class="tile-value">3</div>
            <div class="tile-sub">Tiếng Việt, English, Zhongwen</div>
        </article>
    </div>

    <section class="dashboard-panel">
        <div class="panel-head">
            <div>
                <div class="eyebrow">Danh sách POI</div>
                <h2>Quán ăn nổi bật</h2>
            </div>
            <a href="/Poi" class="panel-link">Mở quản lý POI</a>
        </div>

        <div class="poi-dashboard-grid">
            @if (Model.POIs.Any())
            {
                @foreach (var p in Model.POIs)
                {
                    var coverImageUrl = ImageUrlHelper.ResolvePoi(p.AnhDaiDien, Model.ApiBaseUrl, p.TenPOI);
                    var coverFallbackUrl = ImageUrlHelper.ResolvePoi(null, Model.ApiBaseUrl, p.TenPOI);
                    <article class="poi-dashboard-card">
                        <div class="poi-cover">
                            <img src="@coverImageUrl" alt="@p.TenPOI" class="poi-cover-img"
                                 onerror="this.onerror=null;this.src='@coverFallbackUrl';" />
                        </div>

                        <div class="poi-card-body">
                            <div class="poi-card-top">
                                <div>
                                    <h3>@p.TenPOI</h3>
                                    <p>@(string.IsNullOrWhiteSpace(p.DiaChi) ? "Phố Vĩnh Khánh, Quận 4" : p.DiaChi)</p>
                                </div>
                                <span class="status-pill @(p.TrangThai ? "status-on" : "status-off")">
                                    @(p.TrangThai ? "Hiện" : "Ẩn")
                                </span>
                            </div>

                            <div class="poi-meta-row">
                                <div class="poi-meta">
                                    <span class="meta-label">Món đang bật</span>
                                    <strong>@p.MonAns.Count(m => m.TinhTrang)</strong>
                                </div>
                                <div class="poi-meta">
                                    <span class="meta-label">Tổng món</span>
                                    <strong>@p.MonAns.Count</strong>
                                </div>
                            </div>

                            <div class="poi-card-actions">
                                <a href="/Poi/Edit/@p.Id" class="cms-btn cms-btn-primary">Chỉnh sửa</a>
                                <a href="/Poi/Edit/@p.Id#menu-section" class="cms-btn cms-btn-ghost">Xem món ăn</a>
                            </div>
                        </div>
                    </article>
                }
            }
            else
            {
                <article class="poi-dashboard-card">
                    <div class="poi-card-body">
                        <div class="poi-card-top">
                            <div>
                                <h3>Chưa có dữ liệu POI</h3>
                                <p>Kiểm tra kết nối Supabase, API hoặc dữ liệu nguồn rồi tải lại trang.</p>
                            </div>
                        </div>
                    </div>
                </article>
            }
        </div>
    </section>
</section>
