@page
@model VinhKhanhTour.CMS.Pages.Poi.CreateModel
@{
    ViewData["Title"] = "Thêm quán mới";
    ViewData["Page"]  = "poi";
}

<form method="post">
    <input type="hidden" id="monan-count" name="monan-count" value="0"/>

    <div class="grid-2" style="align-items:start;gap:24px">

        <!-- CỘT TRÁI -->
        <div style="display:flex;flex-direction:column;gap:20px">
            <div class="card">
                <div class="card-title">🏪 Thông tin quán</div>

                <div class="form-group">
                    <label class="form-label">Tên quán <span style="color:var(--danger)">*</span></label>
                    <input asp-for="POI.TenPOI" class="form-input" required placeholder="VD: Quán Ốc Oanh"/>
                </div>

                <div class="grid-2">
                    <div class="form-group">
                        <label class="form-label">Số điện thoại</label>
                        <input asp-for="POI.SDT" class="form-input" placeholder="028 xxxx xxxx"/>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Thứ tự hiển thị</label>
                        <input asp-for="POI.MucUuTien" type="number" class="form-input" value="1"/>
                    </div>
                </div>

                <div class="form-group">
                    <label class="form-label">Địa chỉ</label>
                    <input asp-for="POI.DiaChi" class="form-input" placeholder="Số nhà, Phố Vĩnh Khánh, Q4"/>
                </div>

                <div class="grid-2">
                    <div class="form-group">
                        <label class="form-label">Vĩ độ (Lat)</label>
                        <input asp-for="POI.ViDo" type="number" step="any" class="form-input" placeholder="10.758955"/>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Kinh độ (Lng)</label>
                        <input asp-for="POI.KinhDo" type="number" step="any" class="form-input" placeholder="106.701831"/>
                    </div>
                </div>

                <div class="form-group">
                    <label class="form-label">Bán kính geofence (m)</label>
                    <input asp-for="POI.BanKinh" type="number" class="form-input" value="10"/>
                </div>

                <div class="form-group">
                    <label class="form-label">
                        <input type="checkbox" asp-for="POI.TrangThai" checked style="margin-right:6px"/>
                        Hiển thị trên app
                    </label>
                </div>
            </div>

            <div class="card">
                <div class="card-title">🖼️ Ảnh bìa</div>
                <div class="form-group">
                    <label class="form-label">URL ảnh</label>
                    <input asp-for="POI.AnhDaiDien" class="form-input"
                           placeholder="https://..."
                           oninput="previewImg(this,'preview-cover')"/>
                </div>
                <img id="preview-cover" style="display:none;width:100%;height:160px;object-fit:cover;border-radius:8px;margin-top:8px"/>
            </div>
        </div>

        <!-- CỘT PHẢI: Thuyết minh -->
        <div class="card">
            <div class="card-title">🎙️ Nội dung thuyết minh</div>
            <div class="lang-tabs">
                <button type="button" id="tab-tm-vi" class="lang-tab active-vi"
                        data-tab-group="tm" onclick="switchLang('vi','tm')">🇻🇳 Tiếng Việt</button>
                <button type="button" id="tab-tm-en" class="lang-tab"
                        data-tab-group="tm" onclick="switchLang('en','tm')">🇬🇧 English</button>
                <button type="button" id="tab-tm-zh" class="lang-tab"
                        data-tab-group="tm" onclick="switchLang('zh','tm')">🇨🇳 中文</button>
            </div>
            <div id="panel-tm-vi" class="lang-panel show" data-group="tm">
                <textarea name="ThuyetMinhVi" class="form-textarea" rows="10"
                          placeholder="Nhập nội dung thuyết minh tiếng Việt..."></textarea>
            </div>
            <div id="panel-tm-en" class="lang-panel" data-group="tm">
                <textarea name="ThuyetMinhEn" class="form-textarea" rows="10"
                          placeholder="Enter English audio guide content..."></textarea>
            </div>
            <div id="panel-tm-zh" class="lang-panel" data-group="tm">
                <textarea name="ThuyetMinhZh" class="form-textarea" rows="10"
                          placeholder="请输入中文语音导览内容..."></textarea>
            </div>
        </div>
    </div>

    <!-- THỰC ĐƠN -->
    <div class="card mt-6">
        <div class="flex-between mb-4">
            <div class="card-title" style="margin-bottom:0">🍽️ Thực đơn</div>
            <button type="button" class="btn btn-ghost btn-sm" onclick="addMonAn()">＋ Thêm món</button>
        </div>
        <div id="monan-list">
            <div style="text-align:center;padding:32px;color:var(--text-muted);font-size:14px">
                Nhấn "Thêm món" để thêm món ăn
            </div>
        </div>
    </div>

    <div class="flex-between mt-6">
        <a href="/Poi" class="btn btn-ghost">← Quay lại</a>
        <button type="submit" class="btn btn-primary">＋ Tạo quán</button>
    </div>
</form>
