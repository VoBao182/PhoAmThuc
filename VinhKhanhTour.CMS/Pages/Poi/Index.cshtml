@page
@model VinhKhanhTour.CMS.Pages.Poi.IndexModel
@{
    ViewData["Title"] = "Quản lý quán ăn";
    ViewData["Page"] = "poi";
}

<div class="flex-between mb-4">
    <div>
        <div style="font-size:12px;color:var(--text-muted);margin-bottom:4px;">Nội dung quán ăn</div>
        <div style="font-size:24px;font-weight:700;color:var(--text);">Quản lý quán và món ăn</div>
    </div>
    <a href="/Poi/Create" class="btn btn-primary">+ Thêm quán mới</a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <div class="alert alert-warning">@Model.ErrorMessage</div>
}

<form method="get" class="card mb-4" style="padding:16px;">
    <div style="display:grid;grid-template-columns:2fr repeat(4, minmax(150px, 1fr)) auto;gap:12px;align-items:end;">
        <div>
            <label style="font-size:12px;color:var(--text-muted);font-weight:600;">Tìm kiếm</label>
            <input name="search" value="@Model.Search" class="form-input" placeholder="Ten quan, dia chi, SDT..." />
        </div>
        <div>
            <label style="font-size:12px;color:var(--text-muted);font-weight:600;">Trạng thái</label>
            <select name="status" class="form-input">
                <option value="all" selected="@(Model.StatusFilter == "all")">Tất cả</option>
                <option value="visible" selected="@(Model.StatusFilter == "visible")">Đang hiện</option>
                <option value="hidden" selected="@(Model.StatusFilter == "hidden")">Đang ẩn</option>
                <option value="active-sub" selected="@(Model.StatusFilter == "active-sub")">Còn hạn</option>
                <option value="expired" selected="@(Model.StatusFilter == "expired")">Het han</option>
                <option value="no-expiry" selected="@(Model.StatusFilter == "no-expiry")">Chưa có hạn</option>
            </select>
        </div>
        <div>
            <label style="font-size:12px;color:var(--text-muted);font-weight:600;">Han duy tri</label>
            <select name="expiry" class="form-input">
                <option value="all" selected="@(Model.ExpiryFilter == "all")">Tất cả</option>
                <option value="active" selected="@(Model.ExpiryFilter == "active")">Còn hạn</option>
                <option value="expiring7" selected="@(Model.ExpiryFilter == "expiring7")">Sắp hết hạn 7 ngày</option>
                <option value="expired" selected="@(Model.ExpiryFilter == "expired")">Đã hết hạn</option>
                <option value="none" selected="@(Model.ExpiryFilter == "none")">Chưa có hạn</option>
            </select>
        </div>
        <div>
            <label style="font-size:12px;color:var(--text-muted);font-weight:600;">Sắp xếp</label>
            <select name="sort" class="form-input">
                <option value="priority" selected="@(Model.SortBy == "priority")">Uu tien</option>
                <option value="name" selected="@(Model.SortBy == "name")">Ten A-Z</option>
                <option value="expiry" selected="@(Model.SortBy == "expiry")">Hạn còn lại</option>
                <option value="menu" selected="@(Model.SortBy == "menu")">Số món đang hiện</option>
                <option value="status" selected="@(Model.SortBy == "status")">Trạng thái</option>
            </select>
        </div>
        <div>
            <label style="font-size:12px;color:var(--text-muted);font-weight:600;">Hướng</label>
            <select name="dir" class="form-input">
                <option value="asc" selected="@(Model.SortDir == "asc")">Thap len cao / A-Z</option>
                <option value="desc" selected="@(Model.SortDir == "desc")">Cao xuong thap / Z-A</option>
            </select>
        </div>
        <div class="flex gap-2">
            <button type="submit" class="btn btn-primary">Lọc</button>
            <a href="/Poi" class="btn btn-ghost">Xóa</a>
        </div>
    </div>
    <div style="margin-top:10px;font-size:12px;color:var(--text-muted);">
        Đang hiện thi <strong>@Model.POIs.Count</strong> POI theo bộ lọc hiện tại.
    </div>
</form>

<div class="card">
    <div class="table-wrap">
        <table>
            <thead>
                <tr>
                    <th></th>
                    <th>Tên quán</th>
                    <th>Địa chỉ</th>
                    <th>Món ăn trong quán</th>
                    <th>Ưu tiên</th>
                    <th>Hạn duy trì</th>
                    <th>Trạng thái</th>
                    <th>Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.POIs.Any())
                {
                    @foreach (var poi in Model.POIs)
                    {
                        var activeMenuItems = poi.MonAns.Where(m => m.TinhTrang).ToList();
                        var coverImageUrl = ImageUrlHelper.ResolvePoi(poi.AnhDaiDien, Model.ApiBaseUrl, poi.TenPOI);
                        var coverFallbackUrl = ImageUrlHelper.ResolvePoi(null, Model.ApiBaseUrl, poi.TenPOI);

                        <tr>
                            <td>
                                <img src="@coverImageUrl" class="poi-avatar"
                                     onerror="this.onerror=null;this.src='@coverFallbackUrl';" />
                            </td>
                            <td>
                                <strong>@poi.TenPOI</strong>
                                <div style="font-size:12px;color:var(--text-muted);margin-top:4px;">@(poi.SDT ?? "Không có số điện thoại")</div>
                            </td>
                            <td style="color:var(--text-muted);font-size:13px">@(poi.DiaChi ?? "-")</td>
                            <td style="min-width:320px;">
                                @if (activeMenuItems.Any())
                                {
                                    <div style="display:flex;flex-direction:column;gap:8px;">
                                        @foreach (var mon in activeMenuItems.Take(4))
                                        {
                                            var dishImageUrl = ImageUrlHelper.ResolveDish(mon.HinhAnh, Model.ApiBaseUrl, mon.TenMonAn, mon.PhanLoai);
                                            var dishFallbackUrl = ImageUrlHelper.ResolveDish(null, Model.ApiBaseUrl, mon.TenMonAn, mon.PhanLoai);

                                            <div style="display:flex;align-items:center;gap:10px;">
                                                <img src="@dishImageUrl"
                                                     style="width:36px;height:36px;border-radius:8px;object-fit:cover;border:1px solid var(--border);flex:none"
                                                     onerror="this.onerror=null;this.src='@dishFallbackUrl';" />

                                                <div style="min-width:0;">
                                                    <div style="font-size:13px;font-weight:600;color:var(--text);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">
                                                        @mon.TenMonAn
                                                    </div>
                                                    <div style="font-size:12px;color:var(--text-muted);">
                                                        @(string.IsNullOrWhiteSpace(mon.PhanLoai) ? "Chưa phân loại" : mon.PhanLoai)
                                                        @if (mon.DonGia > 0)
                                                        {
                                                            <text> • @mon.DonGia.ToString("N0") đ</text>
                                                        }
                                                    </div>
                                                </div>
                                            </div>
                                        }

                                        @if (activeMenuItems.Count > 4)
                                        {
                                            <span style="display:inline-flex;align-items:center;padding:6px 10px;border-radius:999px;background:#f1f5f9;color:#475569;font-size:12px;font-weight:600;width:max-content;">
                                                +@(activeMenuItems.Count - 4) món
                                            </span>
                                        }
                                    </div>
                                }
                                else
                                {
                                    <span style="font-size:13px;color:var(--text-muted);">Chưa có món ăn</span>
                                }
                            </td>
                            <td style="font-size:13px">@poi.MucUuTien</td>
                            <td style="font-size:13px">
                                @if (poi.NgayHetHanDuyTri.HasValue)
                                {
                                    var remainingDays = VinhKhanhTour.CMS.Pages.Poi.IndexModel.GetRemainingDays(poi);
                                    <strong>@poi.NgayHetHanDuyTri.Value.ToLocalTime().ToString("dd/MM/yyyy")</strong>
                                    <div style="font-size:12px;color:@(remainingDays < 0 ? "#dc2626" : remainingDays <= 7 ? "#d97706" : "var(--text-muted)")">
                                        @(remainingDays < 0 ? $"Quá hạn {Math.Abs(remainingDays)} ngày" : $"Còn {remainingDays + 1} ngày")
                                    </div>
                                }
                                else
                                {
                                    <span style="color:var(--text-muted)">Chưa có hạn</span>
                                }
                            </td>
                            <td>
                                <span class="status-dot @(poi.TrangThai ? "dot-on" : "dot-off")"></span>
                                @(poi.TrangThai ? "Hiện" : "Ẩn")
                            </td>
                            <td>
                                <div class="flex gap-2" style="flex-wrap:wrap;">
                                    <a href="/Poi/Edit/@poi.Id" class="btn btn-ghost btn-sm">Sửa quán</a>
                                    <a href="/Poi/Edit/@poi.Id#menu-section" class="btn btn-ghost btn-sm">Xem món</a>
                                    <form method="post" asp-page-handler="Toggle" style="display:inline">
                                        <input type="hidden" name="id" value="@poi.Id" />
                                        <button type="submit" class="btn btn-ghost btn-sm">
                                            @(poi.TrangThai ? "Ẩn" : "Hiện")
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="8" style="padding:24px;text-align:center;color:var(--text-muted);">
                            Chưa tải được dữ liệu POI. Kiểm tra kết nối database/API rồi thử lại.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
