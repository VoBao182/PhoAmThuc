<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>@ViewData["Title"] - Vĩnh Khánh CMS</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;500;600;700&family=Playfair+Display:wght@700&display=swap" rel="stylesheet">
    <style>
        :root {
            --brand: #e36a11;
            --brand-light: #fff0e8;
            --brand-dark: #a83d06;
            --sidebar-bg: #1a1410;
            --sidebar-w: 260px;
            --text: #1c1917;
            --text-muted: #78716c;
            --border: #e7e5e4;
            --bg: #fafaf9;
            --card: #ffffff;
            --success: #16a34a;
            --danger: #dc2626;
            --radius: 12px;
        }

        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: "Be Vietnam Pro", sans-serif;
            background:
                radial-gradient(circle at top left, rgba(255, 143, 61, 0.18), transparent 28%),
                linear-gradient(180deg, #f7f2eb 0%, #efe7dc 100%);
            color: var(--text);
            min-height: 100vh;
        }

        .cms-shell {
            display: grid;
            grid-template-columns: 260px minmax(0, 1fr);
            min-height: 100vh;
        }

        .cms-sidebar {
            background: linear-gradient(180deg, #211b16 0%, #191410 100%);
            color: white;
            padding: 22px 16px;
            display: flex;
            flex-direction: column;
            gap: 22px;
            box-shadow: inset -1px 0 0 rgba(255,255,255,.04);
        }

        .brand-block {
            padding: 10px 12px 16px;
            border-radius: 18px;
        }

        .brand-title {
            margin: 0;
            font-size: 1.9rem;
            font-weight: 700;
            font-family: "Playfair Display", Georgia, serif;
            line-height: 1.05;
        }

        .brand-sub {
            margin: 10px 0 0;
            color: #f08a3c;
            font-size: .74rem;
            font-weight: 700;
            letter-spacing: .09em;
            text-transform: uppercase;
        }

        .cms-nav {
            display: flex;
            flex-direction: column;
            gap: 10px;
            padding: 10px;
            border-radius: 24px;
            background: rgba(255,255,255,.05);
            border: 1px solid rgba(255,255,255,.08);
            box-shadow: inset 0 1px 0 rgba(255,255,255,.04);
        }

        .cms-nav > a {
            display: flex;
            align-items: center;
            gap: 14px;
            padding: 14px 16px;
            border-radius: 18px;
            color: rgba(255,255,255,.78);
            text-decoration: none;
            font-weight: 600;
            border: 1px solid transparent;
            transition: 0.2s ease;
        }

        .cms-nav > a:hover {
            color: white;
            background: rgba(255,255,255,.08);
            border-color: rgba(255,255,255,.08);
            transform: translateX(2px);
        }

        .cms-nav > a.active {
            color: #201712;
            background: linear-gradient(135deg, #fff6ec 0%, #ffd7b6 100%);
            border-color: rgba(255,255,255,.18);
            box-shadow: 0 16px 28px rgba(227, 106, 17, .22);
        }

        .nav-icon {
            width: 28px;
            height: 28px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border-radius: 10px;
            background: rgba(255,255,255,.08);
            text-align: center;
            font-size: 13px;
            font-weight: 700;
            opacity: .92;
        }

        .cms-nav > a.active .nav-icon { background: rgba(32, 23, 18, .08); }

        .cms-main {
            padding: 28px;
        }

        .cms-content {
            padding: 30px;
            min-height: calc(100vh - 56px);
            background: rgba(255,255,255,.64);
            backdrop-filter: blur(8px);
            border: 1px solid rgba(255,255,255,.55);
            border-radius: 34px;
            box-shadow: 0 24px 60px rgba(31, 41, 51, 0.08);
        }

        .btn {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 9px 18px;
            border-radius: 8px;
            font-family: inherit;
            font-size: 14px;
            font-weight: 600;
            cursor: pointer;
            border: none;
            text-decoration: none;
            transition: all .15s;
        }

        .btn-primary { background: var(--brand); color: #fff; }
        .btn-primary:hover { background: var(--brand-dark); }
        .btn-ghost { background: transparent; color: var(--text-muted); border: 1px solid var(--border); }
        .btn-ghost:hover { background: var(--bg); color: var(--text); }
        .btn-danger { background: #fef2f2; color: var(--danger); border: 1px solid #fecaca; }
        .btn-danger:hover { background: var(--danger); color: #fff; }
        .btn-sm { padding: 6px 12px; font-size: 13px; }

        .card {
            background: var(--card);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            padding: 24px;
        }

        .card-title {
            font-size: 14px;
            font-weight: 700;
            color: var(--text);
            margin-bottom: 16px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .form-group { margin-bottom: 20px; }

        .form-label {
            display: block;
            font-size: 13px;
            font-weight: 600;
            color: var(--text);
            margin-bottom: 6px;
        }

        .form-label .badge-lang {
            display: inline-block;
            font-size: 10px;
            font-weight: 700;
            padding: 2px 7px;
            border-radius: 20px;
            margin-left: 6px;
            letter-spacing: .05em;
        }

        .lang-vi { background: #fff7ed; color: #c2410c; }
        .lang-en { background: #eff6ff; color: #1d4ed8; }
        .lang-zh { background: #fef2f2; color: #b91c1c; }

        .form-input, .form-textarea, .form-select {
            width: 100%;
            padding: 10px 14px;
            border: 1.5px solid var(--border);
            border-radius: 8px;
            font-family: inherit;
            font-size: 14px;
            color: var(--text);
            background: #fff;
            transition: border-color .15s;
            outline: none;
        }

        .form-input:focus, .form-textarea:focus, .form-select:focus {
            border-color: var(--brand);
        }

        .form-textarea { resize: vertical; min-height: 100px; line-height: 1.6; }
        .form-hint { font-size: 12px; color: var(--text-muted); margin-top: 4px; }

        .lang-tabs {
            display: inline-flex;
            gap: 8px;
            margin-bottom: 18px;
            padding: 6px;
            border-radius: 18px;
            background: linear-gradient(180deg, #f8fafc 0%, #ffffff 100%);
            border: 1px solid var(--border);
            box-shadow: inset 0 1px 0 rgba(255,255,255,.85);
        }

        .lang-tab {
            min-width: 116px;
            padding: 10px 18px;
            border-radius: 14px;
            font-size: 13px;
            font-weight: 700;
            cursor: pointer;
            border: 1px solid transparent;
            background: transparent;
            color: var(--text-muted);
            transition: transform .15s ease, box-shadow .15s ease, background .15s ease, color .15s ease;
        }

        .lang-tab:hover {
            color: var(--text);
            background: rgba(255,255,255,.92);
            transform: translateY(-1px);
        }

        .lang-tab.active-vi,
        .lang-tab.active-en,
        .lang-tab.active-zh {
            color: #111827;
            background: #ffffff;
            box-shadow: 0 10px 22px rgba(15, 23, 42, 0.08);
        }

        .lang-tab.active-vi {
            border-color: rgba(194, 65, 12, .18);
            color: #c2410c;
            background: linear-gradient(180deg, #fff7ed 0%, #ffffff 100%);
        }

        .lang-tab.active-en {
            border-color: rgba(29, 78, 216, .18);
            color: #1d4ed8;
            background: linear-gradient(180deg, #eff6ff 0%, #ffffff 100%);
        }

        .lang-tab.active-zh {
            border-color: rgba(185, 28, 28, .18);
            color: #b91c1c;
            background: linear-gradient(180deg, #fef2f2 0%, #ffffff 100%);
        }
        .lang-panel { display: none; }
        .lang-panel.show { display: block; }

        .table-wrap { overflow-x: auto; }
        table { width: 100%; border-collapse: collapse; }

        th {
            text-align: left;
            font-size: 11px;
            font-weight: 700;
            letter-spacing: .07em;
            text-transform: uppercase;
            color: var(--text-muted);
            padding: 10px 16px;
            border-bottom: 1px solid var(--border);
        }

        td {
            padding: 14px 16px;
            font-size: 14px;
            border-bottom: 1px solid var(--border);
            vertical-align: middle;
        }

        tr:last-child td { border-bottom: none; }
        tr:hover td { background: var(--bg); }

        .alert {
            padding: 12px 16px;
            border-radius: 8px;
            font-size: 14px;
            margin-bottom: 20px;
        }

        .alert-success { background: #f0fdf4; color: #15803d; border: 1px solid #bbf7d0; }
        .alert-danger  { background: #fef2f2; color: #b91c1c; border: 1px solid #fecaca; }

        .img-preview {
            width: 80px;
            height: 80px;
            border-radius: 8px;
            object-fit: cover;
            border: 2px solid var(--border);
        }

        .img-preview-lg {
            width: 120px;
            height: 80px;
            border-radius: 8px;
            object-fit: cover;
            border: 2px solid var(--border);
        }

        .grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
        .grid-3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 20px; }
        .flex { display: flex; }
        .flex-between { display: flex; justify-content: space-between; align-items: center; }
        .gap-2 { gap: 8px; }
        .gap-3 { gap: 12px; }
        .mt-4 { margin-top: 16px; }
        .mt-6 { margin-top: 24px; }
        .mb-4 { margin-bottom: 16px; }

        .stat-card {
            background: var(--card);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            padding: 20px 24px;
        }

        .stat-label { font-size: 12px; color: var(--text-muted); font-weight: 600; text-transform: uppercase; letter-spacing: .06em; }
        .stat-value { font-size: 32px; font-weight: 700; color: var(--text); margin: 4px 0; font-family: "Playfair Display", serif; }
        .stat-sub { font-size: 13px; color: var(--text-muted); }

        .poi-avatar {
            width: 44px;
            height: 44px;
            border-radius: 8px;
            object-fit: cover;
        }

        .poi-avatar-placeholder {
            width: 44px;
            height: 44px;
            border-radius: 8px;
            background: var(--brand-light);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
        }

        .status-dot {
            display: inline-block;
            width: 8px;
            height: 8px;
            border-radius: 50%;
            margin-right: 6px;
        }

        .dot-on { background: var(--success); }
        .dot-off { background: #d1d5db; }

        .monan-item {
            display: grid;
            grid-template-columns: 60px 1fr 120px 100px 40px;
            gap: 12px;
            align-items: center;
            padding: 12px 0;
            border-bottom: 1px solid var(--border);
        }

        .monan-item:last-child { border-bottom: none; }

        .monan-img {
            width: 56px;
            height: 56px;
            border-radius: 8px;
            object-fit: cover;
            border: 1px solid var(--border);
        }

        .monan-img-placeholder {
            width: 56px;
            height: 56px;
            border-radius: 8px;
            background: var(--brand-light);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 14px;
            font-weight: 700;
            color: var(--brand-dark);
        }

        .remove-btn {
            background: none;
            border: none;
            cursor: pointer;
            color: var(--text-muted);
            font-size: 18px;
            padding: 4px;
            border-radius: 4px;
            transition: color .15s;
        }

        .remove-btn:hover { color: var(--danger); }
    </style>
</head>
<body>
<div class="cms-shell">
    <aside class="cms-sidebar">
        <div class="brand-block">
            <h1 class="brand-title">Vĩnh Khánh CMS</h1>
            <p class="brand-sub">Quản lý POI, thuyết minh và thống kê trên một giao diện gọn gàng.</p>
        </div>
        <nav class="cms-nav">
            <a href="/" class="@(ViewData["Page"]?.ToString() == "dashboard" ? "active" : "")">
                <span class="nav-icon">DB</span>
                <span>Dashboard</span>
            </a>
            <a href="/Poi" class="@(ViewData["Page"]?.ToString() == "poi" ? "active" : "")">
                <span class="nav-icon">QA</span>
                <span>Quán ăn</span>
            </a>
            <a href="/ThuyetMinh" class="@(ViewData["Page"]?.ToString() == "thuyetminh" ? "active" : "")">
                <span class="nav-icon">TM</span>
                <span>Thuyết minh</span>
            </a>
            <a href="/ThanhToan" class="@(ViewData["Page"]?.ToString() == "thanhtoan" ? "active" : "")">
                <span class="nav-icon">💰</span>
                <span>Phí duy trì</span>
            </a>
            <a href="/DuyetThanhToan" class="@(ViewData["Page"]?.ToString() == "duyetthanhtoan" ? "active" : "")">
                <span class="nav-icon">✅</span>
                <span>Duyệt thanh toán</span>
            </a>
            <a href="/BanDo" class="@(ViewData["Page"]?.ToString() == "bando" ? "active" : "")">
                <span class="nav-icon">🗺</span>
                <span>Bản đồ live</span>
            </a>
        </nav>
    </aside>
    <main class="cms-main">
        <div class="cms-content">
            @RenderBody()
        </div>
    </main>
</div>

<script>
function switchLang(lang, groupId) {
    const panels = document.querySelectorAll(`[data-group="${groupId}"]`);
    panels.forEach(p => p.classList.remove('show'));
    document.getElementById(`panel-${groupId}-${lang}`).classList.add('show');

    const tabs = document.querySelectorAll(`[data-tab-group="${groupId}"]`);
    tabs.forEach(t => { t.className = 'lang-tab'; });
    document.getElementById(`tab-${groupId}-${lang}`).className = `lang-tab active-${lang}`;
}

function previewImg(inputEl, previewId) {
    const url = inputEl.value.trim();
    const img = document.getElementById(previewId);
    if (!img) return;
    if (url) { img.src = url; img.style.display = 'block'; }
    else { img.style.display = 'none'; }
}

let monAnIndex = parseInt(document.getElementById('monan-count')?.value ?? '0');
function addMonAn() {
    const container = document.getElementById('monan-list');
    const i = monAnIndex++;
    document.getElementById('monan-count').value = monAnIndex;
    const div = document.createElement('div');
    div.className = 'monan-item';
    div.id = `monan-${i}`;
    div.innerHTML = `
        <div class="monan-img-placeholder">AN</div>
        <div>
            <input name="MonAns[${i}].TenMonAn" placeholder="Tên món ăn" class="form-input" style="margin-bottom:6px" required/>
            <input name="MonAns[${i}].MoTa" placeholder="Mô tả ngắn (tùy chọn)" class="form-input" style="font-size:12px"/>
        </div>
        <input name="MonAns[${i}].PhanLoai" placeholder="Phân loại" class="form-input"/>
        <input name="MonAns[${i}].DonGia" type="number" placeholder="Giá (đ)" class="form-input"/>
        <button type="button" class="remove-btn" onclick="this.closest('.monan-item').remove()">×</button>
        <input name="MonAns[${i}].HinhAnh" placeholder="URL ảnh" class="form-input" style="grid-column:2/-2;margin-top:6px"/>
    `;
    container.appendChild(div);
}
</script>

@RenderSection("Scripts", required: false)
</body>
</html>
