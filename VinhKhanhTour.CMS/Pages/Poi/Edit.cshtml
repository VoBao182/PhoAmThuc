@page "{id:guid}"
@model VinhKhanhTour.CMS.Pages.Poi.EditModel
@{
    ViewData["Title"] = "Sửa quán: " + Model.POI.TenPOI;
    ViewData["Page"] = "poi";

    var coverImageUrl = ImageUrlHelper.ResolvePoi(Model.POI.AnhDaiDien, Model.ApiBaseUrl, Model.POI.TenPOI);
}
<script>
    const API_BASE = "@Model.ApiBaseUrl";
    const POI_FALLBACK_IMAGE = "@Html.Raw(ImageUrlHelper.ResolvePoi(null, Model.ApiBaseUrl, Model.POI.TenPOI))";
    const DISH_FALLBACK_IMAGE = "@Html.Raw(ImageUrlHelper.ResolveDish(null, Model.ApiBaseUrl, null, null))";
    const RESTAURANT_GENERIC_IMAGE = "@Html.Raw(VinhKhanhTour.Shared.SharedImageCatalog.RestaurantGenericPhoto)";
    const RESTAURANT_SEAFOOD_IMAGE = "@Html.Raw(VinhKhanhTour.Shared.SharedImageCatalog.RestaurantSeafoodPhoto)";
    const RESTAURANT_BEEF_GRILL_IMAGE = "@Html.Raw(VinhKhanhTour.Shared.SharedImageCatalog.RestaurantBeefGrillPhoto)";
    const RESTAURANT_HOTPOT_IMAGE = "@Html.Raw(VinhKhanhTour.Shared.SharedImageCatalog.RestaurantHotpotPhoto)";
    const RESTAURANT_DESSERT_IMAGE = "@Html.Raw(VinhKhanhTour.Shared.SharedImageCatalog.RestaurantDessertPhoto)";
    const RESTAURANT_NOODLE_IMAGE = "@Html.Raw(VinhKhanhTour.Shared.SharedImageCatalog.RestaurantNoodlePhoto)";
    const RESTAURANT_SIDEWALK_IMAGE = "@Html.Raw(VinhKhanhTour.Shared.SharedImageCatalog.RestaurantSidewalkPhoto)";
    const DISH_GENERIC_IMAGE = "@Html.Raw(VinhKhanhTour.Shared.SharedImageCatalog.DishGenericPhoto)";
    const DISH_SEAFOOD_IMAGE = "@Html.Raw(VinhKhanhTour.Shared.SharedImageCatalog.DishSeafoodPhoto)";
    const DISH_BEEF_IMAGE = "@Html.Raw(VinhKhanhTour.Shared.SharedImageCatalog.DishBeefPhoto)";
    const DISH_GRILL_IMAGE = "@Html.Raw(VinhKhanhTour.Shared.SharedImageCatalog.DishGrillPhoto)";
    const DISH_HOTPOT_IMAGE = "@Html.Raw(VinhKhanhTour.Shared.SharedImageCatalog.DishHotpotPhoto)";
    const DISH_NOODLE_IMAGE = "@Html.Raw(VinhKhanhTour.Shared.SharedImageCatalog.DishNoodlePhoto)";
    const DISH_DESSERT_IMAGE = "@Html.Raw(VinhKhanhTour.Shared.SharedImageCatalog.DishDessertPhoto)";
    const DISH_DRINK_IMAGE = "@Html.Raw(VinhKhanhTour.Shared.SharedImageCatalog.DishDrinkPhoto)";
    const DISH_SALAD_IMAGE = "@Html.Raw(VinhKhanhTour.Shared.SharedImageCatalog.DishSaladPhoto)";
</script>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<form method="post">
    <input type="hidden" asp-for="POI.Id" />
    <input type="hidden" id="monan-count" name="monan-count" value="@Model.POI.MonAns.Count" />

    <div class="grid-2" style="align-items:start;gap:24px">
        <div style="display:flex;flex-direction:column;gap:20px">
            <div class="card">
                <div class="card-title">Thông tin quán</div>

                <div class="form-group">
                    <label class="form-label">Tên quán <span style="color:var(--danger)">*</span></label>
                    <input asp-for="POI.TenPOI" class="form-input" required />
                </div>

                <div class="grid-2">
                    <div class="form-group">
                        <label class="form-label">Số điện thoại</label>
                        <input asp-for="POI.SDT" class="form-input" placeholder="028 xxxx xxxx" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Thứ tự hiển thị</label>
                        <input asp-for="POI.MucUuTien" type="number" class="form-input" />
                    </div>
                </div>

                <div class="form-group">
                    <label class="form-label">Địa chỉ</label>
                    <input asp-for="POI.DiaChi" class="form-input" placeholder="Số nhà, Phố Vĩnh Khánh, Q4" />
                </div>

                <div class="grid-2">
                    <div class="form-group">
                        <label class="form-label">Vĩ độ (Lat)</label>
                        <input asp-for="POI.ViDo" type="number" step="any" class="form-input" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Kinh độ (Lng)</label>
                        <input asp-for="POI.KinhDo" type="number" step="any" class="form-input" />
                    </div>
                </div>

                <div class="form-group">
                    <label class="form-label">Bán kính geofence (m)</label>
                    <input asp-for="POI.BanKinh" type="number" class="form-input" />
                    <div class="form-hint">Khoảng cách để kích hoạt thuyết minh tự động.</div>
                </div>

                <div class="form-group">
                    <label class="form-label">
                        <input type="checkbox" asp-for="POI.TrangThai" style="margin-right:6px" />
                        Hiển thị trên app
                    </label>
                </div>
            </div>

            <div class="card">
                <div class="card-title">Ảnh bìa quán</div>
                <div class="form-group">
                    <label class="form-label">Chọn hoặc dán URL ảnh</label>
                    <div style="display:flex;gap:8px;align-items:center">
                        <input asp-for="POI.AnhDaiDien" id="input-cover-url" class="form-input"
                               placeholder="https://... hoặc nhấn Chọn file"
                               oninput="previewImg(this,'preview-cover')" />
                        <label class="btn btn-ghost btn-sm" style="white-space:nowrap;cursor:pointer">
                            Chọn file
                            <input type="file" accept="image/*" style="display:none"
                                   onchange="uploadImg(this,'input-cover-url','preview-cover')" />
                        </label>
                    </div>
                    <div id="upload-cover-status" class="form-hint"></div>
                </div>

                <img id="preview-cover" src="@coverImageUrl" class="img-preview-lg"
                     style="display:block;width:100%;height:160px;object-fit:cover;border-radius:8px;margin-top:8px"
                     onerror="this.onerror=null;this.src=POI_FALLBACK_IMAGE;" />
            </div>
        </div>

        <div style="display:flex;flex-direction:column;gap:20px">
            <div class="card">
                <div class="card-title">Nội dung thuyết minh</div>
                <div class="form-hint mb-4" style="margin-bottom:12px">
                    Nội dung này sẽ hiển thị trong app và được đọc bằng giọng nói tự động khi khách vào vùng geofence.
                </div>

                <div class="lang-tabs">
                    <button type="button" id="tab-tm-vi" class="lang-tab active-vi"
                            data-tab-group="tm" onclick="switchLang('vi','tm')">Tiếng Việt</button>
                    <button type="button" id="tab-tm-en" class="lang-tab"
                            data-tab-group="tm" onclick="switchLang('en','tm')">English</button>
                    <button type="button" id="tab-tm-zh" class="lang-tab"
                            data-tab-group="tm" onclick="switchLang('zh','tm')">中文</button>
                </div>

                <div id="panel-tm-vi" class="lang-panel show" data-group="tm">
                    <div class="form-group">
                        <label class="form-label">Nội dung <span class="badge-lang lang-vi">VI</span></label>
                        <textarea name="ThuyetMinhVi" class="form-textarea" rows="8"
                                  placeholder="Nhập nội dung thuyết minh tiếng Việt...">@Model.ThuyetMinhVi</textarea>
                        <div class="form-hint">Sẽ được đọc khi điện thoại đặt ngôn ngữ Tiếng Việt</div>
                    </div>
                </div>

                <div id="panel-tm-en" class="lang-panel" data-group="tm">
                    <div class="form-group">
                        <label class="form-label">Content <span class="badge-lang lang-en">EN</span></label>
                        <textarea name="ThuyetMinhEn" class="form-textarea" rows="8"
                                  placeholder="Enter English audio guide content...">@Model.ThuyetMinhEn</textarea>
                        <div class="form-hint">Played when device language is set to English</div>
                    </div>
                </div>

                <div id="panel-tm-zh" class="lang-panel" data-group="tm">
                    <div class="form-group">
                        <label class="form-label">内容 <span class="badge-lang lang-zh">ZH</span></label>
                        <textarea name="ThuyetMinhZh" class="form-textarea" rows="8"
                                  placeholder="请输入中文语音导览内容...">@Model.ThuyetMinhZh</textarea>
                        <div class="form-hint">当设备语言设置为中文时播放</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div id="menu-section" class="card mt-6">
        <div class="flex-between mb-4">
            <div class="card-title" style="margin-bottom:0">Thực đơn</div>
            <button type="button" class="btn btn-ghost btn-sm" onclick="addMonAn()">+ Thêm món</button>
        </div>

        <div style="display:grid;grid-template-columns:68px 1fr 120px 100px 40px;gap:12px;padding:0 0 8px;border-bottom:2px solid var(--border)">
            <div style="font-size:11px;font-weight:700;color:var(--text-muted);text-transform:uppercase;letter-spacing:.06em">Ảnh</div>
            <div style="font-size:11px;font-weight:700;color:var(--text-muted);text-transform:uppercase;letter-spacing:.06em">Tên món / Mô tả</div>
            <div style="font-size:11px;font-weight:700;color:var(--text-muted);text-transform:uppercase;letter-spacing:.06em">Phân loại</div>
            <div style="font-size:11px;font-weight:700;color:var(--text-muted);text-transform:uppercase;letter-spacing:.06em">Giá (đ)</div>
            <div></div>
        </div>

        <div id="monan-list">
            @for (var i = 0; i < Model.POI.MonAns.Count; i++)
            {
                var mon = Model.POI.MonAns.ElementAt(i);
                var imageUrl = ImageUrlHelper.ResolveDish(mon.HinhAnh, Model.ApiBaseUrl, mon.TenMonAn, mon.PhanLoai);

                <div class="monan-item" id="monan-@i">
                    <div style="display:flex;flex-direction:column;align-items:center;gap:4px">
                        <img id="monan-img-@i" src="@imageUrl" class="monan-img"
                             onerror="this.onerror=null;this.src=DISH_FALLBACK_IMAGE;" />
                        <label style="font-size:10px;color:var(--brand);cursor:pointer;text-align:center">
                            Đổi ảnh
                            <input type="file" accept="image/*" style="display:none"
                                   onchange="uploadMonAnImg(this,@i)" />
                        </label>
                    </div>
                    <div>
                        <input type="hidden" name="MonAns.Index" value="@i" />
                        <input type="hidden" name="MonAns[@i].Id" value="@mon.Id" />
                        <input name="MonAns[@i].TenMonAn" value="@mon.TenMonAn"
                               placeholder="Tên món ăn" class="form-input" style="margin-bottom:6px" required />
                        <input name="MonAns[@i].MoTa" value="@mon.MoTa"
                               placeholder="Mô tả ngắn (tùy chọn)" class="form-input" style="font-size:12px" />
                        <input id="monan-url-@i" name="MonAns[@i].HinhAnh" value="@mon.HinhAnh"
                               placeholder="URL ảnh hoặc chọn file ở trên" class="form-input"
                               style="font-size:12px;margin-top:6px"
                               oninput="updateMonAnImg(this,@i)" />
                    </div>
                    <input name="MonAns[@i].PhanLoai" value="@mon.PhanLoai"
                           placeholder="VD: Khai vị" class="form-input" />
                    <input name="MonAns[@i].DonGia" type="number" value="@mon.DonGia"
                           placeholder="0" class="form-input" />
                    <button type="button" class="remove-btn" onclick="removeMonAn(@i)">×</button>
                    <input type="hidden" name="MonAns[@i].TinhTrang" value="true" />
                </div>
            }
        </div>

        <div id="monan-empty" style="@(Model.POI.MonAns.Any() ? "display:none;" : "")text-align:center;padding:32px;color:var(--text-muted);font-size:14px">
            Chưa có món ăn. Nhấn "Thêm món" để bắt đầu.
        </div>
    </div>

    <div class="flex-between mt-6">
        <a href="/Poi" class="btn btn-ghost">← Quay lại</a>
        <button type="submit" class="btn btn-primary" style="min-width:140px">Lưu thay đổi</button>
    </div>
</form>

@section Scripts {
<script>
function resolveImageUrl(url) {
    if (!url) return '';
    const trimmed = url.trim();
    if (!trimmed) return '';
    if (/^https?:\/\//i.test(trimmed)) return trimmed;
    return trimmed.startsWith('/') ? `${API_BASE}${trimmed}` : `${API_BASE}/${trimmed.replace(/^\/+/, '')}`;
}

function normalizeVietnamese(value) {
    return (value || '')
        .trim()
        .normalize('NFD')
        .replace(/[\u0300-\u036f]/g, '')
        .replace(/đ/g, 'd')
        .replace(/Đ/g, 'd')
        .toLowerCase();
}

function containsAny(source, keywords) {
    return keywords.some(keyword => source.includes(keyword));
}

function getPoiFallbackImage(name) {
    const text = normalizeVietnamese(name);
    if (containsAny(text, ['oc', 'ngheu', 'hai san', 'seafood'])) return RESTAURANT_SEAFOOD_IMAGE;
    if (containsAny(text, ['bo', 'be', 'nuong'])) return RESTAURANT_BEEF_GRILL_IMAGE;
    if (containsAny(text, ['lau', 'hotpot'])) return RESTAURANT_HOTPOT_IMAGE;
    if (containsAny(text, ['che', 'dessert', 'tra sua', 'sweet'])) return RESTAURANT_DESSERT_IMAGE;
    if (containsAny(text, ['bun', 'pho', 'mi', 'hu tieu', 'noodle'])) return RESTAURANT_NOODLE_IMAGE;
    if (containsAny(text, ['nhau', 'via he', 'an vat', 'sidewalk'])) return RESTAURANT_SIDEWALK_IMAGE;
    return RESTAURANT_GENERIC_IMAGE;
}

function getDishFallbackImage(name, category) {
    const text = normalizeVietnamese(`${name || ''} ${category || ''}`);
    if (containsAny(text, ['oc', 'ngheu', 'so diep', 'so huyet', 'muc', 'ghe', 'tom', 'hai san', 'seafood'])) return DISH_SEAFOOD_IMAGE;
    if (containsAny(text, ['bun', 'pho', 'hu tieu', 'mi', 'noodle'])) return DISH_NOODLE_IMAGE;
    if (containsAny(text, ['che', 'tau hu', 'khuc bach', 'sua tuoi', 'dessert', 'sweet'])) return DISH_DESSERT_IMAGE;
    if (containsAny(text, ['tra', 'nuoc', 'drink', 'uong'])) return DISH_DRINK_IMAGE;
    if (containsAny(text, ['lau', 'hotpot'])) return DISH_HOTPOT_IMAGE;
    if (containsAny(text, ['goi', 'salad', 'ngo sen'])) return DISH_SALAD_IMAGE;
    if (containsAny(text, ['bo', 'be', 'la lot'])) return DISH_BEEF_IMAGE;
    if (containsAny(text, ['nuong', 'sa te', 'kho muc', 'long'])) return DISH_GRILL_IMAGE;
    return DISH_GENERIC_IMAGE;
}

function getCurrentPoiName() {
    return document.getElementById('POI_TenPOI')?.value || '';
}

function getMonAnRow(idx) {
    return document.getElementById(`monan-${idx}`);
}

function getMonAnField(row, suffix) {
    return row?.querySelector(`input[name="MonAns[${row.id.replace('monan-', '')}].${suffix}"]`);
}

function getDishFallbackForIndex(idx) {
    const row = getMonAnRow(idx);
    const name = getMonAnField(row, 'TenMonAn')?.value || '';
    const category = getMonAnField(row, 'PhanLoai')?.value || '';
    return getDishFallbackImage(name, category);
}

function previewImg(inputEl, previewId) {
    const url = resolveImageUrl(inputEl.value);
    const img = document.getElementById(previewId);
    if (!img) return;
    const fallback = getPoiFallbackImage(getCurrentPoiName());
    img.onerror = () => {
        img.onerror = null;
        img.src = fallback;
    };
    img.src = url || fallback;
    img.style.display = 'block';
}

async function doUpload(file) {
    const fd = new FormData();
    fd.append('file', file);

    const res = await fetch(`${API_BASE}/api/upload`, { method: 'POST', body: fd });
    if (!res.ok) {
        const err = await res.json().catch(() => ({}));
        throw new Error(err.error || 'Upload thất bại');
    }

    const data = await res.json();
    return data.url;
}

async function uploadImg(fileInput, urlInputId, previewId) {
    const file = fileInput.files[0];
    if (!file) return;

    const status = document.getElementById('upload-cover-status');
    status.textContent = 'Đang tải lên...';

    try {
        const url = await doUpload(file);
        document.getElementById(urlInputId).value = url;
        previewImg(document.getElementById(urlInputId), previewId);
        status.textContent = 'Tải lên thành công.';
        setTimeout(() => status.textContent = '', 3000);
    } catch (e) {
        status.textContent = e.message;
    }

    fileInput.value = '';
}

function setMonAnPreview(idx, url) {
    const imgEl = document.getElementById(`monan-img-${idx}`);
    if (!imgEl) return;

    const resolvedUrl = resolveImageUrl(url);
    const fallback = getDishFallbackForIndex(idx);
    imgEl.outerHTML = `<img id="monan-img-${idx}" src="${resolvedUrl || fallback}" class="monan-img"
        onerror="this.onerror=null;this.src='${fallback}'"/>`;
}

async function uploadMonAnImg(fileInput, idx) {
    const file = fileInput.files[0];
    if (!file) return;

    try {
        const url = await doUpload(file);
        const urlInput = document.getElementById(`monan-url-${idx}`);
        if (urlInput) {
            urlInput.value = url;
        }
        setMonAnPreview(idx, url);
    } catch (e) {
        alert(e.message);
    }

    fileInput.value = '';
}

function updateMonAnImg(input, idx) {
    setMonAnPreview(idx, input.value);
}

function refreshCoverFallback() {
    const input = document.getElementById('input-cover-url');
    if (input) {
        previewImg(input, 'preview-cover');
    }
}

function refreshDishFallback(idx) {
    const input = document.getElementById(`monan-url-${idx}`);
    setMonAnPreview(idx, input?.value || '');
}

function wireMonAnRow(row) {
    if (!row) return;

    const idx = row.id.replace('monan-', '');
    const nameInput = getMonAnField(row, 'TenMonAn');
    const categoryInput = getMonAnField(row, 'PhanLoai');

    if (nameInput && !nameInput.dataset.smartFallbackBound) {
        nameInput.dataset.smartFallbackBound = '1';
        nameInput.addEventListener('input', () => refreshDishFallback(idx));
    }

    if (categoryInput && !categoryInput.dataset.smartFallbackBound) {
        categoryInput.dataset.smartFallbackBound = '1';
        categoryInput.addEventListener('input', () => refreshDishFallback(idx));
    }

    refreshDishFallback(idx);
}

function initializeSmartFallbacks() {
    const poiNameInput = document.getElementById('POI_TenPOI');
    if (poiNameInput && !poiNameInput.dataset.smartFallbackBound) {
        poiNameInput.dataset.smartFallbackBound = '1';
        poiNameInput.addEventListener('input', refreshCoverFallback);
    }

    refreshCoverFallback();

    document.querySelectorAll('[id^="monan-"]').forEach(row => {
        if (row.classList.contains('monan-item')) {
            wireMonAnRow(row);
        }
    });

    const container = document.getElementById('monan-list');
    if (container && !container.dataset.smartObserverBound) {
        container.dataset.smartObserverBound = '1';
        const observer = new MutationObserver(() => {
            container.querySelectorAll('.monan-item').forEach(wireMonAnRow);
        });
        observer.observe(container, { childList: true });
    }
}

let monAnIndex = @Model.POI.MonAns.Count;
document.getElementById('monan-count').value = monAnIndex;

function toggleEmptyMenuState() {
    const empty = document.getElementById('monan-empty');
    const container = document.getElementById('monan-list');
    if (!empty || !container) return;
    empty.style.display = container.children.length === 0 ? 'block' : 'none';
}

function addMonAn() {
    const container = document.getElementById('monan-list');
    const i = monAnIndex++;
    document.getElementById('monan-count').value = monAnIndex;

    const div = document.createElement('div');
    div.className = 'monan-item';
    div.id = `monan-${i}`;
    div.innerHTML = `
        <div style="display:flex;flex-direction:column;align-items:center;gap:4px">
            <img id="monan-img-${i}" src="${DISH_FALLBACK_IMAGE}" class="monan-img"
                 onerror="this.onerror=null;this.src='${DISH_FALLBACK_IMAGE}'"/>
            <label style="font-size:10px;color:var(--brand);cursor:pointer;text-align:center">
                Đổi ảnh
                <input type="file" accept="image/*" style="display:none"
                       onchange="uploadMonAnImg(this,${i})"/>
            </label>
        </div>
        <div>
            <input type="hidden" name="MonAns.Index" value="${i}" />
            <input type="hidden" name="MonAns[${i}].Id" value="" />
            <input name="MonAns[${i}].TenMonAn" placeholder="Tên món ăn"
                   class="form-input" style="margin-bottom:6px" required />
            <input name="MonAns[${i}].MoTa" placeholder="Mô tả ngắn"
                   class="form-input" style="font-size:12px" />
            <input id="monan-url-${i}" name="MonAns[${i}].HinhAnh"
                   placeholder="URL ảnh hoặc chọn file ở trên"
                   class="form-input" style="font-size:12px;margin-top:6px"
                   oninput="updateMonAnImg(this,${i})" />
        </div>
        <input name="MonAns[${i}].PhanLoai" placeholder="VD: Khai vị" class="form-input" />
        <input name="MonAns[${i}].DonGia" type="number" value="0" placeholder="0" class="form-input" />
        <button type="button" class="remove-btn" onclick="removeMonAn(${i})">×</button>
        <input type="hidden" name="MonAns[${i}].TinhTrang" value="true" />
    `;

    container.appendChild(div);
    toggleEmptyMenuState();
}

function removeMonAn(idx) {
    const el = document.getElementById(`monan-${idx}`);
    if (el) {
        el.remove();
    }
    toggleEmptyMenuState();
}

toggleEmptyMenuState();
initializeSmartFallbacks();
</script>
}
