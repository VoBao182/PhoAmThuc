@page
@model VinhKhanhTour.CMS.Pages.DuyetThanhToan.IndexModel
@{
    ViewData["Title"] = "Duyet thanh toan app";
    ViewData["Page"] = "duyetthanhtoan";
    Layout = "/Pages/Shared/_Layout.cshtml";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-0">Duyet thanh toan app</h2>
            <p class="text-muted mb-0">Xac nhan yeu cau chuyen khoan tu khach mua goi</p>
        </div>
        <span id="pendingCountBadge" class="badge bg-warning text-dark fs-6">
            @Model.SoChoDuyet yeu cau cho duyet
        </span>
    </div>

    <div id="paymentPendingAlert"
         class="alert alert-warning alert-dismissible fade show d-none"
         role="alert"
         aria-live="polite">
        <strong>Co yeu cau thanh toan moi.</strong>
        <span id="paymentPendingAlertText">Trang se tu cap nhat.</span>
        <a href="?tab=cho_duyet" class="alert-link ms-2">Mo danh sach cho duyet</a>
        <button type="button" class="btn-close" onclick="this.closest('.alert').classList.add('d-none')"></button>
    </div>

    @if (!string.IsNullOrEmpty(Model.ThongBao))
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @Model.ThongBao
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (!string.IsNullOrEmpty(Model.LoiMsg))
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @Model.LoiMsg
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <ul class="nav nav-tabs mb-3" id="filterTab">
        <li class="nav-item">
            <a class="nav-link @(Model.FilterTab == "cho_duyet" ? "active" : "")"
               href="?tab=cho_duyet">Cho duyet (@Model.SoChoDuyet)</a>
        </li>
        <li class="nav-item">
            <a class="nav-link @(Model.FilterTab == "da_duyet" ? "active" : "")"
               href="?tab=da_duyet">Da duyet</a>
        </li>
        <li class="nav-item">
            <a class="nav-link @(Model.FilterTab == "tu_choi" ? "active" : "")"
               href="?tab=tu_choi">Da tu choi</a>
        </li>
    </ul>

    <div class="card border-0 shadow-sm">
        <div class="card-body p-0">
            <div class="px-3 py-2 border-bottom bg-light small text-muted">
                Trang tu kiem tra yeu cau moi moi 5 giay. Khi co thay doi, he thong se thong bao va tai lai neu admin khong dang thao tac.
            </div>
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Thiet bi</th>
                            <th>Goi</th>
                            <th>So tien</th>
                            <th>Noi dung CK</th>
                            <th>Thoi gian</th>
                            <th>Ghi chu admin</th>
                            <th>Thao tac</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.DanhSach.Any())
                        {
                            <tr>
                                <td colspan="7" class="text-center text-muted py-4">
                                    Khong co yeu cau nao.
                                </td>
                            </tr>
                        }
                        @foreach (var yc in Model.DanhSach)
                        {
                            <tr>
                                <td>
                                    <span class="font-monospace small fw-semibold" title="@yc.MaThietBi">
                                        @(yc.MaThietBi.Length > 8 ? yc.MaThietBi[..8].ToUpperInvariant() : yc.MaThietBi.ToUpperInvariant())
                                    </span>
                                    <div class="text-muted" style="font-size:10px">ID thiet bi</div>
                                </td>
                                <td>
                                    @switch (yc.LoaiGoi)
                                    {
                                        case "ngay":
                                            <span class="badge bg-secondary">1 ngay</span>
                                            break;
                                        case "tuan":
                                            <span class="badge bg-info text-dark">1 tuan</span>
                                            break;
                                        case "thang":
                                            <span class="badge bg-primary">1 thang</span>
                                            break;
                                        case "nam":
                                            <span class="badge bg-success">1 nam</span>
                                            break;
                                        default:
                                            <span class="badge bg-light text-dark">@yc.LoaiGoi</span>
                                            break;
                                    }
                                </td>
                                <td class="fw-semibold text-success">@yc.SoTien.ToString("N0")d</td>
                                <td>
                                    <code class="small">@yc.NoiDungChuyen</code>
                                </td>
                                <td class="small text-muted">
                                    @yc.NgayTao.ToLocalTime().ToString("dd/MM HH:mm")
                                    @if (yc.NgayDuyet.HasValue)
                                    {
                                        <br />
                                        <span class="text-info">-> @yc.NgayDuyet.Value.ToLocalTime().ToString("dd/MM HH:mm")</span>
                                    }
                                </td>
                                <td class="small text-muted">@(yc.GhiChuAdmin ?? "-")</td>
                                <td>
                                    @if (yc.TrangThai == "cho_duyet")
                                    {
                                        <form method="post" asp-page-handler="Approve" class="d-inline">
                                            <input type="hidden" name="yeuCauId" value="@yc.Id" />
                                            <button type="submit"
                                                    class="btn btn-sm btn-success me-1"
                                                    onclick="return confirm('Xac nhan duyet yeu cau nay?')">
                                                Duyet
                                            </button>
                                        </form>
                                        <button type="button"
                                                class="btn btn-sm btn-outline-danger"
                                                data-bs-toggle="modal"
                                                data-bs-target="#modalTuChoi"
                                                data-id="@yc.Id">
                                            Tu choi
                                        </button>
                                    }
                                    else if (yc.TrangThai == "da_duyet")
                                    {
                                        <span class="badge bg-success">Da duyet</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">Tu choi</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="modalTuChoi" tabindex="-1">
    <div class="modal-dialog">
        <form method="post" asp-page-handler="Reject">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Tu choi yeu cau</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" id="tuChoiId" name="yeuCauId" />
                    <div class="mb-3">
                        <label class="form-label">Ly do tu choi <span class="text-danger">*</span></label>
                        <textarea name="lyDo"
                                  class="form-control"
                                  rows="3"
                                  placeholder="Vi du: Khong tim thay giao dich khop noi dung chuyen khoan..."
                                  required></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Huy</button>
                    <button type="submit" class="btn btn-danger">Xac nhan tu choi</button>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
<script>
(function () {
    var rejectModal = document.getElementById('modalTuChoi');
    if (rejectModal) {
        rejectModal.addEventListener('show.bs.modal', function (e) {
            var id = e.relatedTarget.dataset.id;
            document.getElementById('tuChoiId').value = id;
        });
    }

    document.addEventListener('submit', function () {
        document.body.dataset.paymentSubmitting = '1';
    });

    var snapshotUrl = '@Url.Page(null, "PendingSnapshot")';
    var currentTitle = document.title;
    var lastCount = Number('@Model.SoChoDuyet');
    var lastLatestId = '@Model.LatestPendingId';
    var storageKey = 'vktPendingPaymentNotice';
    var alertBox = document.getElementById('paymentPendingAlert');
    var alertText = document.getElementById('paymentPendingAlertText');
    var pendingBadge = document.getElementById('pendingCountBadge');

    function isAdminEditing() {
        return document.body.dataset.paymentSubmitting === '1'
            || document.querySelector('.modal.show, textarea:focus, input:focus') !== null;
    }

    function normalizeSnapshot(data) {
        return {
            count: Number(data.count ?? data.Count ?? 0),
            latestId: data.latestId ?? data.LatestId ?? '',
            latestTransferContent: data.latestTransferContent ?? data.LatestTransferContent ?? '',
            latestDeviceShort: data.latestDeviceShort ?? data.LatestDeviceShort ?? ''
        };
    }

    function updateBadge(count) {
        if (pendingBadge) {
            pendingBadge.textContent = count + ' yeu cau cho duyet';
        }

        document.title = count > 0 ? '(' + count + ') ' + currentTitle : currentTitle;
    }

    function showPendingNotice(snapshot) {
        if (!alertBox || !alertText) return;

        var detail = snapshot.latestTransferContent
            ? ' Gan nhat: ' + snapshot.latestTransferContent
            : '';
        var device = snapshot.latestDeviceShort
            ? ' (' + snapshot.latestDeviceShort + ')'
            : '';

        alertText.textContent = 'Dang co ' + snapshot.count + ' yeu cau cho duyet' + device + '.' + detail;
        alertBox.classList.remove('d-none');

        if ('Notification' in window && Notification.permission === 'granted') {
            new Notification('Vinh Khanh Tour', {
                body: 'Co ' + snapshot.count + ' yeu cau thanh toan cho duyet.'
            });
        }
    }

    var queuedCount = Number(sessionStorage.getItem(storageKey) || '0');
    if (queuedCount > 0) {
        showPendingNotice({ count: queuedCount, latestTransferContent: '', latestDeviceShort: '' });
        sessionStorage.removeItem(storageKey);
    }

    async function pollPendingPayments() {
        try {
            var response = await fetch(snapshotUrl, {
                headers: { 'Accept': 'application/json' },
                cache: 'no-store'
            });
            if (!response.ok) return;

            var snapshot = normalizeSnapshot(await response.json());
            var hasChanged = snapshot.count !== lastCount || snapshot.latestId !== lastLatestId;
            var hasNewPending = snapshot.count > lastCount;

            updateBadge(snapshot.count);

            if (hasNewPending) {
                showPendingNotice(snapshot);
            }

            if (hasChanged) {
                lastCount = snapshot.count;
                lastLatestId = snapshot.latestId;
                sessionStorage.setItem(storageKey, String(snapshot.count));

                if (!isAdminEditing()) {
                    window.location.reload();
                } else {
                    showPendingNotice(snapshot);
                }
            }
        } catch {
            // Bo qua loi mang tam thoi; lan poll tiep theo se thu lai.
        }
    }

    updateBadge(lastCount);
    window.setInterval(pollPendingPayments, 5000);
})();
</script>
}
