@startuml
' Diagram: F01 - Kich hoat va khoi phuc quyen su dung app (Sequence)
' Status: WIP
' Baseline: branch master, HEAD adb1a28
' Source:
' - VinhKhanhTourDemo/App.xaml.cs: CreateWindow()
' - VinhKhanhTourDemo/LaunchPage.xaml.cs: RouteAsync()
' - VinhKhanhTourDemo/SubscriptionState.cs: IsSubscriptionActive(), HasStoredSubscriptionRecord()
' - VinhKhanhTourDemo/MainPage.xaml.cs: OnAppearing(), EnsureSubscriptionGateAsync(), RestoreSubscriptionStateAsync()
' - VinhKhanhTourDemo/SubscriptionPage.xaml.cs: OnAppearing(), UpdateRecoveryCard(), OnCopyRecoveryCodeClicked(), OnPasteRecoveryCodeClicked(), OnEnterRecoveryCodeClicked(), OnScanRecoveryQrClicked(), RestoreFromRecoveryCodeAsync(), OnMuaGoiClicked(), ActivateFreeTrialAsync(), UpdateTrialButtonState(), ExitSubscriptionGateAsync()
' - VinhKhanhTourDemo/QrScannerPage.xaml.cs: OnBarcodesDetected()
' - VinhKhanhTourDemo/DeviceIdentity.cs: GetDeviceId(), BuildRecoveryPayload(), BuildQrCodeUrl(), TrySetDeviceIdOverride()
' - VinhKhanhTourDemo/ApiConnectionPrompt.cs: EnsureConnectedApiBaseUrlAsync()
' - VinhKhanhTourDemo/PaymentPage.xaml.cs
' - VinhKhanhTour.API/Controllers/SubscriptionController.cs: GetStatus(), Purchase()
' Note: Sequence da cap nhat them luong recovery code/QR cua SubscriptionPage va giu luong subscription gate hien tai.
title F01 - Kich hoat va khoi phuc quyen su dung app

actor Guest
participant App
participant LaunchPage
participant SubscriptionState
participant MainPage
participant Preferences
participant DeviceIdentity
participant SubscriptionPage
participant Clipboard
participant QrScannerPage
participant PaymentPage
participant ApiConnectionPrompt
participant AppConfig
participant "SubscriptionController" as SubscriptionController
database DB

Guest -> App: mo ung dung
App -> LaunchPage: CreateWindow()\nNavigationPage(new LaunchPage)
LaunchPage -> LaunchPage: OnAppearing()\nRouteAsync()
LaunchPage -> SubscriptionState: IsSubscriptionActive()
SubscriptionState -> Preferences: Get(sub_ngay_het_han)
Preferences --> SubscriptionState: expiryRaw

alt subscription local con han
  SubscriptionState --> LaunchPage: true
  LaunchPage -> MainPage: PushAsync(new MainPage)
else chua co / het han local
  SubscriptionState --> LaunchPage: false
  LaunchPage -> SubscriptionState: HasStoredSubscriptionRecord()
  SubscriptionState -> Preferences: ContainsKey(sub_ngay_het_han)
  SubscriptionState --> LaunchPage: hetHan
  LaunchPage -> SubscriptionPage: PushAsync(new SubscriptionPage(hetHan))
  SubscriptionPage -> SubscriptionPage: OnAppearing()
  SubscriptionPage -> DeviceIdentity: BuildRecoveryPayload()
  DeviceIdentity --> SubscriptionPage: payload
  SubscriptionPage -> DeviceIdentity: BuildQrCodeUrl()
  DeviceIdentity --> SubscriptionPage: qrUrl
  SubscriptionPage -> SubscriptionPage: UpdateRecoveryCard()\nUpdateTrialButtonState()
end

opt MainPage xuat hien nhung subscription local khong hop le
  MainPage -> MainPage: EnsureSubscriptionGateAsync()
  MainPage -> Preferences: KiemTraSubscription()
  MainPage -> DeviceIdentity: GetDeviceId()
  MainPage -> AppConfig: EnsureApiBaseUrlAsync()
  MainPage -> SubscriptionController: GET /api/subscription/status/{deviceId}
  SubscriptionController -> DB: doc DangKyApp con han\nkiem tra da dung thu
  DB --> SubscriptionController: status
  SubscriptionController --> MainPage: CoDangKy, NgayHetHan, DaDungThu
  MainPage -> Preferences: Set(da_dung_thu)\nSet(sub_ngay_het_han)
  alt van chua co goi hop le
    MainPage -> SubscriptionPage: PushModalAsync(new SubscriptionPage(hetHan))
  end
end

alt nguoi dung copy recovery code
  Guest -> SubscriptionPage: OnCopyRecoveryCodeClicked()
  SubscriptionPage -> DeviceIdentity: BuildRecoveryPayload()
  DeviceIdentity --> SubscriptionPage: payload
  SubscriptionPage -> Clipboard: SetTextAsync(payload)
else nguoi dung paste / nhap recovery code
  Guest -> SubscriptionPage: OnPasteRecoveryCodeClicked() / OnEnterRecoveryCodeClicked()
  SubscriptionPage -> SubscriptionPage: RestoreFromRecoveryCodeAsync(rawCode)
  SubscriptionPage -> DeviceIdentity: TrySetDeviceIdOverride(rawCode)
  alt ma hop le
    DeviceIdentity --> SubscriptionPage: restoredDeviceId
    SubscriptionPage -> SubscriptionPage: UpdateRecoveryCard()\nSetLoading(true)
    SubscriptionPage -> ApiConnectionPrompt: EnsureConnectedApiBaseUrlAsync(this, http)
    ApiConnectionPrompt -> AppConfig: EnsureApiBaseUrlAsync()
    AppConfig --> ApiConnectionPrompt: apiBaseUrl?
    ApiConnectionPrompt --> SubscriptionPage: apiBaseUrl
    SubscriptionPage -> SubscriptionController: GET /api/subscription/status/{restoredDeviceId}
    SubscriptionController -> DB: doc DangKyApp theo ma thiet bi
    DB --> SubscriptionController: status
    SubscriptionController --> SubscriptionPage: CoDangKy, NgayHetHan, DaDungThu
    SubscriptionPage -> Preferences: Set(da_dung_thu)\nSet(sub_ngay_het_han neu co)
    SubscriptionPage -> SubscriptionPage: UpdateTrialButtonState()
    alt goi da duoc khoi phuc va con han
      SubscriptionPage -> MainPage: ExitSubscriptionGateAsync()
    else chi doi ma thiet bi, chua co goi active
      SubscriptionPage -> Guest: hien LblRecoveryStatus
    end
    SubscriptionPage -> SubscriptionPage: SetLoading(false)
  else ma khong hop le
    DeviceIdentity --> SubscriptionPage: false
    SubscriptionPage -> Guest: hien LblRecoveryStatus
  end
else nguoi dung scan QR recovery
  Guest -> SubscriptionPage: OnScanRecoveryQrClicked()
  SubscriptionPage -> SubscriptionPage: RequestAsync<Permissions.Camera>()
  alt duoc cap quyen camera
    SubscriptionPage -> QrScannerPage: PushModalAsync(new QrScannerPage(RestoreFromRecoveryCodeAsync))
    QrScannerPage -> QrScannerPage: OnBarcodesDetected()
    QrScannerPage -> SubscriptionPage: RestoreFromRecoveryCodeAsync(rawCode)
    SubscriptionPage -> DeviceIdentity: TrySetDeviceIdOverride(rawCode)
    alt ma hop le
      DeviceIdentity --> SubscriptionPage: restoredDeviceId
      SubscriptionPage -> SubscriptionPage: UpdateRecoveryCard()\nSetLoading(true)
      SubscriptionPage -> ApiConnectionPrompt: EnsureConnectedApiBaseUrlAsync(this, http)
      ApiConnectionPrompt -> AppConfig: EnsureApiBaseUrlAsync()
      AppConfig --> ApiConnectionPrompt: apiBaseUrl?
      ApiConnectionPrompt --> SubscriptionPage: apiBaseUrl
      SubscriptionPage -> SubscriptionController: GET /api/subscription/status/{restoredDeviceId}
      SubscriptionController -> DB: doc DangKyApp theo ma thiet bi
      DB --> SubscriptionController: status
      SubscriptionController --> SubscriptionPage: CoDangKy, NgayHetHan, DaDungThu
      SubscriptionPage -> Preferences: Set(da_dung_thu)\nSet(sub_ngay_het_han neu co)
      SubscriptionPage -> SubscriptionPage: UpdateTrialButtonState()
      alt goi da duoc khoi phuc va con han
        SubscriptionPage -> MainPage: ExitSubscriptionGateAsync()
      else chi doi ma thiet bi, chua co goi active
        SubscriptionPage -> Guest: hien LblRecoveryStatus
      end
      SubscriptionPage -> SubscriptionPage: SetLoading(false)
    else ma khong hop le
      DeviceIdentity --> SubscriptionPage: false
      SubscriptionPage -> Guest: hien LblRecoveryStatus
    end
  else bi tu choi quyen camera
    SubscriptionPage -> Guest: hien thong bao can quyen camera
  end
end

alt nguoi dung chon goi dung thu
  Guest -> SubscriptionPage: OnMuaGoiClicked("thu")
  SubscriptionPage -> DeviceIdentity: GetDeviceId()
  DeviceIdentity -> Preferences: doc override/device_id\nhoac tao stable id
  DeviceIdentity --> SubscriptionPage: deviceId
  SubscriptionPage -> ApiConnectionPrompt: EnsureConnectedApiBaseUrlAsync(this, http)
  ApiConnectionPrompt -> AppConfig: EnsureApiBaseUrlAsync()
  AppConfig --> ApiConnectionPrompt: apiBaseUrl?
  alt ket noi API thanh cong
    ApiConnectionPrompt --> SubscriptionPage: apiBaseUrl
    SubscriptionPage -> SubscriptionController: POST /api/subscription/purchase
    SubscriptionController -> DB: neu goi thu, kiem tra da dung thu\ninsert DangKyApp
    DB --> SubscriptionController: saved
    SubscriptionController --> SubscriptionPage: ngayHetHan
    SubscriptionPage -> Preferences: Set(sub_ngay_het_han)\nSet(da_dung_thu)
    SubscriptionPage -> SubscriptionPage: UpdateTrialButtonState()
    SubscriptionPage -> MainPage: ExitSubscriptionGateAsync()
  else khong tim thay API dung
    ApiConnectionPrompt --> SubscriptionPage: null
    SubscriptionPage -> Guest: hien LblError
  end
else nguoi dung chon goi tra phi
  Guest -> SubscriptionPage: OnMuaGoiClicked("ngay|tuan|thang|nam")
  SubscriptionPage -> PaymentPage: PushModalAsync(loaiGoi)
end

@enduml
