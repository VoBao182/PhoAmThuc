' Note: Sequence khong liet ke cau SQL; chi the hien cac ham doc du lieu va xu ly tong hop trong IndexModel.
title F09 - Theo doi khach hang va trang thai su dung

actor Admin
control "BanDo IndexModel" as IndexModel
participant "AppDbContext\n<<persistence>>" as DbContext
participant "Raw read helper\n(ExecuteRawReadAsync)" as RawRead
database "PostgreSQL" as DB

Admin -> IndexModel: OnGetAsync(search, filter, sort, dir)
IndexModel -> IndexModel: NormalizeOption(filter/sort)\nSortDir\nnow, onlineCutoff, expiringSoonCutoff

IndexModel -> IndexModel: LoadSubscriptionsAsync()
IndexModel -> DbContext: Database.GetConnectionString()
DbContext --> IndexModel: connection string
IndexModel -> RawRead: ExecuteRawReadAsync("subscriptions")
RawRead -> DB: read subscription aggregates
DB --> RawRead: rows
RawRead --> IndexModel: DeviceSubscription[]

IndexModel -> IndexModel: LoadLocationsAsync()
IndexModel -> RawRead: ExecuteRawReadAsync("locations")
RawRead -> DB: read location snapshots
DB --> RawRead: rows
RawRead --> IndexModel: DeviceLocation[]

IndexModel -> IndexModel: LoadPoiActivityCountsAsync(VisitedSourceValues)
IndexModel -> RawRead: ExecuteRawReadAsync("visitedCounts")
RawRead -> DB: read visited POI counts
DB --> RawRead: rows
RawRead --> IndexModel: DevicePoiCount[]

IndexModel -> IndexModel: LoadPoiActivityCountsAsync(ViewedSourceValues)
IndexModel -> RawRead: ExecuteRawReadAsync("viewedCounts")
RawRead -> DB: read viewed POI counts
DB --> RawRead: rows
RawRead --> IndexModel: DevicePoiCount[]

IndexModel -> IndexModel: BuildCustomerRows()
note right of IndexModel
  BuildCustomerRows() derives:
  expiresAt, currentPoi, isOnline,
  viewedCount, visitedCount,
  experiencePoints and level.
end note
IndexModel -> IndexModel: ApplySearch()\nApplyFilter()\nApplySort()
IndexModel --> Admin: render customer table + summary tiles
@enduml
