@startuml
' Diagram: F04 - Xem chi tiet POI, thuc don, audio guide va chi duong (Activity)
' Status: VERIFIED
' Baseline: branch master, HEAD b946abe
' Source:
' - VinhKhanhTourDemo/DetailPage.xaml.cs: LoadDetail(), UseFallback(), ConfigureAudioPlayer(), RenderMenu(), OnNgheClicked(), OnMapClicked()
' - VinhKhanhTourDemo/FoodImageCatalog.cs: GetPoiImageSource(), GetDishImageSource(), TryCreateImageSource()
' - VinhKhanhTourDemo/AppConfig.cs: ResolveImageUrl()
' - VinhKhanhTour.API/Controllers/PoiController.cs: GetById()
' Note: Da bo sung dung logic fallback anh hien tai qua FoodImageCatalog; luong activity khop voi DetailPage hien tai.
title F04 - Xem chi tiet POI, thuc don, audio guide va chi duong
start
:Tao DetailPage(poiBasic);
:InitializeAudioBridge();
:ApplyLocalizedLabels();
:LoadDetail(poiId, tenPoi);

:AppConfig.EnsureApiBaseUrlAsync();
:GET /api/poi/{id}?lang=_lang;
if (API thanh cong?) then (Co)
  :FoodImageCatalog.GetPoiImageSource(_poi.AnhDaiDien, _poi.TenPOI);
  :Gan ImgCover, thong tin quan,\nNoiDungThuyetMinh, MonAns;
  :ConfigureAudioPlayer();
  :RenderMenu(_poi.MonAns);
  :Voi tung mon an, FoodImageCatalog.GetDishImageSource();
else (Khong)
  :UseFallback(tenPoi);
  :FoodImageCatalog.GetPoiImageSource(_poiBasic.AnhDaiDien, tenPoi);
  :An SectionMenu;
endif

if (Nguoi dung bam nghe?) then (Co)
  if (Co FileAudio?) then (Co)
    :AudioControls.IsVisible = true;
    if (_audioBridgeReady?) then (Co)
      :ExecuteAudioScript("playAudio()");
    else (Chua)
      :_playWhenReady = true;
    endif
  else (Khong)
    if (NoiDungThuyetMinh rong?) then (Co)
      :DisplayAlert(AppStrings.NoAudio);
    else (Khong)
      :TextToSpeech.Default.SpeakAsync(text);
    endif
  endif
endif

if (Nguoi dung pause/stop/seek?) then (Co)
  :OnPlayPauseClicked() / OnStopAudioClicked() /\nOnAudioSliderDragCompleted();
  :ExecuteAudioScript(...);
endif

if (Nguoi dung bam Chi duong?) then (Co)
  :Browser.Default.OpenAsync(google maps q=lat,lng);
endif

stop
@enduml
