@startuml
' Diagram: F01 - Kich hoat quyen su dung app (Activity)
' Status: WIP
' Baseline: branch master, HEAD a5fde70
' Source:
' - VinhKhanhTourDemo/App.xaml.cs: CreateWindow(), BuildMissingConfigurationPage()
' - VinhKhanhTourDemo/MainPage.xaml.cs: OnAppearing(), EnsureSubscriptionGateAsync(), KiemTraSubscription()
' - VinhKhanhTourDemo/SubscriptionPage.xaml.cs: OnAppearing(), UpdateTrialButtonState(), OnMuaGoiClicked(), ActivateFreeTrialAsync(), GetDeviceId()
' - VinhKhanhTourDemo/ApiConnectionPrompt.cs: EnsureConnectedApiBaseUrlAsync()
' - VinhKhanhTour.API/Controllers/SubscriptionController.cs: Purchase()
' Note: Da cap nhat theo baseline hien tai co them nhanh chan app neu Android phat hanh chua cau hinh HostedApiBaseUrl, va prompt ket noi API truoc khi kich hoat goi dung thu.
title F01 - Kich hoat quyen su dung app
start
:App.CreateWindow();
if (ShouldBlockPublishedAndroidApp?) then (Co)
  :BuildMissingConfigurationPage();
  stop
endif

:MainPage.OnAppearing();
if (KiemTraSubscription() con han?) then (Co)
  if (_isInitialized == false?) then (Co)
    :LoadPoisFromApi();
  endif
  :EnsureGpsTrackingAsync();
  stop
else (Khong)
  :EnsureSubscriptionGateAsync();
  :Navigation.PushModalAsync(SubscriptionPage);

  if (Nguoi dung chon goi dung thu?) then (Co)
    :SubscriptionPage.OnMuaGoiClicked("thu");
    :GetDeviceId();
    :ActivateFreeTrialAsync();
    :ApiConnectionPrompt.EnsureConnectedApiBaseUrlAsync();
    if (Tim thay API dung va reachable?) then (Co)
      :POST /api/subscription/purchase;
      :Preferences.Set(sub_ngay_het_han);
      :Preferences.Set(da_dung_thu = true);
      :DisplayAlert thanh cong;
      :PopModalAsync();
    else (Khong)
      :Hien loi / DisplayAlert tren SubscriptionPage;
    endif
  else (Goi tra phi)
    :Navigation.PushModalAsync(PaymentPage);
    note right
      Luong chi tiet cua goi tra phi
      duoc mo ta o F05.
    end note
  endif
endif
stop
@enduml
