@startuml
' Diagram: F02 - Tai va kham pha danh sach POI (Activity)
' Status: WIP
' Baseline: branch master, HEAD 29947b2
' Source:
' - VinhKhanhTourDemo/MainPage.xaml.cs: OnAppearing(), LoadPoisFromApi(), RestorePoiHistoryAsync(), RefreshPoisInBackgroundAsync(), RefreshMapIfNeeded(), RenderPoiCards(), OnSearchTextChanged(), OpenPoiDetailAsync(), RecordPoiViewAsync(), SyncPoiHistoryAsync(), UpdateCaiDatUI()
' - VinhKhanhTourDemo/DeviceIdentity.cs: GetDeviceId()
' - VinhKhanhTour.API/Controllers/PoiController.cs: GetAll()
' - VinhKhanhTour.API/Controllers/HeartbeatController.cs: GetExperienceProfile(), RecordView(), SyncHistory()
' Note: Da cap nhat theo code hien tai co restore profile/XP tu /api/heartbeat/profile va refresh POI nen moi 20 giay.
title F02 - Tai va kham pha danh sach POI
start
:MainPage.OnAppearing();
if (_uiPrepared == false?) then (Co)
  :ApplyLocalizedUiText();
  :UpdateCaiDatUI();
endif

if (_isInitialized == false?) then (Co)
  :LoadPoisFromApi();
  :AppConfig.EnsureApiBaseUrlAsync();
  :GET /api/poi;
  if (API thanh cong?) then (Co)
    :_pois = ket qua tu PoiController.GetAll();
    :_isUsingFallbackData = false;
    :_lastDataLoadError = null;
    :RestorePoiHistoryAsync();
    :GET /api/heartbeat/profile/{maThietBi};
    :SyncPoiHistoryAsync();
    :POST /api/heartbeat/sync-history;
  else (Khong)
    :CreateFallbackPois();
    :_isUsingFallbackData = true;
    :_lastDataLoadError = ex.Message;
  endif
else (Da tai)
  :Bo qua tai danh sach lan dau;
endif

:RefreshMapIfNeeded();
:RenderPoiCards();
:UpdateApiConnectionUi();
:RestorePoiHistoryAsync();
:EnsureGpsTrackingAsync();
:SyncPoiHistoryAsync();

while (Nguoi dung tiep tuc kham pha?) is (Co)
  if (Nhap tu khoa tim kiem?) then (Co)
    :OnSearchTextChanged();
    :GetVisiblePois();
    :RenderPoiCards();
    :RefreshMapIfNeeded();
  endif

  if (Bam xem chi tiet POI?) then (Co)
    :OpenPoiDetailAsync(poi);
    :RecordViewedPoi(poi);
    :RecordPoiViewAsync(poi);
    :SyncPoiHistoryAsync();
    :UpdateCaiDatUI();
    :Navigation.PushAsync(new DetailPage(poi));
  endif

  if (Den chu ky refresh nen 20 giay?) then (Co)
    :RefreshPoisInBackgroundAsync();
    :GET /api/poi;
    :RefreshMapIfNeeded();
    :RenderPoiCards();
  endif
endwhile (Khong)

stop
@enduml
