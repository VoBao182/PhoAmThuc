@startuml
' Diagram: F02 - Tai va kham pha danh sach POI (Activity)
' Status: VERIFIED
' Baseline: branch master, current worktree @ HEAD 8ed8643
' Source:
' - VinhKhanhTourDemo/MainPage.xaml.cs: OnAppearing(), LoadPoisFromApi(), RestoreSubscriptionStateAsync(), RestorePoiHistoryAsync(), RefreshPoisInBackgroundAsync(), RefreshMapIfNeeded(), LoadMap(), GetMapPoiSignature(), GetPoiVisualPositions(), ShowMapPoiSheet(), RenderPoiCards(), OnSearchTextChanged(), OpenPoiDetailAsync(), RecordPoiViewAsync(), SyncPoiHistoryAsync(), UpdateCaiDatUI(), OnCopyDeviceCodeClicked(), OnPasteDeviceCodeClicked(), OnScanDeviceQrClicked(), OnRestoreDeviceCodeClicked(), RestoreDeviceCodeAsync()
' - VinhKhanhTourDemo/QrScannerPage.xaml.cs: OnBarcodesDetected()
' - VinhKhanhTourDemo/DeviceIdentity.cs: GetDeviceId(), BuildRecoveryPayload(), BuildQrCodeUrl(), TrySetDeviceIdOverride()
' - VinhKhanhTour.API/Controllers/PoiController.cs: GetAll()
' - VinhKhanhTour.API/Controllers/HeartbeatController.cs: GetExperienceProfile(), RecordView(), SyncHistory()
' - VinhKhanhTour.API/Controllers/SubscriptionController.cs: GetStatus()
' Note: So do chi tiet hoa fallback seed data, khoi phuc lich su/XP, render tab explore-ban do-cai dat, va luong khoi phuc ma thiet bi trong MainPage.
' Note: Map hien tai ve vong geofence theo toa do that cua POI, co the offset marker hien thi de tranh chong len, ve guide line noi marker den toa do that, va chi rebuild HTML map khi chu ky POI thay doi.
' Note: Luong ghi nhan "visit" khi geofence trigger (RecordPoiVisitAsync -> POST /api/heartbeat/visit) duoc mo hinh o F03 (Geofence/Audio) de tach concern.
title F02 - Tai va kham pha danh sach POI
start
:MainPage.OnAppearing();
if (_uiPrepared == false?) then (Co)
  :ApplyLocalizedUiText();
  :UpdateCaiDatUI();
  :DeviceIdentity.BuildRecoveryPayload();
  :DeviceIdentity.BuildQrCodeUrl();
endif

if (_isInitialized == false?) then (Co)
  :LoadPoisFromApi();
  :AppConfig.EnsureApiBaseUrlAsync();
  :GET /api/poi;
  if (API thanh cong?) then (Co)
    :_pois = ket qua tu PoiController.GetAll();
    :_isUsingFallbackData = false;
    :_lastDataLoadError = null;
    :RestorePoiHistoryAsync();
    :GET /api/heartbeat/profile/{maThietBi};
    :SyncPoiHistoryAsync();
    :POST /api/heartbeat/sync-history;
  else (Khong)
    :CreateFallbackPois();
    :_isUsingFallbackData = true;
    :_lastDataLoadError = ex.Message;
    :Neu co yeu cau explicit reload -> co the DisplayAlert loi;
  endif
else (Da tai)
  :Bo qua tai danh sach lan dau;
endif

:RefreshMapIfNeeded();
if (MapWebView null hoac chu ky POI thay doi?) then (Co)
  :LoadMap();
  :GetPoiVisualPositions();
  :Ve geofence circle theo ViDo/KinhDo that;
  :Ve marker theo DisplayViDo/DisplayKinhDo;
  :Neu marker bi offset -> ve guide line + diem true position;
else (Khong)
  :Chi update user location/hightlight tren map hien co;
endif
:RenderPoiCards();
:UpdateApiConnectionUi();
:RestorePoiHistoryAsync();
:EnsureGpsTrackingAsync();
:SyncPoiHistoryAsync();

if (Nguoi dung chuyen tab Ban do?) then (Co)
  :Map tab load marker tu _pois;
  :Marker bam vao -> poi://{id};
  :Cho phep bam marker/card de mo sheet chi tiet;
endif

while (Nguoi dung tiep tuc kham pha?) is (Co)
  if (Nhap tu khoa tim kiem?) then (Co)
    :OnSearchTextChanged();
    :GetVisiblePois();
    :RenderPoiCards();
    :RefreshMapIfNeeded();
  endif

  if (Bam xem chi tiet POI?) then (Co)
    :OpenPoiDetailAsync(poi);
    :RecordViewedPoi(poi);
    :RecordPoiViewAsync(poi);
    :SyncPoiHistoryAsync();
    :UpdateCaiDatUI();
    :Navigation.PushAsync(new DetailPage(poi));
  endif

  if (Bam marker tren ban do / sheet POI?) then (Co)
    :ShowMapPoiSheet(poi);
    :Cho phep "Xem chi tiet" tu sheet;
  endif

  if (Mo tab Cai dat va sao chep ma thiet bi?) then (Co)
    :OnCopyDeviceCodeClicked();
    :DeviceIdentity.BuildRecoveryPayload();
    :Clipboard.SetTextAsync(payload);
  endif

  if (Mo tab Cai dat va khoi phuc bang paste / nhap / QR?) then (Co)
    if (Khoi phuc bang QR?) then (Co)
      :OnScanDeviceQrClicked();
      :Request camera permission;
      if (Duoc cap quyen?) then (Co)
        :Navigation.PushModalAsync(new QrScannerPage(RestoreDeviceCodeAsync));
        :QrScannerPage.OnBarcodesDetected();
        :RestoreDeviceCodeAsync(code);
      else (Khong)
        :Hien thong bao can quyen camera;
      endif
    else (Paste/Nhap)
      :OnPasteDeviceCodeClicked() hoac OnRestoreDeviceCodeClicked();
      :RestoreDeviceCodeAsync(code);
    endif

    :DeviceIdentity.TrySetDeviceIdOverride(code, out deviceId);
    if (Ma hop le?) then (Co)
      :RestoreSubscriptionStateAsync();
      :GET /api/subscription/status/{maThietBi};
      :RestorePoiHistoryAsync();
      :GET /api/heartbeat/profile/{maThietBi};
      :SyncPoiHistoryAsync();
      :POST /api/heartbeat/sync-history;
      :UpdateCaiDatUI();
      :DeviceIdentity.BuildRecoveryPayload();
      :DeviceIdentity.BuildQrCodeUrl();
      :DisplayAlert da khoi phuc;
    else (Khong)
      :DisplayAlert ma khong hop le;
    endif
  endif

  if (Den chu ky refresh nen 20 giay?) then (Co)
    :RefreshPoisInBackgroundAsync();
    :GET /api/poi;
    :RefreshMapIfNeeded();
    :RenderPoiCards();
    :Neu dang o map sheet thi cap nhat badge/near status;
  endif
endwhile (Khong)

stop
@enduml
