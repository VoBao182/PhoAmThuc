@startuml
' Diagram: F02 - Tai va kham pha danh sach POI (Activity)
' Status: WIP
' Baseline: branch master, HEAD b618c08
' Source:
' - VinhKhanhTourDemo/MainPage.xaml.cs: OnAppearing(), LoadPoisFromApi(), RestoreSubscriptionStateAsync(), RestorePoiHistoryAsync(), RefreshPoisInBackgroundAsync(), RefreshMapIfNeeded(), RenderPoiCards(), OnSearchTextChanged(), OpenPoiDetailAsync(), RecordPoiViewAsync(), SyncPoiHistoryAsync(), UpdateCaiDatUI(), OnCopyDeviceCodeClicked(), OnPasteDeviceCodeClicked(), OnScanDeviceQrClicked(), OnRestoreDeviceCodeClicked(), RestoreDeviceCodeAsync()
' - VinhKhanhTourDemo/QrScannerPage.xaml.cs: OnBarcodesDetected()
' - VinhKhanhTourDemo/DeviceIdentity.cs: GetDeviceId(), BuildRecoveryPayload(), BuildQrCodeUrl(), TrySetDeviceIdOverride()
' - VinhKhanhTour.API/Controllers/PoiController.cs: GetAll()
' - VinhKhanhTour.API/Controllers/HeartbeatController.cs: GetExperienceProfile(), RecordView(), SyncHistory()
' - VinhKhanhTour.API/Controllers/SubscriptionController.cs: GetStatus()
' Note: Da bo sung luong khoi phuc ma thiet bi trong tab Cai dat cua MainPage va giu luong explore/refresh 20 giay theo code hien tai.
title F02 - Tai va kham pha danh sach POI
start
:MainPage.OnAppearing();
if (_uiPrepared == false?) then (Co)
  :ApplyLocalizedUiText();
  :UpdateCaiDatUI();
  :DeviceIdentity.BuildRecoveryPayload();
  :DeviceIdentity.BuildQrCodeUrl();
endif

if (_isInitialized == false?) then (Co)
  :LoadPoisFromApi();
  :AppConfig.EnsureApiBaseUrlAsync();
  :GET /api/poi;
  if (API thanh cong?) then (Co)
    :_pois = ket qua tu PoiController.GetAll();
    :_isUsingFallbackData = false;
    :_lastDataLoadError = null;
    :RestorePoiHistoryAsync();
    :GET /api/heartbeat/profile/{maThietBi};
    :SyncPoiHistoryAsync();
    :POST /api/heartbeat/sync-history;
  else (Khong)
    :CreateFallbackPois();
    :_isUsingFallbackData = true;
    :_lastDataLoadError = ex.Message;
  endif
else (Da tai)
  :Bo qua tai danh sach lan dau;
endif

:RefreshMapIfNeeded();
:RenderPoiCards();
:UpdateApiConnectionUi();
:RestorePoiHistoryAsync();
:EnsureGpsTrackingAsync();
:SyncPoiHistoryAsync();

while (Nguoi dung tiep tuc kham pha?) is (Co)
  if (Nhap tu khoa tim kiem?) then (Co)
    :OnSearchTextChanged();
    :GetVisiblePois();
    :RenderPoiCards();
    :RefreshMapIfNeeded();
  endif

  if (Bam xem chi tiet POI?) then (Co)
    :OpenPoiDetailAsync(poi);
    :RecordViewedPoi(poi);
    :RecordPoiViewAsync(poi);
    :SyncPoiHistoryAsync();
    :UpdateCaiDatUI();
    :Navigation.PushAsync(new DetailPage(poi));
  endif

  if (Mo tab Cai dat va sao chep ma thiet bi?) then (Co)
    :OnCopyDeviceCodeClicked();
    :DeviceIdentity.BuildRecoveryPayload();
    :Clipboard.SetTextAsync(payload);
  endif

  if (Mo tab Cai dat va khoi phuc bang paste / nhap / QR?) then (Co)
    if (Khoi phuc bang QR?) then (Co)
      :OnScanDeviceQrClicked();
      :Request camera permission;
      if (Duoc cap quyen?) then (Co)
        :Navigation.PushModalAsync(new QrScannerPage(RestoreDeviceCodeAsync));
        :QrScannerPage.OnBarcodesDetected();
        :RestoreDeviceCodeAsync(code);
      else (Khong)
        :Hien thong bao can quyen camera;
      endif
    else (Paste/Nhap)
      :OnPasteDeviceCodeClicked() hoac OnRestoreDeviceCodeClicked();
      :RestoreDeviceCodeAsync(code);
    endif

    :DeviceIdentity.TrySetDeviceIdOverride(code, out deviceId);
    if (Ma hop le?) then (Co)
      :RestoreSubscriptionStateAsync();
      :GET /api/subscription/status/{maThietBi};
      :RestorePoiHistoryAsync();
      :GET /api/heartbeat/profile/{maThietBi};
      :SyncPoiHistoryAsync();
      :POST /api/heartbeat/sync-history;
      :UpdateCaiDatUI();
      :DeviceIdentity.BuildRecoveryPayload();
      :DeviceIdentity.BuildQrCodeUrl();
      :DisplayAlert da khoi phuc;
    else (Khong)
      :DisplayAlert ma khong hop le;
    endif
  endif

  if (Den chu ky refresh nen 20 giay?) then (Co)
    :RefreshPoisInBackgroundAsync();
    :GET /api/poi;
    :RefreshMapIfNeeded();
    :RenderPoiCards();
  endif
endwhile (Khong)

stop
@enduml
