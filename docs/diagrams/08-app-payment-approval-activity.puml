@startuml
' Diagram: F08 - Duyet hoac tu choi thanh toan goi app (Activity)
' Status: VERIFIED
' Baseline: HEAD 8ca9ec7
' Source:
' - VinhKhanhTour.CMS/Pages/DuyetThanhToan/Index.cshtml.cs: OnGetAsync(), LoadStatsAsync(), LoadListAsync(), OnGetPendingSnapshotAsync(), OnPostApproveAsync(), OnPostRejectAsync()
' - VinhKhanhTour.CMS/Pages/DuyetThanhToan/Index.cshtml: snapshotUrl, polling JS
' - VinhKhanhTour.API/Models/YeuCauThanhToan.cs
' - VinhKhanhTour.API/Models/DangKyApp.cs
' Note: Luong da sync voi code hien tai: page load tach LoadStatsAsync()/LoadListAsync(), polling PendingSnapshot 5s, approve tinh han moi, va reject bat buoc co lyDo.
title F08 - Duyet hoac tu choi thanh toan goi app
start
:DuyetThanhToan/Index.OnGetAsync(tab,...);
:NormalizeTab(tab) va NormalizePackage(pkg);
:LoadStatsAsync();
:LoadListAsync();

if (JS polling snapshot?) then (Co)
  :OnGetPendingSnapshotAsync();
  :Query count cho_duyet va request moi nhat;
  if (Query thanh cong?) then (Co)
    :Tra JSON Count, LatestId,\nLatestTransferContent, LatestDeviceShort, Ok=true;
  else (Loi)
    :Neu IsDisposedWaitHandle -> ClearNpgsqlPoolsQuietly();
    :Tra 503 JSON Ok=false;
  endif
endif

if (Admin bam Duyet?) then (Co)
  :OnPostApproveAsync(yeuCauId);
  :Load yeu cau;
  if (Yeu cau khong ton tai?) then (Co)
    :Redirect voi thong bao loi;
  else (Hop le)
    if (TrangThai != cho_duyet?) then (Co)
      :Redirect voi thong bao loi;
    else (Khong)
      if (LoaiGoi khong hop le?) then (Co)
        :Redirect voi thong bao loi;
      else (Hop le)
        :Tra bang Goi de lay so ngay;
        :Tim goi DangKyApp con han cua thiet bi;
        :Tinh mocBatDau va hetHan moi;
        :Them DangKyApp moi;
        :Cap nhat YeuCauThanhToan -> da_duyet;
        :SaveChangesAsync();
        :Redirect ve tab cho_duyet;
      endif
    endif
  endif
else (Khong)
  if (Admin bam Tu choi?) then (Co)
    :OnPostRejectAsync(yeuCauId, lyDo);
    if (lyDo rong?) then (Co)
      :Redirect voi thong bao loi;
    else (Khong)
      :Load yeu cau;
      if (Yeu cau khong ton tai?) then (Co)
        :Redirect voi thong bao loi;
      else (Khong)
        if (TrangThai == cho_duyet?) then (Co)
          :Cap nhat TrangThai = tu_choi;
          :NgayDuyet = now;
          :GhiChuAdmin = lyDo;
          :SaveChangesAsync();
          :Redirect ve tab tu_choi;
        else (Khong)
          :Redirect voi thong bao loi;
        endif
      endif
    endif
  endif
endif

stop
@enduml
