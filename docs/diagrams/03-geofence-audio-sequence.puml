@startuml
' Diagram: F03 - Theo doi GPS, geofence va tu dong phat thuyet minh (Sequence)
' Status: VERIFIED
' Baseline: branch master, current worktree @ HEAD 0121e4f
' Source:
' - VinhKhanhTourDemo/MainPage.xaml.cs: OnAppearing(), StartGpsTracking(), CheckGeofence(), SelectPoiForLocation(), SendHeartbeatAsync(), RecordPoiVisitAsync(), SyncPoiHistoryAsync(), QueuePoiPlayback(), ProcessSpeakQueueAsync(), SpeakPoiAsync(), LogPlaybackAsync()
' - VinhKhanhTourDemo/DeviceIdentity.cs: GetDeviceId()
' - VinhKhanhTour.API/Controllers/HeartbeatController.cs: SendHeartbeat(), RecordVisit(), SyncHistory(), VerifyCurrentPoiAsync()
' - VinhKhanhTour.API/Controllers/ThuyetMinhController.cs: GetByPoi()
' - VinhKhanhTour.API/Controllers/LogController.cs: Post()
' Note: Sequence da sync dwell 5 giay truoc khi xac nhan vao POI, heartbeat 10 giay, refresh POI 20 giay.
' Note: Nhanh "giua 2 POI" tach tuong minh: sort theo MucUuTien -> Distance -> TenPOI + hysteresis 5m.
' Note: Queue audio per-device duoc tach hoan toan vao SpeakQueue (lock + semaphore + dedup); chi tiet o 03b-queue-playback-sequence.puml.
title F03 - Theo doi GPS, geofence va tu dong phat thuyet minh

actor Guest
participant MainPage
participant DeviceIdentity
participant "Geolocation / GPS" as GPS
participant "SpeakQueue\n(per-device)" as SpeakQueue
participant "HeartbeatController" as HeartbeatController
participant "ThuyetMinhController" as ThuyetMinhController
participant "LogController" as LogController
participant "TextToSpeech" as TTS
participant "AppDbContext\n<<persistence>>" as DbContext
database "PostgreSQL" as DB

Guest -> MainPage: cho phep vi tri
MainPage -> MainPage: EnsureGpsTrackingAsync()\nStartGpsTracking()
opt dong bo lich su local khi vao lai MainPage
  MainPage -> HeartbeatController: POST /api/heartbeat/sync-history
  HeartbeatController -> DbContext: LichSuPhats.Where(...).ToListAsync()
  DbContext -> DB: read existing history rows
  DB --> DbContext: history rows
  DbContext --> HeartbeatController: existing rows
  HeartbeatController -> DbContext: LichSuPhats.AddRange()/SaveChangesAsync()
  DbContext -> DB: persist missing LichSuPhat rows
  DB --> DbContext: saved
end

loop moi 5 giay
  MainPage -> GPS: GetLocationAsync()
  GPS --> MainPage: lat/lng
  MainPage -> MainPage: CheckGeofence(location)

  group SelectPoiForLocation - xu ly chong lan giua 2 POI
    MainPage -> MainPage: tinh distance moi POI\nloc distance <= BanKinh\nsort MucUuTien -> Distance -> TenPOI
    alt khong co POI nao trong ban kinh
      MainPage -> MainPage: return null\n_candidatePoi=null, _currentPoi=null
    else top1 == _currentPoi (giu nguyen)
      MainPage -> MainPage: return top1
    else _currentPoi != null va vao vung 2 POI
      MainPage -> MainPage: tim _currentPoi trong candidates
      alt _currentPoi cung MucUuTien voi top1\nVA chenh distance <= 5m
        MainPage -> MainPage: HYSTERESIS: giu _currentPoi\n(tranh nhay POI do GPS jitter)
      else top1 uu tien cao hon\nhoac chenh > 5m
        MainPage -> MainPage: doi sang top1
      end
    end
  end

  alt nearest != _candidatePoi (vao ung vien moi)
    MainPage -> MainPage: _candidatePoi = nearest\n_candidateSinceUtc = now\nreset dwell
  else dwell < 5 giay
    MainPage -> MainPage: tiep tuc cho dwell\nchua audio/chua report CMS
  else dwell >= 5s va isNewPoi va qua cooldown 10 phut
    MainPage -> MainPage: _currentPoi = nearest\n_lastSpokenTime[poiKey] = now\nHighlightNearestPoi()\nRenderPoiCards()

    MainPage -> DeviceIdentity: GetDeviceId()
    MainPage -> HeartbeatController: POST /api/heartbeat/sync-history
    HeartbeatController -> DbContext: LichSuPhats.Where(...).ToListAsync()
    DbContext -> DB: read existing history rows
    DB --> DbContext: history rows
    DbContext --> HeartbeatController: existing rows
    HeartbeatController -> DbContext: LichSuPhats.AddRange()/SaveChangesAsync()
    DbContext -> DB: persist missing LichSuPhat rows
    DB --> DbContext: saved

    MainPage -> HeartbeatController: POST /api/heartbeat/visit
    HeartbeatController -> HeartbeatController: dedup 10 phut\nverify VerifyCurrentPoiAsync (BanKinh+5m)
    HeartbeatController -> DbContext: LichSuPhats.AnyAsync()
    DbContext -> DB: read recent visit rows
    DB --> DbContext: AnyAsync result
    DbContext --> HeartbeatController: daCo
    HeartbeatController -> DbContext: POIs.AsNoTracking().Where(...).Select(...).FirstOrDefaultAsync()
    DbContext -> DB: read claimed POI row
    DB --> DbContext: POI row
    DbContext --> HeartbeatController: poi
    HeartbeatController -> DbContext: LichSuPhats.Add()/SaveChangesAsync()
    DbContext -> DB: persist visit row when needed
    DB --> DbContext: saved

    note right of MainPage
      Tu day chuyen sang SpeakQueue
      (chi tiet o 03b-queue-playback-sequence.puml).
      Phan duoi chi tom tat lai cac
      tuong tac voi backend de ghi log.
    end note

    MainPage -> SpeakQueue: QueuePoiPlayback(nearest)
    note right of SpeakQueue
      lock(_speakQueueGate)
      neu _playingPoi.Id == poi.Id
      hoac _queuedSpeakPoiIds.Contains
      -> SKIP (tranh phat trung POI cu)
      else enqueue + start processor
    end note
    SpeakQueue -> ThuyetMinhController: GET /api/thuyet-minh/{poiId}?lang=langCode
    ThuyetMinhController -> DbContext: POIs.AnyAsync()/ThuyetMinhs.FirstOrDefaultAsync()/BanDichs.FirstOrDefaultAsync()
    DbContext -> DB: read POI, ThuyetMinh and BanDich rows
    DB --> DbContext: rows
    DbContext --> ThuyetMinhController: dto source rows
    ThuyetMinhController --> SpeakQueue: ThuyetMinhResponse

    SpeakQueue -> TTS: SpeakAsync(content)\n(qua _speakLock semaphore - serial)
    TTS --> SpeakQueue: da doc xong

    SpeakQueue -> LogController: POST /api/log
    LogController -> DbContext: LichSuPhats.Add()/SaveChangesAsync()
    DbContext -> DB: persist LichSuPhat row
    DB --> DbContext: saved
  else dwell >= 5s nhung dang cooldown / khong phai POI moi
    MainPage -> MainPage: cap nhat highlight / card / map\n(log "cooldown N phut con lai" neu can)
  end

  opt moi 10 giay
    MainPage -> DeviceIdentity: GetDeviceId()
    MainPage -> HeartbeatController: POST /api/heartbeat
    alt toa do ngoai vung phuc vu
      HeartbeatController --> MainPage: skipped = true,\nreason = out_of_service_area
    else toa do hop le
      HeartbeatController -> HeartbeatController: VerifyCurrentPoiAsync(req.PoiIdHienTai, lat, lng)
      alt user van trong BanKinh+5m cua POI claim
        HeartbeatController -> DbContext: VitriKhachs.FirstOrDefaultAsync()/SaveChangesAsync()
        DbContext -> DB: persist verified VitriKhach snapshot
      else user da ra ngoai BanKinh+5m
        HeartbeatController -> DbContext: VitriKhachs.FirstOrDefaultAsync()/SaveChangesAsync()
        DbContext -> DB: persist VitriKhach snapshot without current POI
      end
      DB --> DbContext: saved
      DbContext --> HeartbeatController: snapshot saved
    end
  end

  opt moi 20 giay
    MainPage -> MainPage: RefreshPoisInBackgroundAsync()
  end
end
@enduml
