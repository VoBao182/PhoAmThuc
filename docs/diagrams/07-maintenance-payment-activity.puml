@startuml
' Diagram: F07 - Ghi nhan phi duy tri va lich su hoa don POI (Activity)
' Status: WIP
' Baseline: branch master, HEAD adb1a28
' Source:
' - VinhKhanhTour.CMS/Pages/ThanhToan/Index.cshtml.cs: OnGetAsync()
' - VinhKhanhTour.CMS/Pages/ThanhToan/GhiNhan.cshtml.cs: OnGetAsync(), OnPostAsync(), LoadPoiAsync()
' - VinhKhanhTour.CMS/Pages/ThanhToan/LichSu.cshtml.cs: OnGetAsync()
' - VinhKhanhTour.API/Models/POI.cs
' - VinhKhanhTour.API/Models/DangKyDichVu.cs
' - VinhKhanhTour.API/Models/HoaDon.cs
' Note: Luong chinh van khop code hien tai; cap nhat them viec Index doc DangKyDichVus active de lay PhiDuyTriThang.
title F07 - Ghi nhan phi duy tri va lich su hoa don POI
start
:ThanhToan/Index.OnGetAsync();
:Load danh sach POI + trang thai han duy tri;
:Load DangKyDichVus.TrangThai active va lay goi moi nhat theo POI;
:Cap nhat PhiDuyTriThang hien thi cho tung POI;
:Tinh SoQuanDaDong / SoQuanQuaHan / SoQuanSapHan / TongThuThang;

if (Admin chon mot POI de ghi nhan?) then (Co)
  :GhiNhan.OnGetAsync(poiId);
  :LoadPoiAsync(poiId);
  :Hien thong tin quan + lich su gan day;

  :Admin nhap soThangGiaHan, phiDuyTriThang, ghiChu;
  if (soThangGiaHan <= 0?) then (Co)
    :Bao loi validation;
  else (Hop le)
    :GhiNhan.OnPostAsync();
    :Tinh mocGiaHan;
    :Cap nhat poi.NgayHetHanDuyTri;
    :poi.TrangThai = true;
    if (Chua co DangKyDichVu?) then (Co)
      :Tao DangKyDichVu moi;
    else (Da co)
      :Cap nhat PhiDuyTriThang va NgayHetHan;
    endif
    :Lap theo soThangGiaHan -> tao HoaDon theo tung ky;
    :SaveChangesAsync();
    :Redirect ve /ThanhToan voi thong bao thanh cong;
  endif
endif

if (Admin muon xem lich su day du?) then (Co)
  :LichSu.OnGetAsync(poiId);
  :Truy van toan bo HoaDons cua POI;
endif

stop
@enduml
