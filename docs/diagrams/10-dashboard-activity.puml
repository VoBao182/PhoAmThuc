@startuml
' Diagram: F10 - Dashboard tong quan va monitoring CMS (Activity)
' Status: WIP
' Baseline: branch master, HEAD adb1a28
' Source:
' - VinhKhanhTour.CMS/Pages/Index.cshtml.cs: OnGetAsync(), ResolveRange(), LoadPoiSectionAsync(), LoadAnalyticsWithRetryAsync(), LoadAnalyticsAsync(), LoadActivityAsync(), LoadGeoAsync(), LoadTopPoiAsync(), LoadRevenueAsync(), LoadSummaryAsync(), FillMissingBuckets()
' - VinhKhanhTour.CMS/Pages/Index.cshtml
' - VinhKhanhTour.CMS/Utils/ImageUrlHelper.cs: ResolvePoi()
' Note: Da sync theo dashboard hien tai co monitoring/analytics, retry ClearNpgsqlPoolsQuietly, va cac truy van raw Npgsql.
title F10 - Dashboard tong quan va monitoring CMS
start
:Index.OnGetAsync(mode,date,week,month,year,from,to);
:ResolveRange();
:Gan SinceUtc, UntilUtc, Granularity, RangeLabel;

:LoadPoiSectionAsync();
if (Load POI thanh cong?) then (Co)
  :_db.POIs.AsNoTracking()\n.Include(MonAns).OrderBy(MucUuTien);
  :Tinh TongPOI, TongMonAn, SoQuanQuaHan;
  :Index.cshtml dung ImageUrlHelper.ResolvePoi de hien anh;
else (Khong)
  :Neu IsDisposedWaitHandle va attempt dau -> ClearNpgsqlPoolsQuietly();
  :Gan ErrorMessage va reset POI stats;
endif

:LoadAnalyticsWithRetryAsync();
if (Analytics thanh cong?) then (Co)
  :LoadAnalyticsAsync();
  :Mo DbConnection neu chua open;
  :LoadActivityAsync();
  :Raw SQL lichsuphat theo bucket -> ActivityBuckets;
  :LoadGeoAsync();
  :Raw SQL lichsuphat join poi -> GeoPoints;
  :LoadTopPoiAsync();
  :Raw SQL top POI theo views/visits;
  :LoadRevenueAsync();
  :Raw SQL dangkyapp + hoadon -> RevenueBuckets;
  :LoadSummaryAsync();
  :Tinh TotalActiveDevices, TotalViews, TotalVisits, TotalRevenue;
  :FillMissingBuckets();
else (Khong)
  :Neu IsDisposedWaitHandle va attempt dau -> ClearNpgsqlPoolsQuietly();
  :ResetAnalytics();
  :Gan AnalyticsError;
endif

:Serialize ActivityJson, GeoJson, RevenueJson;
:Render dashboard + monitoring section trong Index.cshtml;
stop
@enduml
