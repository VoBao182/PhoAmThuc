@startuml
' Diagram: F03 - Theo doi GPS, geofence va tu dong phat thuyet minh (Activity)
' Status: VERIFIED
' Baseline: HEAD 8ca9ec7
' Source:
' - VinhKhanhTourDemo/MainPage.xaml.cs: EnsureGpsTrackingAsync(), StartGpsTracking(), CheckGeofence(), SelectPoiForLocation(), ToPlaybackItem(), SendHeartbeatAsync(), RecordPoiVisitAsync(), SyncPoiHistoryAsync(), QueuePoiPlayback(), ProcessSpeakQueueAsync(), SpeakPoiAsync(), LogPlaybackAsync()
' - VinhKhanhTourDemo/PoiPlaybackLogic.cs: PoiGeofenceSelector.Select(), HaversineMeters()
' - VinhKhanhTourDemo/AppConfig.cs: EnsureApiBaseUrlAsync()
' - VinhKhanhTourDemo/DeviceIdentity.cs: GetDeviceId()
' - VinhKhanhTour.API/Controllers/HeartbeatController.cs: SendHeartbeat(), RecordVisit(), SyncHistory(), VerifyCurrentPoiAsync()
' - VinhKhanhTour.API/Controllers/ThuyetMinhController.cs: GetByPoi()
' - VinhKhanhTour.API/Controllers/LogController.cs: Post()
' Note: Code hien tai xac nhan vao POI sau khi dwell 5 giay trong ban kinh. Heartbeat gui moi 10 giay va refresh POI moi 20 giay voi GPS poll 5 giay.
' Note: Nhanh "giua 2 POI" duoc tach tuong minh: sort theo MucUuTien -> Distance -> TenPOI; hysteresis 5m giu POI cu khi cung MucUuTien.
' Note: Queue audio per-device (1 may): _speakQueue + _queuedSpeakPoiIds dedup, _speakQueueGate lock, _speakLock semaphore serial hoa TTS. Sub-activity tach o 03b-queue-playback-activity.puml.
' Note: Luong geofence hien tai lay NoiDung thuyet minh qua API roi doc bang TTS. API van tra ca FileAudio, nhung geofence auto-play khong phat file audio truc tiep; FileAudio duoc dung o F04.
' Note: Geofence/audio luon dua tren toa do that cua POI (ViDo/KinhDo, BanKinh). Marker offset tren map chi la presentation, khong doi logic geofence.
title F03 - Theo doi GPS, geofence va tu dong phat thuyet minh
start
:EnsureGpsTrackingAsync();
if (Da duoc cap quyen vi tri?) then (Co)
  :StartGpsTracking();
else (Khong)
  :DisplayAlert can cap quyen vi tri;
  stop
endif

while (token chua bi cancel?) is (Co)
  :Geolocation.Default.GetLocationAsync();
  if (location != null?) then (Co)
    :_userLocation = location;
    :CheckGeofence(location);
    :UpdateUserLocationOnMap(location);

    partition "SelectPoiForLocation - xu ly chong lan giua 2 POI" {
      :_pois.Select(ToPlaybackItem());
      :PoiGeofenceSelector.Select(\nplaybackItems, userLocation,\n_currentPoi?.Id, PoiSwitchDistanceBufferMeters);
      :Tinh HaversineMeters toi tat ca POI;
      :Loc candidates co distance <= BanKinh;
      if (candidates rong?) then (Co)
        :return null;
      else (Khong)
        :Sort: MucUuTien ASC -> DistanceMeters ASC -> TenPOI;
        :top1 = candidates[0];
        if (_currentPoi null hoac _currentPoi.Id == top1.Id?) then (Co)
          :return top1;
        else (Khong - dang giao 2 POI)
          :Tim _currentPoi trong candidates;
          if (_currentPoi van trong ban kinh\nVA cung MucUuTien voi top1\nVA chenh top1 <= 5m?) then (Co)
            :Hysteresis: giu _currentPoi\n(tranh nhay qua lai do GPS jitter);
          else (Khong)
            :Doi sang top1\n(POI uu tien cao hon hoac\nxa hon top1 > 5m);
          endif
        endif
      endif
    }

    if (co ung vien POI trong ban kinh?) then (Co)
      if (_candidatePoi khac nearest?) then (Co)
        :Gan _candidatePoi = nearest;
        :Gan _candidateSinceUtc = now;
        :Reset dwell timer;
        note right
          Vao mep POI hoac doi candidate
          giua chu ky GPS jitter -> dwell
          reset, KHONG trigger audio.
        end note
      else (Khong)
        if (dwell < 5 giay?) then (Co)
          :Tiep tuc dwell, chua audio/chua report CMS;
        else (Khong)
          :Xac nhan _currentPoi = nearest;
          :HighlightNearestPoi();\nRenderPoiCards();
          if (isNewPoi VA qua cooldown 10 phut?) then (Co)
            :_lastSpokenTime[poiKey] = now;
            :RecordVisitedPoi(nearest);
            :SyncPoiHistoryAsync();
            :POST /api/heartbeat/sync-history;
            :RecordPoiVisitAsync(nearest);
            :POST /api/heartbeat/visit;
            note right
              Server dedup 10 phut o
              LichSuPhat(Nguon=app-geofence)
              + verify lai BanKinh+5m.
            end note
            :QueuePoiPlayback(nearest);
            note right
              Sub-activity tach rieng:
              03b-queue-playback-activity.puml
              (enqueue voi dedup, processor
              don, _speakLock serial hoa TTS).
            end note
            partition "SpeakPoiAsync - lay noi dung va doc TTS" {
              :langCode = AppText.LanguageCode;
              :AppConfig.EnsureApiBaseUrlAsync(_http);
              :GET /api/thuyet-minh/{poiId}?lang={langCode};
              :NormalizeLanguageCode(lang);
              :Kiem tra POI con hoat dong\n(TrangThai=true, con han duy tri);
              :Lay ThuyetMinh dau tien dang TrangThai=true\nOrderBy(ThuTu);
              :Lay BanDich uu tien langCode,\nfall back ve vi;
              :Tra ThuyetMinhDto(NoiDung, FileAudio, NgonNgu);
              if (NoiDung rong?) then (Co)
                :content = greeting fallback theo ngon ngu;
              else (Khong)
                :content = NoiDung;
              endif
              note right
                FileAudio co trong DTO tra ve,
                nhung luong geofence hien tai
                chi dung NoiDung + TTS.
                Phat file audio truc tiep nam o F04.
              end note
              :TextToSpeech.Default.GetLocalesAsync();
              :Chon locale theo langCode;
              :ShowNowPlaying(); RenderPoiCards();
              :TextToSpeech.Default.SpeakAsync(content, locale);
              :LogPlaybackAsync(poi.Id, langCode);
              :POST /api/log (Nguon=GPS);
            }
            :UpdateCaiDatUI();
          else (Khong)
            :Chi highlight / render lai card\n(hoac chi log "cooldown N phut con lai");
          endif
        endif
      endif
    else (Khong)
      :_candidatePoi = null;
      :ClearHighlight();
      :_currentPoi = null;
      :RenderPoiCards();
    endif

    if (den nhip heartbeat 10s?) then (Co)
      :SendHeartbeatAsync(lat, lng, currentPoi?);
      :DeviceIdentity.GetDeviceId();
      :POST /api/heartbeat;
      note right
        Server bo qua toa do ngoai vung phuc vu.
        VerifyCurrentPoiAsync re-check claim:
        neu user khong con trong BanKinh+5m
        -> drop currentPoi, CMS hien
        "online/dang di chuyen" thay vi "o quan".
      end note
    endif

    if (den nhip refresh POI 20s?) then (Co)
      :RefreshPoisInBackgroundAsync();
    endif
  else (Khong)
    :GpsStatusDot = xam;
  endif
endwhile (Khong)
stop
@enduml
