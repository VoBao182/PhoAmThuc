@startuml
' Diagram: F03 - Theo doi GPS, geofence va tu dong phat thuyet minh (Activity)
' Status: WIP
' Baseline: branch master, HEAD 29947b2
' Source:
' - VinhKhanhTourDemo/MainPage.xaml.cs: EnsureGpsTrackingAsync(), StartGpsTracking(), CheckGeofence(), SendHeartbeatAsync(), RecordPoiVisitAsync(), SyncPoiHistoryAsync(), SpeakPoiAsync(), LogPlaybackAsync()
' - VinhKhanhTourDemo/DeviceIdentity.cs: GetDeviceId()
' - VinhKhanhTour.API/Controllers/HeartbeatController.cs: SendHeartbeat(), RecordVisit(), SyncHistory()
' - VinhKhanhTour.API/Controllers/ThuyetMinhController.cs: GetByPoi()
' - VinhKhanhTour.API/Controllers/LogController.cs: Post()
' Note: Da doi heartbeat 10 giay va refresh POI 20 giay theo constants HEARTBEAT_EVERY_TICKS=2, POI_REFRESH_EVERY_TICKS=4 voi GPS poll 5 giay.
title F03 - Theo doi GPS, geofence va tu dong phat thuyet minh
start
:EnsureGpsTrackingAsync();
if (Da duoc cap quyen vi tri?) then (Co)
  :StartGpsTracking();
else (Khong)
  :DisplayAlert can cap quyen vi tri;
  stop
endif

while (token chua bi cancel?) is (Co)
  :Geolocation.Default.GetLocationAsync();
  if (location != null?) then (Co)
    :_userLocation = location;
    :CheckGeofence(location);
    :UpdateUserLocationOnMap(location);

    if (den nhip heartbeat 10s?) then (Co)
      :SendHeartbeatAsync(lat, lng);
      :DeviceIdentity.GetDeviceId();
      :POST /api/heartbeat;
    endif

    if (den nhip refresh POI 20s?) then (Co)
      :RefreshPoisInBackgroundAsync();
    endif

    if (tim thay nearest POI nam trong ban kinh?) then (Co)
      if (isNewPoi && qua cooldown?) then (Co)
        :RecordVisitedPoi(nearest);
        :SyncPoiHistoryAsync();
        :POST /api/heartbeat/sync-history;
        :RecordPoiVisitAsync(nearest);
        :POST /api/heartbeat/visit;
        :UpdateCaiDatUI();
        :SpeakPoiAsync(nearest);
        :GET /api/thuyet-minh/{poiId}?lang=...;
        if (Co NoiDung/API hop le?) then (Co)
          :TextToSpeech.Default.SpeakAsync(content);
        else (Khong)
          :Speak text fallback;
        endif
        :LogPlaybackAsync(poiId, lang);
        :POST /api/log;
      else (Khong)
        :Chi highlight / render lai card;
      endif
    else (Khong)
      :ClearHighlight();
      :_currentPoi = null;
    endif
  else (Khong)
    :GpsStatusDot = xam;
  endif
endwhile (Khong)
stop
@enduml
