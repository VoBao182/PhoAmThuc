@startuml
' Diagram: F05 - Thanh toan goi tra phi va cho duyet (Activity)
' Status: VERIFIED
' Baseline: branch master, current worktree @ HEAD 3158ff7
' Source:
' - VinhKhanhTourDemo/PaymentPage.xaml.cs: SetupUi(), OnCopyNoiDungClicked(), OnDaChuyenKhoanClicked()
' - VinhKhanhTourDemo/DeviceIdentity.cs: GetDeviceId()
' - VinhKhanhTourDemo/ApiConnectionPrompt.cs: EnsureConnectedApiBaseUrlAsync()
' - VinhKhanhTourDemo/PaymentStatusPage.xaml.cs: OnAppearing(), StartPollingAsync(), PollStatusAsync(), ShowSuccess(), ShowRejected(), ClosePaymentFlowAsync()
' - VinhKhanhTour.API/Controllers/SubscriptionController.cs: CreateRequest(), GetRequestStatus()
' Note: So do chi tiet hoa tao noi dung chuyen khoan/VietQR, prompt API URL, polling 10 giay, va cach dong modal stack sau khi duyet/tu choi.
title F05 - Thanh toan goi tra phi va cho duyet
start
:SubscriptionPage.OnMuaGoiClicked(loaiGoi != "thu");
:Navigation.PushModalAsync(PaymentPage);
:DeviceIdentity.GetDeviceId();
:PaymentPage.SetupUi();
:Tao _noiDungChuyen = "VKT <GOI> <SHORTID>";
:Sinh URL VietQR va hien QR;
:HideApiGuide();

if (Nguoi dung bam copy noi dung?) then (Co)
  :Clipboard.SetTextAsync(_noiDungChuyen);
endif

if (Nguoi dung bam "Da chuyen khoan"?) then (Co)
  :OnDaChuyenKhoanClicked();
  :ApiConnectionPrompt.EnsureConnectedApiBaseUrlAsync();
  if (Tim thay API dung va reachable?) then (Co)
    :POST /api/subscription/request;
    :PushModalAsync(PaymentStatusPage);
    while (Trang thai van la cho_duyet?) is (Co)
      :PollStatusAsync();
      :GET /api/subscription/request/{yeuCauId};
      :dem nguoc 10 giay;
    endwhile (Khong)

    if (trangThai == da_duyet?) then (Co)
      :ShowSuccess();
      :Preferences.Set(sub_ngay_het_han);
      :Nguoi dung bam Bat dau;
      :ClosePaymentFlowAsync(closeSubscriptionPage:true);
      :Pop het modal;\nneu stack goc cuoi la SubscriptionPage\nthi PushAsync(MainPage) + RemovePage(SubscriptionPage);
    else (tu_choi)
      :ShowRejected(lyDo);
      :Nguoi dung bam Thu lai hoac Dong;
      :PopModalAsync() hoac ClosePaymentFlowAsync(false);
    endif
  else (Khong)
    :Neu can -> prompt nhap API URL thu cong;
    :Hien loi ket noi / loi tao yeu cau;
  endif
else (Khong)
  :Nguoi dung dong PaymentPage;
endif
stop
@enduml
