  usecase "F03\nTheo doi GPS,\ngeofence, auto audio" as UC03
  usecase "F04\nXem chi tiet POI,\nthuc don, audio, maps" as UC04
  usecase "F05\nThanh toan goi\ntra phi va cho duyet" as UC05

  usecase "F06\nQuan ly POI,\nanh, geofence,\nthuyet minh, menu" as UC06
  usecase "F07\nGhi nhan phi duy tri\nva lich su hoa don" as UC07
  usecase "F08\nDuyet / tu choi\nthanh toan goi app" as UC08
  usecase "F09\nTheo doi khach hang,\ntrang thai su dung,\nXP va hanh trinh" as UC09
  usecase "F10\nDashboard tong quan\nva monitoring CMS" as UC10
}

Guest --> UC01
Guest --> UC02
Guest --> UC03
Guest --> UC04
Guest --> UC05

Admin --> UC06
Admin --> UC07
Admin --> UC08
