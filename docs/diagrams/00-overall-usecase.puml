  usecase "F08\nDuyet / tu choi\nthanh toan goi app" as UC08
  usecase "F09\nBan do live va\nhanh trinh khach" as UC09
  usecase "F10\nDashboard tong quan CMS" as UC10
}

Guest --> UC01
Guest --> UC02
Guest --> UC03
Guest --> UC04
Guest --> UC05

Admin --> UC06
Admin --> UC07
