@startuml
' Diagram: F06 - Quan ly POI, anh, geofence, thuyet minh va menu (Sequence)
' Status: VERIFIED
' Baseline: branch master, current worktree @ HEAD 2497a96
' Source:
' - VinhKhanhTour.CMS/Pages/Poi/Index.cshtml.cs: OnGetAsync(), OnPostToggleAsync()
' - VinhKhanhTour.CMS/Pages/Poi/Create.cshtml.cs: OnPostAsync()
' - VinhKhanhTour.CMS/Pages/Poi/Edit.cshtml.cs: OnPostAsync(), UpsertBanDich()
' - VinhKhanhTour.CMS/Utils/ImageUrlHelper.cs: ResolvePoi(), ResolveDish()
' - VinhKhanhTour.CMS/Pages/Poi/Create.cshtml: doUpload()
' - VinhKhanhTour.CMS/Pages/Poi/Edit.cshtml: doUpload()
' - VinhKhanhTour.API/Controllers/UploadController.cs: Upload()
' Note: Sequence khop voi Create/Edit hien tai, gom upload anh, free trial 30 ngay cho POI moi, xu ly MonAns rong/null, va cac nhanh loi DB/concurrency.
title F06 - Quan ly POI, anh, geofence, thuyet minh va menu

actor Admin
participant "Create/Edit.cshtml JS" as JS
participant "Poi IndexModel" as IndexModel
participant ImageUrlHelper
participant "UploadController" as UploadController
participant "CreateModel / EditModel" as PageModel
participant AppDbContext
database DB
collections "wwwroot/uploads" as UploadStore

opt mo danh sach /Poi
  Admin -> IndexModel: OnGetAsync(search,status,expiry,sort,dir)
  IndexModel -> AppDbContext: POIs.Include(MonAns).AsNoTracking()
  AppDbContext -> DB: SELECT POI + MonAns
  DB --> AppDbContext: pois
  IndexModel -> IndexModel: ApplyStatusFilter()\nApplyExpiryFilter()\nApplySort()
  IndexModel -> ImageUrlHelper: ResolvePoi()/ResolveDish() trong view
  ImageUrlHelper --> Admin: URL anh hoac fallback
end

opt upload cover hoac anh mon an
  Admin -> JS: chon file anh
  JS -> UploadController: fetch POST /api/upload
  UploadController -> UploadStore: File.Create(fullPath)\nCopyToAsync(stream)
  UploadStore --> UploadController: file saved
  UploadController --> JS: { url: "/uploads/..." }
  JS --> Admin: gan url vao form + previewImg()/setMonAnPreview()
end

alt tao POI moi
  Admin -> PageModel: submit /Poi/Create
  PageModel -> PageModel: CreateModel.OnPostAsync()
  alt ModelState hop le
    PageModel -> PageModel: Tao POI + ThuyetMinh + BanDich\nNeu chua co NgayHetHanDuyTri -> UtcNow + 30 ngay\nLoc MonAns co TenMonAn\nDonGia null -> 0
    PageModel -> AppDbContext: Add(POI)
    alt SaveChangesAsync thanh cong
      AppDbContext -> DB: INSERT poi/thuyetminh/bandich/monan
      DB --> AppDbContext: saved
      AppDbContext --> PageModel: SaveChangesAsync()
      PageModel --> Admin: Redirect /Poi
    else loi DB
      AppDbContext --> PageModel: Exception
      PageModel -> PageModel: LogError()\nTempData["Error"]
      PageModel --> Admin: return Page()
    end
  else ModelState khong hop le
    PageModel --> Admin: return Page()
  end
else sua POI hien co
  Admin -> PageModel: submit /Poi/Edit/{id}
  PageModel -> PageModel: EditModel.OnPostAsync()\nModelState.Remove("MonAns[*]")
  alt van con loi validation tren POI
    PageModel -> PageModel: TempData["Error"]\nRebuild POI.MonAns tu input dang nhap\nLoc MonAns rong\nDonGia null -> 0
    PageModel --> Admin: return Page()
  else du lieu hop le
    PageModel -> AppDbContext: load POI + MonAns + ThuyetMinhs
    AppDbContext -> DB: SELECT data hien co
    DB --> AppDbContext: entity graph
    PageModel -> PageModel: cap nhat POI\nUpsertBanDich()\nTim formIds co Id hop le\nDeactivate MonAns mat khoi form\nAdd/update MonAns co TenMonAn\nDonGia null -> 0
    alt SaveChangesAsync thanh cong
      AppDbContext -> DB: UPDATE + INSERT related rows
      DB --> AppDbContext: saved
      PageModel --> Admin: Redirect reload /Poi/Edit/{id}
    else DbUpdateConcurrencyException
      AppDbContext --> PageModel: concurrency exception
      PageModel -> PageModel: LogWarning()\nTempData["Error"]
      PageModel --> Admin: Redirect reload /Poi/Edit/{id}
    else loi DB khac
      AppDbContext --> PageModel: exception
      PageModel -> PageModel: LogError()\nTempData["Error"]\nBuildMenuItemsFromInput()
      PageModel --> Admin: return Page()
    end
  end
end

opt bat/tat hien thi POI
  Admin -> IndexModel: POST /Poi?handler=Toggle
  IndexModel -> AppDbContext: FindAsync(id)
  IndexModel -> AppDbContext: poi.TrangThai = !poi.TrangThai
  AppDbContext -> DB: UPDATE poi.trangthai
end
@enduml
