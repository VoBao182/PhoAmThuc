@startuml
' Diagram: F06 - Quan ly POI, anh, geofence, thuyet minh va menu (Sequence)
' Status: VERIFIED
' Baseline: branch master, current worktree @ HEAD 0121e4f
' Source:
' - VinhKhanhTour.CMS/Pages/Poi/Index.cshtml.cs: OnGetAsync(), OnPostToggleAsync()
' - VinhKhanhTour.CMS/Pages/Poi/Create.cshtml.cs: OnPostAsync()
' - VinhKhanhTour.CMS/Pages/Poi/Edit.cshtml.cs: OnPostAsync(), UpsertBanDich()
' - VinhKhanhTour.CMS/Utils/ImageUrlHelper.cs: ResolvePoi(), ResolveDish()
' - VinhKhanhTour.CMS/Pages/Poi/Create.cshtml: doUpload()
' - VinhKhanhTour.CMS/Pages/Poi/Edit.cshtml: doUpload()
' - VinhKhanhTour.API/Controllers/UploadController.cs: Upload()
' Note: Sequence nay mo ta tuong tac o cap UI / PageModel / Controller / persistence; khong liet ke cau SQL.
' Note: Luong khop voi Create/Edit hien tai, gom upload anh, free trial 30 ngay cho POI moi, xu ly MonAns rong/null, va cac nhanh loi DB/concurrency.
title F06 - Quan ly POI, anh, geofence, thuyet minh va menu

actor Admin
boundary "Create/Edit.cshtml JS" as JS
control "Poi IndexModel" as IndexModel
control ImageUrlHelper
control "UploadController" as UploadController
control "CreateModel / EditModel" as PageModel
participant "AppDbContext\n<<persistence>>" as DbContext
database "PostgreSQL" as DB
collections "wwwroot/uploads" as UploadStore

opt open /Poi
  Admin -> IndexModel: OnGetAsync(search, status, expiry, sort, dir)
  IndexModel -> DbContext: POIs.Include(MonAns).AsNoTracking().ToListAsync()
  DbContext -> DB: read POI and MonAn rows
  DB --> DbContext: POI + MonAn rows
  DbContext --> IndexModel: pois
  IndexModel -> IndexModel: ApplyStatusFilter()\nApplyExpiryFilter()\nApplySort()
  IndexModel -> ImageUrlHelper: ResolvePoi()/ResolveDish()
  ImageUrlHelper --> Admin: resolved image URL
end

opt upload cover image or dish image
  Admin -> JS: doUpload()
  JS -> UploadController: POST /api/upload
  UploadController -> UploadStore: File.Create(fullPath)\nCopyToAsync(stream)
  UploadStore --> UploadController: file saved
  UploadController --> JS: { url: "/uploads/..." }
  JS --> Admin: previewImg()/setMonAnPreview()
end

alt create POI
  Admin -> PageModel: OnPostAsync()
  PageModel -> PageModel: CreateModel.OnPostAsync()
  alt ModelState hop le
    note right of PageModel
      OnPostAsync() builds:
      - POI
      - ThuyetMinh
      - BanDich
      - filtered MonAns
      It also sets NgayHetHanDuyTri
      when the value is null.
    end note
    PageModel -> DbContext: Add(POI)
    alt SaveChangesAsync thanh cong
      DbContext -> DB: persist POI aggregate
      DB --> DbContext: saved
      DbContext --> PageModel: SaveChangesAsync()
      PageModel --> Admin: Redirect /Poi
    else loi DB
      DbContext --> PageModel: Exception
      PageModel -> PageModel: LogError()\nTempData["Error"]
      PageModel --> Admin: return Page()
    end
  else ModelState invalid
    PageModel --> Admin: return Page()
  end
else edit existing POI
  Admin -> PageModel: OnPostAsync(id)
  PageModel -> PageModel: EditModel.OnPostAsync()\nModelState.Remove("MonAns[*]")
  alt POI validation still fails
    note right of PageModel
      OnPostAsync() rebuilds POI.MonAns
      from current input so the form
      can be rendered again.
    end note
    PageModel --> Admin: return Page()
  else ModelState valid
    PageModel -> DbContext: POIs.Include(MonAns).Include(ThuyetMinhs).FirstOrDefaultAsync()
    DbContext -> DB: read current entity graph
    DB --> DbContext: entity graph rows
    DbContext --> PageModel: entity graph
    PageModel -> PageModel: UpsertBanDich()
    note right of PageModel
      OnPostAsync() then:
      - updates POI fields
      - matches formIds
      - deactivates removed MonAns
      - adds or updates valid MonAns
    end note
    alt SaveChangesAsync thanh cong
      PageModel -> DbContext: SaveChangesAsync()
      DbContext -> DB: persist aggregate changes
      DB --> DbContext: saved
      PageModel --> Admin: Redirect reload /Poi/Edit/{id}
    else DbUpdateConcurrencyException
      DbContext --> PageModel: concurrency exception
      PageModel -> PageModel: LogWarning()\nTempData["Error"]
      PageModel --> Admin: Redirect reload /Poi/Edit/{id}
    else loi DB khac
      DbContext --> PageModel: exception
      PageModel -> PageModel: LogError()\nTempData["Error"]\nBuildMenuItemsFromInput()
      PageModel --> Admin: return Page()
    end
  end
end

opt toggle POI visibility
  Admin -> IndexModel: OnPostToggleAsync(id)
  IndexModel -> DbContext: FindAsync(id)
  DbContext -> DB: read target POI row
  DB --> DbContext: poi row
  DbContext --> IndexModel: poi
  note right of IndexModel
    OnPostToggleAsync() flips
    poi.TrangThai in memory.
  end note
  IndexModel -> DbContext: SaveChangesAsync()
  DbContext -> DB: persist TrangThai change
end
@enduml
