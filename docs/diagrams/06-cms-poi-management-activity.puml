@startuml
' Diagram: F06 - Quan ly POI, anh, geofence, thuyet minh va menu (Activity)
' Status: WIP
' Baseline: branch master, HEAD 0b9ca4b + working tree 2026-04-22
' Source:
' - VinhKhanhTour.CMS/Pages/Poi/Index.cshtml.cs: OnGetAsync(), ApplyStatusFilter(), ApplyExpiryFilter(), ApplySort(), OnPostToggleAsync()
' - VinhKhanhTour.CMS/Pages/Poi/Create.cshtml.cs: OnPostAsync()
' - VinhKhanhTour.CMS/Pages/Poi/Edit.cshtml.cs: OnGetAsync(), OnPostAsync(), UpsertBanDich()
' - VinhKhanhTour.CMS/Pages/ThuyetMinh/Index.cshtml.cs: OnGetAsync()
' - VinhKhanhTour.CMS/Utils/ImageUrlHelper.cs: ResolvePoi(), ResolveDish()
' - VinhKhanhTour.CMS/Pages/Poi/Create.cshtml: doUpload(), uploadImg(), uploadMonAnImg()
' - VinhKhanhTour.CMS/Pages/Poi/Edit.cshtml: doUpload(), uploadImg(), uploadMonAnImg()
' - VinhKhanhTour.API/Controllers/UploadController.cs: Upload()
' Note: Da them filter/sort/search va fallback anh CMS theo code hien tai; van WIP vi cac trang .cshtml dang trong worktree modified.
title F06 - Quan ly POI, anh, geofence, thuyet minh va menu
start
:Admin mo /Poi hoac /Poi/Create hoac /Poi/Edit/{id};

if (Admin mo danh sach /Poi?) then (Co)
  :IndexModel.OnGetAsync(search,status,expiry,sort,dir);
  :Query POIs.Include(MonAns);
  :Neu co search -> loc TenPOI/DiaChi/SDT;
  :ApplyStatusFilter();
  :ApplyExpiryFilter();
  :ApplySort();
  :Index.cshtml dung ImageUrlHelper.ResolvePoi/ResolveDish de hien anh;
endif

if (Can tai anh cover / anh mon an?) then (Co)
  :JS doUpload(file);
  :fetch POST /api/upload;
  :UploadController.Upload(IFormFile);
  :Luu file vao wwwroot/uploads;
  :Tra ve url tuong doi;
  :Gan url vao input POI.AnhDaiDien hoac MonAns[i].HinhAnh;
endif

if (Dang tao POI moi?) then (Co)
  :CreateModel.OnPostAsync();
  :Tao POI.Id moi;
  :Tao ThuyetMinh + cac BanDich vi/en/zh;
  :Tao danh sach MonAns tu form;
  :_db.POIs.Add(POI);
else (Sua POI)
  :EditModel.OnPostAsync();
  :Load POI + MonAns + ThuyetMinhs;
  :Cap nhat thong tin POI;
  :UpsertBanDich("vi"|"en"|"zh");
  :Danh dau MonAn khong con tren form -> TinhTrang=false;
  :Them moi / cap nhat MonAn;
endif

:SaveChangesAsync();
:Redirect ve /Poi hoac reload trang edit;

if (Admin bam Hien/An trong danh sach?) then (Co)
  :IndexModel.OnPostToggleAsync(id);
  :poi.TrangThai = !poi.TrangThai;
  :SaveChangesAsync();
endif

if (Admin mo /ThuyetMinh?) then (Co)
  :ThuyetMinh.Index.OnGetAsync();
  :Query POIs va ThuyetMinhs.TrangThai;
  :Select BanDich vi/en/zh co NoiDung;
  :Render so ban dich va noi dung theo POI;
endif

stop
@enduml
